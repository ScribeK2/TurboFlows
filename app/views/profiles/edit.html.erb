<% content_for(:title) { "Profile — TurboFlows" } %>

<div class="page-content">
  <div class="page-main">
    <div class="page-header-section">
      <div>
        <h1 class="page-header-section__title">Profile</h1>
        <p class="page-header-section__subtitle">Your name and time zone</p>
      </div>
    </div>

    <div class="card">
      <div class="card__body">
        <%= form_with model: current_user, url: profile_path, method: :patch, class: "space-y-4" do |f| %>
          <% if current_user.errors.any? %>
            <div class="flash flash--alert" role="alert" style="position: static; margin-bottom: var(--space-4);">
              <strong><%= pluralize(current_user.errors.count, "error") %> prevented saving:</strong>
              <ul class="mt-2" style="padding-inline-start: var(--space-5);">
                <% current_user.errors.full_messages.each do |msg| %>
                  <li><%= msg %></li>
                <% end %>
              </ul>
            </div>
          <% end %>

          <div class="form-group">
            <label class="form-label">Email</label>
            <input type="text" class="form-input" value="<%= current_user.email %>" disabled
                   aria-describedby="email-hint">
            <p class="form-hint" id="email-hint">
              Change your email under
              <%= link_to "Account settings", edit_user_registration_path %>.
            </p>
          </div>

          <div class="form-group">
            <%= f.label :display_name, "Display name", class: "form-label" %>
            <%= f.text_field :display_name, class: "form-input",
                  placeholder: "How should we address you?",
                  autocomplete: "name", maxlength: 50 %>
            <p class="form-hint">Used in your dashboard greeting and on shared workflows. Up to 50 characters.</p>
          </div>

          <div class="form-group">
            <%= f.label :time_zone, "Time zone", class: "form-label is-required" %>
            <%= f.time_zone_select :time_zone,
                  ActiveSupport::TimeZone.us_zones,
                  { default: current_user.time_zone, include_blank: false },
                  class: "form-select" %>
            <p class="form-hint">
              Used for the dashboard greeting, scenario timestamps, and any time-of-day logic.
              Currently
              <strong>
                <%= ActiveSupport::TimeZone[current_user.time_zone]&.now&.strftime("%-l:%M %p") || "—" %>
              </strong>
              in your selected zone.
            </p>
          </div>

          <div class="flex items-center justify-end gap-3"
               style="padding-top: var(--space-4); border-top: 1px solid var(--color-border);">
            <%= link_to "Cancel", root_path, class: "btn btn--plain" %>
            <%= f.submit "Save changes", class: "btn btn--primary" %>
          </div>
        <% end %>
      </div>
    </div>
  </div>
</div>
