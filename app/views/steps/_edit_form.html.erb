<%#
  Step Edit Form — loaded lazily inside a Turbo Frame when a step card is expanded.

  Local variables:
  - step: AR Step object
  - workflow: Workflow object
%>
<%= turbo_frame_tag dom_id(step, :form) do %>
  <%= form_with model: step, scope: :step, url: workflow_step_path(workflow, step), method: :patch,
      class: "step-edit-form",
      data: { controller: "inline-autosave", "inline-autosave-delay-value": 2000 } do |f| %>

    <div class="form-group">
      <%= f.label :title, class: "form-label" %>
      <%= f.text_field :title, class: "form-input", required: true,
          placeholder: "Enter a descriptive title...",
          data: { action: "input->inline-autosave#schedule" } %>
    </div>

    <div class="form-group">
      <%= f.label :help_text, "Guidance Note", class: "form-label" %>
      <%= f.text_field :help_text, class: "form-input",
          maxlength: 500,
          placeholder: "Optional coaching note for CSRs (e.g., 'Ask this verbatim')",
          data: { action: "input->inline-autosave#schedule input->inline-autosave#updateCharCount",
                  inline_autosave_target: "charCountInput",
                  char_count_max: 500 } %>
      <p class="form-hint" data-inline-autosave-target="charCount"><%= step.help_text&.length || 0 %>/500</p>
    </div>

    <div class="form-group">
      <%= f.label :reference_url, "Reference Link", class: "form-label" %>
      <%= f.text_field :reference_url, class: "form-input",
          placeholder: "https://kb.example.com/article or internal path",
          data: { action: "input->inline-autosave#schedule" } %>
      <p class="form-hint">Optional link to a knowledge base article or external resource</p>
    </div>

    <%# Type-specific fields %>
    <%= render "steps/fields/#{step.step_type}", form: f, step: step, workflow: workflow %>

    <%# Transitions editor (graph mode, non-resolve steps) %>
    <% if workflow.graph_mode? && !step.is_a?(Steps::Resolve) %>
      <%= render "steps/transitions_editor", step: step, workflow: workflow %>
    <% end %>

    <div class="flex justify-end gap-2 mt-4">
      <%= f.submit "Save", class: "btn btn--primary btn--sm" %>
    </div>
  <% end %>
<% end %>
