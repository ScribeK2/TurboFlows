<%#
  Sub-flow target workflow preview card.
  Rendered inside #subflow-preview and updated via Turbo Stream on target change.

  Local variables: step (Steps::SubFlow)
%>
<% if step.sub_flow_workflow_id.present? %>
  <% target_workflow = step.target_workflow %>
  <% if target_workflow %>
    <div class="subflow-preview card card--sub-flow">
      <div class="flex items-center justify-between">
        <div>
          <h4 class="text-sm font-medium"><%= target_workflow.title %></h4>
          <p class="form-hint mt-0.5 mb-0">
            <%= target_workflow.steps.size %> steps
            <% if target_workflow.graph_mode? %>
              <span class="ml-1 badge">Graph</span>
            <% end %>
          </p>
        </div>
        <%= link_to workflow_path(target_workflow), target: "_blank", class: "btn btn--plain btn--sm" do %>
          View
          <%= icon "arrow-top-right-on-square", class: "icon icon--xs ml-0.5 inline" %>
        <% end %>
      </div>
    </div>
  <% end %>
<% end %>
