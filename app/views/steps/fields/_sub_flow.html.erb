<%#
  Sub-flow step fields.
  Local variables: form (FormBuilder), step (Steps::SubFlow), workflow
%>
<div class="form-group"
     data-controller="subflow-selector"
     data-subflow-selector-current-workflow-id-value="<%= workflow.id %>">
  <%= form.label :sub_flow_workflow_id, "Target Workflow", class: "form-label" %>

  <select data-subflow-selector-target="select"
          data-action="change->subflow-selector#selectWorkflow change->inline-autosave#schedule"
          class="form-select w-full"
          name="step[sub_flow_workflow_id]">
    <option value="">-- Select a workflow --</option>
  </select>
  <%= form.hidden_field :sub_flow_workflow_id, data: { subflow_selector_target: "hiddenInput" } %>

  <p class="form-hint">
    Select a published workflow to execute as a sub-routine.
  </p>
</div>

<div id="subflow-preview">
  <%= render "steps/fields/sub_flow_preview", step: step %>
</div>

<div class="form-group mt-4">
  <label class="form-label">Variable Mapping <span class="font-normal">(optional)</span></label>
  <div class="variable-mapping-box card card--muted">
    <p class="form-hint mb-2">
      By default, all parent workflow variables are passed to the sub-flow.
    </p>
    <div class="form-hint italic mb-0">
      Advanced variable mapping editor coming soon.
    </div>
  </div>
</div>
