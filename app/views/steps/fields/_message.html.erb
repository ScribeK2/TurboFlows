<%#
  Message step fields.
  Local variables: form (FormBuilder), step (Steps::Message), workflow
%>
<div class="alert alert--info flex items-start gap-3 mb-4">
  <svg class="icon icon--sm flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
  </svg>
  <p class="text-sm">
    <strong>Message Step:</strong> Display information or guidance to the CSR. Use <code>{{variable_name}}</code> for dynamic content.
  </p>
</div>

<div class="form-group">
  <%= form.label :content, "Message Content", class: "form-label" %>
  <%= form.rich_text_area :content,
      data: { action: "input->inline-autosave#schedule", variable_autocomplete_target: "input" } %>
</div>

<div class="form-group">
  <label class="flex items-center gap-2 cursor-pointer">
    <%= form.check_box :can_resolve, class: "form-checkbox",
        data: { action: "change->inline-autosave#schedule" } %>
    <span class="text-sm">This step may resolve the issue</span>
  </label>
</div>
