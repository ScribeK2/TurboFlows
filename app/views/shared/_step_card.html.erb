<%# Step card partial for displaying step information %>
<%# Used in step selector dropdown and other contexts %>

<% step_type = local_assigns[:step_type] || step['type'] || step[:type] %>
<% step_title = local_assigns[:step_title] || step['title'] || step[:title] %>
<% step_preview = local_assigns[:step_preview] || step['preview'] || step[:preview] || "" %>
<% step_index = local_assigns[:step_index] || step['index'] || step[:index] %>

<%# Type-specific styling %>
<%
  type_icons = {
    'question' => '?',
    'action' => '!',
    'sub_flow' => '↪',
    'message' => 'i',
    'escalate' => '↑',
    'resolve' => '✓'
  }
  type_icon = type_icons[step_type.to_s] || '#'
%>

<div class="step-list-item border-b transition-colors">
  <div class="flex-shrink-0 mt-0.5">
    <span class="badge badge--<%= step_type.to_s.tr('_', '-') %> font-bold"><%= type_icon %></span>
  </div>
  <div class="flex-1 min-w-0">
    <div class="flex items-center gap-2 mb-1">
      <span class="font-medium"><%= step_title %></span>
      <span class="badge badge--<%= step_type.to_s.tr('_', '-') %>"><%= step_type.to_s.capitalize %></span>
    </div>
    <% if step_preview.present? %>
      <p class="text-xs truncate text-muted"><%= step_preview %></p>
    <% end %>
  </div>
</div>
