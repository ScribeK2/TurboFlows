<%# Shared markdown editor with toolbar
     Locals:
       form        - the form builder (optional if name/value provided)
       field       - field name for form builder (e.g. :description)
       name        - raw HTML name attribute (alternative to form+field)
       value       - initial text content (used with name, not form)
       id          - HTML id for the textarea (optional)
       placeholder - placeholder text (optional)
       rows        - number of rows (default 6)
       extra_data  - hash of extra data-* attributes for textarea (optional)
%>
<% id ||= nil %>
<% placeholder ||= "" %>
<% rows ||= 6 %>
<% extra_data ||= {} %>
<% name ||= nil %>
<% value ||= nil %>

<div data-controller="markdown-toolbar"
     data-markdown-toolbar-preview-url-value="<%= markdown_preview_path %>"
     class="mt-1">
  <%# Toolbar %>
  <div data-markdown-toolbar-target="toolbar"
       class="flex items-center gap-0.5 px-2 py-1.5 bg-gray-50 dark:bg-slate-700/60 border border-b-0 border-gray-300 dark:border-gray-600 rounded-t-lg overflow-x-auto">
    <%# Text formatting group %>
    <button type="button" data-action="click->markdown-toolbar#bold" title="Bold"
            class="p-1.5 rounded text-gray-600 dark:text-gray-300 hover:bg-gray-200 dark:hover:bg-slate-600 hover:text-gray-900 dark:hover:text-white transition-colors">
      <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M6 4h8a4 4 0 0 1 4 4 4 4 0 0 1-4 4H6z"/><path stroke-linecap="round" stroke-linejoin="round" d="M6 12h9a4 4 0 0 1 4 4 4 4 0 0 1-4 4H6z"/></svg>
    </button>
    <button type="button" data-action="click->markdown-toolbar#italic" title="Italic"
            class="p-1.5 rounded text-gray-600 dark:text-gray-300 hover:bg-gray-200 dark:hover:bg-slate-600 hover:text-gray-900 dark:hover:text-white transition-colors">
      <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><line x1="19" y1="4" x2="10" y2="4"/><line x1="14" y1="20" x2="5" y2="20"/><line x1="15" y1="4" x2="9" y2="20"/></svg>
    </button>
    <button type="button" data-action="click->markdown-toolbar#strikethrough" title="Strikethrough"
            class="p-1.5 rounded text-gray-600 dark:text-gray-300 hover:bg-gray-200 dark:hover:bg-slate-600 hover:text-gray-900 dark:hover:text-white transition-colors">
      <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M16 4H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H7"/><line x1="4" y1="12" x2="20" y2="12"/></svg>
    </button>

    <span class="w-px h-5 bg-gray-300 dark:bg-gray-500 mx-1"></span>

    <%# Structural formatting group %>
    <button type="button" data-action="click->markdown-toolbar#heading" title="Heading"
            class="p-1.5 rounded text-gray-600 dark:text-gray-300 hover:bg-gray-200 dark:hover:bg-slate-600 hover:text-gray-900 dark:hover:text-white transition-colors text-xs font-bold">
      H
    </button>
    <button type="button" data-action="click->markdown-toolbar#quote" title="Quote"
            class="p-1.5 rounded text-gray-600 dark:text-gray-300 hover:bg-gray-200 dark:hover:bg-slate-600 hover:text-gray-900 dark:hover:text-white transition-colors">
      <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M3 21c3 0 7-1 7-8V5c0-1.25-.756-2.017-2-2H4c-1.25 0-2 .75-2 1.972V11c0 1.25.75 2 2 2 1 0 1 0 1 1v1c0 1-1 2-2 2s-1 .008-1 1.031V21z"/><path stroke-linecap="round" stroke-linejoin="round" d="M15 21c3 0 7-1 7-8V5c0-1.25-.757-2.017-2-2h-4c-1.25 0-2 .75-2 1.972V11c0 1.25.75 2 2 2h.75c0 2.25.25 4-2.75 4v3c0 1 0 1 1 1z"/></svg>
    </button>
    <button type="button" data-action="click->markdown-toolbar#code" title="Code"
            class="p-1.5 rounded text-gray-600 dark:text-gray-300 hover:bg-gray-200 dark:hover:bg-slate-600 hover:text-gray-900 dark:hover:text-white transition-colors">
      <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/></svg>
    </button>

    <span class="w-px h-5 bg-gray-300 dark:bg-gray-500 mx-1"></span>

    <%# List group %>
    <button type="button" data-action="click->markdown-toolbar#bulletList" title="Bullet list"
            class="p-1.5 rounded text-gray-600 dark:text-gray-300 hover:bg-gray-200 dark:hover:bg-slate-600 hover:text-gray-900 dark:hover:text-white transition-colors">
      <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><line x1="8" y1="6" x2="21" y2="6"/><line x1="8" y1="12" x2="21" y2="12"/><line x1="8" y1="18" x2="21" y2="18"/><circle cx="4" cy="6" r="1" fill="currentColor"/><circle cx="4" cy="12" r="1" fill="currentColor"/><circle cx="4" cy="18" r="1" fill="currentColor"/></svg>
    </button>
    <button type="button" data-action="click->markdown-toolbar#numberedList" title="Numbered list"
            class="p-1.5 rounded text-gray-600 dark:text-gray-300 hover:bg-gray-200 dark:hover:bg-slate-600 hover:text-gray-900 dark:hover:text-white transition-colors">
      <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><line x1="10" y1="6" x2="21" y2="6"/><line x1="10" y1="12" x2="21" y2="12"/><line x1="10" y1="18" x2="21" y2="18"/><text x="3" y="8" font-size="8" fill="currentColor" stroke="none">1</text><text x="3" y="14" font-size="8" fill="currentColor" stroke="none">2</text><text x="3" y="20" font-size="8" fill="currentColor" stroke="none">3</text></svg>
    </button>
    <button type="button" data-action="click->markdown-toolbar#link" title="Link"
            class="p-1.5 rounded text-gray-600 dark:text-gray-300 hover:bg-gray-200 dark:hover:bg-slate-600 hover:text-gray-900 dark:hover:text-white transition-colors">
      <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M13.828 10.172a4 4 0 0 0-5.656 0l-4 4a4 4 0 1 0 5.656 5.656l1.102-1.101"/><path stroke-linecap="round" stroke-linejoin="round" d="M10.172 13.828a4 4 0 0 0 5.656 0l4-4a4 4 0 0 0-5.656-5.656l-1.1 1.1"/></svg>
    </button>

    <span class="w-px h-5 bg-gray-300 dark:bg-gray-500 mx-1"></span>

    <%# Image button with dropdown %>
    <div class="relative" data-action="click@window->markdown-toolbar#hideImageMenu">
      <button type="button" data-action="click->markdown-toolbar#toggleImageMenu:stop" title="Insert image"
              class="p-1.5 rounded text-gray-600 dark:text-gray-300 hover:bg-gray-200 dark:hover:bg-slate-600 hover:text-gray-900 dark:hover:text-white transition-colors">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"/>
        </svg>
      </button>
      <div data-markdown-toolbar-target="imageMenu"
           class="hidden absolute left-0 top-full mt-1 z-20 bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-600 rounded-lg shadow-lg py-1 min-w-[160px]">
        <button type="button" data-action="click->markdown-toolbar#pickImage"
                class="w-full text-left px-3 py-1.5 text-sm text-gray-700 dark:text-gray-200 hover:bg-gray-100 dark:hover:bg-gray-700 flex items-center gap-2">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M7 16a4 4 0 01-.88-7.903A5 5 0 1115.9 6L16 6a5 5 0 011 9.9M15 13l-3-3m0 0l-3 3m3-3v12"/></svg>
          Upload Image
        </button>
        <button type="button" data-action="click->markdown-toolbar#insertImageUrl"
                class="w-full text-left px-3 py-1.5 text-sm text-gray-700 dark:text-gray-200 hover:bg-gray-100 dark:hover:bg-gray-700 flex items-center gap-2">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.656l1.102-1.101M10.172 13.828a4 4 0 005.656 0l4-4a4 4 0 00-5.656-5.656l-1.1 1.1"/></svg>
          Paste URL
        </button>
      </div>
    </div>

    <%# Spacer to push preview toggle right %>
    <span class="flex-1"></span>

    <%# Preview toggle %>
    <button type="button" data-action="click->markdown-toolbar#togglePreview" data-preview-toggle title="Toggle preview"
            class="p-1.5 rounded text-gray-600 dark:text-gray-300 hover:bg-gray-200 dark:hover:bg-slate-600 hover:text-gray-900 dark:hover:text-white transition-colors">
      <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/><path stroke-linecap="round" stroke-linejoin="round" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/></svg>
    </button>
  </div>

  <%# Hidden file input for image upload %>
  <input type="file" accept="image/*" class="hidden"
         data-markdown-toolbar-target="fileInput"
         data-action="change->markdown-toolbar#handleFileSelected">

  <%# Upload status %>
  <span data-markdown-toolbar-target="status" class="hidden text-xs text-blue-600 dark:text-blue-400 mt-1 block"></span>

  <%# Textarea %>
  <% textarea_classes = "block w-full border border-gray-300 dark:border-gray-600 rounded-b-lg shadow-sm py-2 px-3 bg-white dark:bg-gray-700 text-gray-900 dark:text-gray-100 placeholder-gray-400 dark:placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-slate-500 dark:focus:ring-slate-400 focus:border-slate-500 dark:focus:border-slate-400 transition-colors font-mono text-sm" %>
  <% textarea_data = { markdown_toolbar_target: "input" }.merge(extra_data) %>
  <% if defined?(form) && form && defined?(field) && field %>
    <%= form.text_area field,
        id: id,
        rows: rows,
        placeholder: placeholder,
        data: textarea_data,
        class: textarea_classes %>
  <% else %>
    <textarea name="<%= name %>"
              id="<%= id %>"
              rows="<%= rows %>"
              placeholder="<%= placeholder %>"
              class="<%= textarea_classes %>"
              <% textarea_data.each do |k, v| %>
                data-<%= k.to_s.dasherize %>="<%= v %>"
              <% end %>><%= value %></textarea>
  <% end %>

  <%# Preview area (hidden by default) %>
  <div data-markdown-toolbar-target="preview"
       class="hidden block w-full border border-gray-300 dark:border-gray-600 rounded-b-lg shadow-sm py-2 px-3 bg-white dark:bg-gray-700 text-gray-900 dark:text-gray-100 min-h-[80px] overflow-auto">
  </div>
</div>
