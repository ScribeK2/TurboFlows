<!-- Modal Partial -->
<%
  modal_id = local_assigns[:id] || "modal"
  size_class = case local_assigns[:size]&.to_sym
               when :sm   then "dialog--sm"
               when :lg   then "dialog--lg"
               else ""
               end
  extra_class = local_assigns[:class] || ""
%>

<!-- Modal Backdrop -->
<div
  id="<%= modal_id %>-backdrop"
  class="dialog-overlay animate-fade-in"
  data-controller="modal"
  data-modal-target="backdrop"
  data-action="click->modal#close"
  style="display: none;"
>
  <!-- Modal Content -->
  <div
    class="dialog <%= size_class %> <%= extra_class %> animate-scale-in"
    data-modal-target="content"
    data-action="click->modal#stop"
  >
    <!-- Modal Header -->
    <% if local_assigns[:title] || local_assigns[:show_close] != false %>
      <div class="dialog__header">
        <% if local_assigns[:title] %>
          <h2 class="dialog__title">
            <%= title %>
          </h2>
        <% end %>
        <% if local_assigns[:show_close] != false %>
          <button
            type="button"
            class="dialog__close"
            data-action="click->modal#close"
            aria-label="Close modal"
          >
            <%= icon "x-mark", class: "icon" %>
          </button>
        <% end %>
      </div>
    <% end %>

    <!-- Modal Body -->
    <div class="dialog__body <%= local_assigns[:body_class] || '' %>">
      <%= yield %>
    </div>

    <!-- Modal Footer -->
    <% if local_assigns[:footer] %>
      <div class="dialog__footer">
        <%= footer %>
      </div>
    <% end %>
  </div>
</div>
