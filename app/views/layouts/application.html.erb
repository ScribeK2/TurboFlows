<!DOCTYPE html>
<html data-controller="dark-mode">
  <head>
    <title>Flows - Workflow Builder</title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="view-transition" content="same-origin">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= action_cable_meta_tag %>

    <!-- Initialize theme before page renders to prevent flash -->
    <script nonce="<%= content_security_policy_nonce %>">
      (function() {
        const savedTheme = localStorage.getItem("theme");
        const prefersDark = window.matchMedia("(prefers-color-scheme: dark)").matches;
        document.documentElement.dataset.theme =
          (savedTheme === "dark" || (!savedTheme && prefersDark)) ? "dark" : "light";
      })();
    </script>

    <!-- Favicon -->
    <link rel="icon" href="/favicon.ico" sizes="any">
    <link rel="icon" href="/favicon.svg" type="image/svg+xml">

    <%= stylesheet_link_tag "application",
          "_global", "reset", "base",
          "buttons", "forms", "cards", "tables", "badges", "dialogs",
          "flash", "dropdowns", "tooltips", "pagination", "icons",
          "layout", "navigation", "dashboard", "workflows", "editor",
          "steps", "transitions", "scenarios", "flow_diagram", "builder", "admin", "auth",
          "animations", "skeleton", "session_timeout", "utilities", "print",
          "_tags", "_version_diff", "_media", "_player", "_form_step",
          "data-turbo-track": "reload", preload_links_header: false %>
    <%= stylesheet_link_tag "lexxy", "data-turbo-track": "reload", preload_links_header: false %>

    <!-- Importmap for ES modules -->
    <%= javascript_importmap_tags %>

    <%= yield :head if content_for?(:head) %>
  </head>

  <body class="page-body"
        <% if user_signed_in? %>
        data-controller="session-monitor"
        data-session-monitor-url-value="<%= session_heartbeat_path %>"
        data-session-monitor-sign-in-url-value="<%= new_user_session_path %>"
        <% end %>
  >
    <!-- Navigation Bar -->
    <nav class="page-header"
         data-controller="dialog-manager"
         data-dialog-manager-nav-menu-outlet="[data-controller='nav-menu']"
         data-dialog-manager-nav-search-outlet="[data-controller='nav-search']"
         data-action="dialog:show->dialog-manager#closeOthers">
      <div class="page-header__inner">
        <div class="page-header__row">
          <%# === Left zone: Search pill === %>
          <div class="nav__zone nav__zone--start">
            <% if user_signed_in? %>
              <div data-controller="nav-search" data-nav-search-url-value="<%= nav_search_data_path(format: :json) %>">
                <button type="button"
                        data-action="click->nav-search#open"
                        class="nav__search-pill"
                        aria-label="Search workflows">
                  <%= icon "magnifying-glass", class: "icon icon--sm" %>
                  <span class="nav__search-pill-text">Search...</span>
                  <kbd class="nav__search-pill-kbd">&#8984;K</kbd>
                </button>

                <dialog data-nav-search-target="dialog"
                        data-action="click->nav-search#backdropClose"
                        class="nav__search popup popup--animated">
                  <div class="nav__search-input-wrapper">
                    <%= icon "magnifying-glass", class: "icon icon--sm" %>
                    <input data-nav-search-target="input"
                           data-action="input->nav-search#search keydown->nav-search#navigate"
                           type="text"
                           id="nav-search-input"
                           name="nav_search"
                           class="nav__search-input"
                           placeholder="Search workflows..."
                           autocomplete="off"
                           aria-label="Search workflows">
                    <kbd class="nav__search-esc">Esc</kbd>
                  </div>
                  <div data-nav-search-target="results" class="nav__search-results"></div>
                  <div class="nav__search-footer">
                    <span><kbd>&#8593;&#8595;</kbd> navigate</span>
                    <span><kbd>&#8629;</kbd> open</span>
                    <span><kbd>esc</kbd> close</span>
                  </div>
                </dialog>
              </div>
            <% end %>
          </div>

          <%# === Center zone: Logo + menu trigger === %>
          <div class="nav__zone nav__zone--center">
            <div class="nav__brand">
              <%= link_to root_path, class: "nav__brand-link" do %>
                <%= render "shared/brand_icon", css_class: "nav__brand-icon" %>
                <span class="nav__brand-text">TurboFlows</span>
              <% end %>

              <% if user_signed_in? %>
                <div data-controller="nav-menu" data-nav-menu-src-value="<%= nav_menu_path %>">
                  <button type="button"
                          data-action="click->nav-menu#toggle"
                          class="nav__menu-trigger"
                          aria-label="Open menu">
                    <%= icon "chevron-down" %>
                  </button>

                  <dialog data-nav-menu-target="dialog"
                          class="nav__menu popup popup--animated">
                    <turbo-frame id="nav_menu" data-nav-menu-target="frame">
                      <div class="nav__menu-loading">Loading...</div>
                    </turbo-frame>
                  </dialog>
                </div>
              <% end %>
            </div>
          </div>

          <%# === Right zone: Dark mode + avatar === %>
          <div class="nav__zone nav__zone--end">
            <!-- Dark Mode Toggle -->
            <button
              type="button"
              data-action="click->dark-mode#toggle"
              class="dark-mode-toggle"
              aria-label="Toggle dark mode"
            >
              <%= icon "sun", class: "icon icon--sm is-hidden" %>
              <%= icon "moon", class: "icon icon--sm" %>
            </button>

            <% if user_signed_in? %>
              <!-- Avatar Dropdown (slimmed) -->
              <div class="relative" data-controller="dropdown">
                <button
                  type="button"
                  data-action="click->dropdown#toggle"
                  aria-expanded="false"
                  aria-haspopup="true"
                  class="avatar-btn <%= current_user.avatar_color_class %>"
                  title="<%= current_user.display_label %>"
                >
                  <%= current_user.avatar_initial %>
                </button>

                <div data-dropdown-target="menu" class="dropdown__menu is-hidden" role="menu">
                  <div class="dropdown__header">
                    <p class="dropdown__user-name"><%= current_user.display_label %></p>
                    <p class="dropdown__user-email"><%= current_user.email %></p>
                  </div>
                  <div class="dropdown__body">
                    <%= link_to edit_user_registration_path, class: "dropdown__item", role: "menuitem" do %>
                      <%= icon "eye", class: "icon icon--sm" %>
                      Account
                    <% end %>
                    <div class="dropdown__divider"></div>
                    <%= link_to destroy_user_session_path, data: { turbo_method: :delete }, class: "dropdown__item", role: "menuitem" do %>
                      <%= icon "arrow-right-on-rectangle", class: "icon icon--sm" %>
                      Sign out
                    <% end %>
                  </div>
                </div>
              </div>
            <% else %>
              <%= link_to "Sign in", new_user_session_path, class: "btn btn--plain" %>
              <%= link_to "Sign up", new_user_registration_path, class: "btn btn--primary" %>
            <% end %>
          </div>
        </div>
      </div>
    </nav>

    <!-- Main Content with top padding for fixed nav -->
    <div class="page-content">
      <!-- Flash Messages -->
      <% if notice %>
        <div class="flash flash--notice animate-slide-in-right"
             data-controller="alert"
             data-alert-duration-value="5000"
             data-action="click->alert#dismiss">
          <div class="flash__body" role="alert">
            <span class="flash__text"><%= notice %></span>
            <div class="flash__progress animate-shrink" data-alert-target="progress"></div>
          </div>
        </div>
      <% end %>

      <% if alert %>
        <div class="flash flash--alert animate-slide-in-right"
             data-controller="alert"
             data-alert-duration-value="5000"
             data-action="click->alert#dismiss">
          <div class="flash__body" role="alert">
            <span class="flash__text"><%= alert %></span>
            <div class="flash__progress animate-shrink" data-alert-target="progress"></div>
          </div>
        </div>
      <% end %>

      <main class="page-main">
        <%= yield %>
      </main>
    </div>
  </body>
</html>
