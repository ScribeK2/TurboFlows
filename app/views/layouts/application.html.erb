<!DOCTYPE html>
<html data-controller="dark-mode">
  <head>
    <title>Flows - Workflow Builder</title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="view-transition" content="same-origin">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= action_cable_meta_tag %>

    <!-- Initialize theme before page renders to prevent flash -->
    <script nonce="<%= content_security_policy_nonce %>">
      (function() {
        const savedTheme = localStorage.getItem("theme");
        const prefersDark = window.matchMedia("(prefers-color-scheme: dark)").matches;
        document.documentElement.dataset.theme =
          (savedTheme === "dark" || (!savedTheme && prefersDark)) ? "dark" : "light";
      })();
    </script>

    <!-- Favicon -->
    <link rel="icon" href="/favicon.ico" sizes="any">
    <link rel="icon" href="/favicon.svg" type="image/svg+xml">

    <%= stylesheet_link_tag "application",
          "_global", "reset", "base",
          "buttons", "forms", "cards", "tables", "badges", "dialogs",
          "flash", "dropdowns", "tooltips", "pagination", "icons",
          "layout", "navigation", "dashboard", "workflows", "editor",
          "steps", "transitions", "scenarios", "flow_diagram", "admin", "auth",
          "animations", "utilities", "print",
          "data-turbo-track": "reload", preload_links_header: false %>
    <%= stylesheet_link_tag "lexxy", "data-turbo-track": "reload", preload_links_header: false %>

    <!-- Importmap for ES modules -->
    <%= javascript_importmap_tags %>

    <%= yield :head if content_for?(:head) %>
  </head>

  <body class="page-body">
    <!-- Navigation Bar -->
    <nav class="page-header">
      <div class="page-header__inner">
        <div class="page-header__row">
          <div class="nav__brand">
            <%= link_to root_path, class: "nav__brand-link" do %>
              <svg class="nav__brand-icon" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                <circle cx="5" cy="6" r="2" fill="#10b981" />
                <circle cx="12" cy="18" r="2" fill="#3b82f6" />
                <circle cx="19" cy="6" r="2" fill="#f59e0b" />
                <path stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" d="M5 8v2a4 4 0 004 4h2" />
                <path stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" d="M19 8v2a4 4 0 01-4 4h-2" />
              </svg>
              <span class="nav__brand-text">TurboFlows</span>
            <% end %>
            <div class="nav__links">
              <%= link_to "Dashboard", root_path, class: "nav-item #{current_page?(root_path) ? 'is-active' : ''}" %>
              <%= link_to "Workflows", workflows_path, class: "nav-item #{current_page?(workflows_path) ? 'is-active' : ''}" %>
              <% if current_user&.can_create_workflows? %>
                <%= link_to "Templates", templates_path, class: "nav-item #{current_page?(templates_path) ? 'is-active' : ''}" %>
              <% end %>
            </div>
          </div>
          <div class="nav__actions">
            <!-- Dark Mode Toggle -->
            <button
              type="button"
              data-action="click->dark-mode#toggle"
              class="dark-mode-toggle"
              aria-label="Toggle dark mode"
            >
              <!-- Sun Icon (shown in dark mode to switch to light) -->
              <svg data-dark-mode-target="sunIcon" class="icon icon--sm is-hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z"></path>
              </svg>
              <!-- Moon Icon (shown in light mode to switch to dark) -->
              <svg data-dark-mode-target="moonIcon" class="icon icon--sm" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z"></path>
              </svg>
            </button>

            <% if user_signed_in? %>
              <!-- Avatar Dropdown -->
              <div class="relative" data-controller="dropdown">
                <button
                  type="button"
                  data-action="click->dropdown#toggle"
                  aria-expanded="false"
                  aria-haspopup="true"
                  class="avatar-btn <%= current_user.avatar_color_class %>"
                  title="<%= current_user.display_label %>"
                >
                  <%= current_user.avatar_initial %>
                </button>

                <!-- Dropdown Menu -->
                <div
                  data-dropdown-target="menu"
                  class="dropdown__menu is-hidden"
                  role="menu"
                >
                  <!-- User Info Header -->
                  <div class="dropdown__header">
                    <p class="dropdown__user-name"><%= current_user.display_label %></p>
                    <span class="badge <%= current_user.avatar_role_badge_classes %>">
                      <%= current_user.role.capitalize %>
                    </span>
                  </div>

                  <!-- Menu Links -->
                  <div class="py-1">
                    <% if current_user.can_access_admin? %>
                      <%= link_to admin_root_path, class: "dropdown__item", role: "menuitem" do %>
                        <svg class="icon icon--sm" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                          <path stroke-linecap="round" stroke-linejoin="round" d="M9.594 3.94c.09-.542.56-.94 1.11-.94h2.593c.55 0 1.02.398 1.11.94l.213 1.281c.063.374.313.686.645.87.074.04.147.083.22.127.325.196.72.257 1.075.124l1.217-.456a1.125 1.125 0 0 1 1.37.49l1.296 2.247a1.125 1.125 0 0 1-.26 1.431l-1.003.827c-.293.241-.438.613-.43.992a7.723 7.723 0 0 1 0 .255c-.008.378.137.75.43.991l1.004.827c.424.35.534.955.26 1.43l-1.298 2.247a1.125 1.125 0 0 1-1.369.491l-1.217-.456c-.355-.133-.75-.072-1.076.124a6.47 6.47 0 0 1-.22.128c-.331.183-.581.495-.644.869l-.213 1.281c-.09.543-.56.94-1.11.94h-2.594c-.55 0-1.019-.398-1.11-.94l-.213-1.281c-.062-.374-.312-.686-.644-.87a6.52 6.52 0 0 1-.22-.127c-.325-.196-.72-.257-1.076-.124l-1.217.456a1.125 1.125 0 0 1-1.369-.49l-1.297-2.247a1.125 1.125 0 0 1 .26-1.431l1.004-.827c.292-.24.437-.613.43-.991a6.932 6.932 0 0 1 0-.255c.007-.38-.138-.751-.43-.992l-1.004-.827a1.125 1.125 0 0 1-.26-1.43l1.297-2.247a1.125 1.125 0 0 1 1.37-.491l1.216.456c.356.133.751.072 1.076-.124.072-.044.146-.086.22-.128.332-.183.582-.495.644-.869l.214-1.28Z" />
                          <path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z" />
                        </svg>
                        Admin
                      <% end %>
                    <% end %>

                    <%= link_to edit_user_registration_path, class: "dropdown__item", role: "menuitem" do %>
                      <svg class="icon icon--sm" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 6a3.75 3.75 0 1 1-7.5 0 3.75 3.75 0 0 1 7.5 0ZM4.501 20.118a7.5 7.5 0 0 1 14.998 0A17.933 17.933 0 0 1 12 21.75c-2.676 0-5.216-.584-7.499-1.632Z" />
                      </svg>
                      Account
                    <% end %>
                  </div>

                  <!-- Sign Out -->
                  <div class="dropdown__divider">
                    <%= link_to destroy_user_session_path, data: { turbo_method: :delete }, class: "dropdown__item", role: "menuitem" do %>
                      <svg class="icon icon--sm" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 9V5.25A2.25 2.25 0 0 0 13.5 3h-6a2.25 2.25 0 0 0-2.25 2.25v13.5A2.25 2.25 0 0 0 7.5 21h6a2.25 2.25 0 0 0 2.25-2.25V15m3 0 3-3m0 0-3-3m3 3H9" />
                      </svg>
                      Sign out
                    <% end %>
                  </div>
                </div>
              </div>
            <% else %>
              <%= link_to "Sign in", new_user_session_path, class: "btn btn--plain" %>
              <%= link_to "Sign up", new_user_registration_path, class: "btn btn--primary" %>
            <% end %>
          </div>
        </div>
      </div>
    </nav>

    <!-- Main Content with top padding for fixed nav -->
    <div class="page-content">
      <!-- Flash Messages -->
      <% if notice %>
        <div class="flash flash--notice animate-slide-in-right"
             data-controller="alert"
             data-alert-duration-value="5000"
             data-action="click->alert#dismiss">
          <div class="flash__body" role="alert">
            <span class="flash__text"><%= notice %></span>
            <div class="flash__progress animate-shrink" data-alert-target="progress"></div>
          </div>
        </div>
      <% end %>

      <% if alert %>
        <div class="flash flash--alert animate-slide-in-right"
             data-controller="alert"
             data-alert-duration-value="5000"
             data-action="click->alert#dismiss">
          <div class="flash__body" role="alert">
            <span class="flash__text"><%= alert %></span>
            <div class="flash__progress animate-shrink" data-alert-target="progress"></div>
          </div>
        </div>
      <% end %>

      <main class="page-main">
        <%= yield %>
      </main>
    </div>
  </body>
</html>
