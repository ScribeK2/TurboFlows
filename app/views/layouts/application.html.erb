<!DOCTYPE html>
<html data-controller="dark-mode">
  <head>
    <title>Flows - Workflow Builder</title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="view-transition" content="same-origin">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= action_cable_meta_tag %>

    <!-- Initialize theme before page renders to prevent flash -->
    <script nonce="<%= content_security_policy_nonce %>">
      (function() {
        const savedTheme = localStorage.getItem("theme");
        const prefersDark = window.matchMedia("(prefers-color-scheme: dark)").matches;
        document.documentElement.dataset.theme =
          (savedTheme === "dark" || (!savedTheme && prefersDark)) ? "dark" : "light";
      })();
    </script>

    <!-- Favicon -->
    <link rel="icon" href="/favicon.ico" sizes="any">
    <link rel="icon" href="/favicon.svg" type="image/svg+xml">

    <%= stylesheet_link_tag "application",
          "_global", "reset", "base",
          "buttons", "forms", "cards", "tables", "badges", "dialogs",
          "flash", "dropdowns", "tooltips", "pagination", "icons",
          "layout", "navigation", "dashboard", "workflows", "editor",
          "steps", "transitions", "scenarios", "flow_diagram", "builder", "admin", "auth",
          "animations", "skeleton", "utilities", "print",
          "data-turbo-track": "reload", preload_links_header: false %>
    <%= stylesheet_link_tag "lexxy", "data-turbo-track": "reload", preload_links_header: false %>

    <!-- Importmap for ES modules -->
    <%= javascript_importmap_tags %>

    <%= yield :head if content_for?(:head) %>
  </head>

  <body class="page-body">
    <!-- Navigation Bar -->
    <nav class="page-header"
         data-controller="dialog-manager"
         data-dialog-manager-nav-menu-outlet="[data-controller='nav-menu']"
         data-dialog-manager-nav-search-outlet="[data-controller='nav-search']"
         data-action="dialog:show->dialog-manager#closeOthers">
      <div class="page-header__inner">
        <div class="page-header__row">
          <%# === Left zone: Search pill === %>
          <div class="nav__zone nav__zone--start">
            <% if user_signed_in? %>
              <div data-controller="nav-search" data-nav-search-url-value="<%= nav_search_data_path(format: :json) %>">
                <button type="button"
                        data-action="click->nav-search#open"
                        class="nav__search-pill"
                        aria-label="Search workflows">
                  <svg class="icon icon--sm" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" aria-hidden="true">
                    <circle cx="11" cy="11" r="8" />
                    <path stroke-linecap="round" d="m21 21-4.35-4.35" />
                  </svg>
                  <span class="nav__search-pill-text">Search...</span>
                  <kbd class="nav__search-pill-kbd">&#8984;K</kbd>
                </button>

                <dialog data-nav-search-target="dialog"
                        data-action="click->nav-search#backdropClose"
                        class="nav__search popup popup--animated">
                  <div class="nav__search-input-wrapper">
                    <svg class="icon icon--sm" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" aria-hidden="true">
                      <circle cx="11" cy="11" r="8" />
                      <path stroke-linecap="round" d="m21 21-4.35-4.35" />
                    </svg>
                    <input data-nav-search-target="input"
                           data-action="input->nav-search#search keydown->nav-search#navigate"
                           type="text"
                           class="nav__search-input"
                           placeholder="Search workflows..."
                           autocomplete="off">
                    <kbd class="nav__search-esc">Esc</kbd>
                  </div>
                  <div data-nav-search-target="results" class="nav__search-results"></div>
                  <div class="nav__search-footer">
                    <span><kbd>&#8593;&#8595;</kbd> navigate</span>
                    <span><kbd>&#8629;</kbd> open</span>
                    <span><kbd>esc</kbd> close</span>
                  </div>
                </dialog>
              </div>
            <% end %>
          </div>

          <%# === Center zone: Logo + menu trigger === %>
          <div class="nav__zone nav__zone--center">
            <div class="nav__brand">
              <%= link_to root_path, class: "nav__brand-link" do %>
                <svg class="nav__brand-icon" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                  <circle cx="5" cy="6" r="2" fill="#10b981" />
                  <circle cx="12" cy="18" r="2" fill="#3b82f6" />
                  <circle cx="19" cy="6" r="2" fill="#f59e0b" />
                  <path stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" d="M5 8v2a4 4 0 004 4h2" />
                  <path stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" d="M19 8v2a4 4 0 01-4 4h-2" />
                </svg>
                <span class="nav__brand-text">TurboFlows</span>
              <% end %>

              <% if user_signed_in? %>
                <div data-controller="nav-menu" data-nav-menu-src-value="<%= nav_menu_path %>">
                  <button type="button"
                          data-action="click->nav-menu#toggle"
                          class="nav__menu-trigger"
                          aria-label="Open menu">
                    <svg width="10" height="10" viewBox="0 0 10 10" fill="none" aria-hidden="true">
                      <path d="M2 3.5l3 3 3-3" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
                    </svg>
                  </button>

                  <dialog data-nav-menu-target="dialog"
                          data-action="click->nav-menu#backdropClose"
                          class="nav__menu popup popup--animated">
                    <turbo-frame id="nav_menu" data-nav-menu-target="frame">
                      <div class="nav__menu-loading">Loading...</div>
                    </turbo-frame>
                  </dialog>
                </div>
              <% end %>
            </div>
          </div>

          <%# === Right zone: Dark mode + avatar === %>
          <div class="nav__zone nav__zone--end">
            <!-- Dark Mode Toggle -->
            <button
              type="button"
              data-action="click->dark-mode#toggle"
              class="dark-mode-toggle"
              aria-label="Toggle dark mode"
            >
              <svg data-dark-mode-target="sunIcon" class="icon icon--sm is-hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z"></path>
              </svg>
              <svg data-dark-mode-target="moonIcon" class="icon icon--sm" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z"></path>
              </svg>
            </button>

            <% if user_signed_in? %>
              <!-- Avatar Dropdown (slimmed) -->
              <div class="relative" data-controller="dropdown">
                <button
                  type="button"
                  data-action="click->dropdown#toggle"
                  aria-expanded="false"
                  aria-haspopup="true"
                  class="avatar-btn <%= current_user.avatar_color_class %>"
                  title="<%= current_user.display_label %>"
                >
                  <%= current_user.avatar_initial %>
                </button>

                <div data-dropdown-target="menu" class="dropdown__menu is-hidden" role="menu">
                  <div class="dropdown__header">
                    <p class="dropdown__user-name"><%= current_user.display_label %></p>
                    <p class="dropdown__user-email"><%= current_user.email %></p>
                  </div>
                  <div class="dropdown__body">
                    <%= link_to edit_user_registration_path, class: "dropdown__item", role: "menuitem" do %>
                      <svg class="icon icon--sm" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.066 2.573c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.573 1.066c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.066-2.573c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z" />
                        <path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
                      </svg>
                      Account
                    <% end %>
                    <div class="dropdown__divider"></div>
                    <%= link_to destroy_user_session_path, data: { turbo_method: :delete }, class: "dropdown__item", role: "menuitem" do %>
                      <svg class="icon icon--sm" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 9V5.25A2.25 2.25 0 0013.5 3h-6a2.25 2.25 0 00-2.25 2.25v13.5A2.25 2.25 0 007.5 21h6a2.25 2.25 0 002.25-2.25V15m3 0l3-3m0 0l-3-3m3 3H9" />
                      </svg>
                      Sign out
                    <% end %>
                  </div>
                </div>
              </div>
            <% else %>
              <%= link_to "Sign in", new_user_session_path, class: "btn btn--plain" %>
              <%= link_to "Sign up", new_user_registration_path, class: "btn btn--primary" %>
            <% end %>
          </div>
        </div>
      </div>
    </nav>

    <!-- Main Content with top padding for fixed nav -->
    <div class="page-content">
      <!-- Flash Messages -->
      <% if notice %>
        <div class="flash flash--notice animate-slide-in-right"
             data-controller="alert"
             data-alert-duration-value="5000"
             data-action="click->alert#dismiss">
          <div class="flash__body" role="alert">
            <span class="flash__text"><%= notice %></span>
            <div class="flash__progress animate-shrink" data-alert-target="progress"></div>
          </div>
        </div>
      <% end %>

      <% if alert %>
        <div class="flash flash--alert animate-slide-in-right"
             data-controller="alert"
             data-alert-duration-value="5000"
             data-action="click->alert#dismiss">
          <div class="flash__body" role="alert">
            <span class="flash__text"><%= alert %></span>
            <div class="flash__progress animate-shrink" data-alert-target="progress"></div>
          </div>
        </div>
      <% end %>

      <main class="page-main">
        <%= yield %>
      </main>
    </div>
  </body>
</html>
