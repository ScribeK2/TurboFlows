<!DOCTYPE html>
<html lang="en" data-controller="dark-mode">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= content_for?(:title) ? yield(:title) : "TurboFlows Player" %></title>
  <meta name="csrf-token" content="<%= form_authenticity_token %>">
  <%= csrf_meta_tags %>
  <%= csp_meta_tag %>

  <!-- Initialize theme before page renders to prevent flash -->
  <script nonce="<%= content_security_policy_nonce %>">
    (function() {
      const savedTheme = localStorage.getItem("theme");
      const prefersDark = window.matchMedia("(prefers-color-scheme: dark)").matches;
      document.documentElement.dataset.theme =
        (savedTheme === "dark" || (!savedTheme && prefersDark)) ? "dark" : "light";
    })();
  </script>

  <%= stylesheet_link_tag "application", "_global", "reset", "base",
        "buttons", "forms", "cards", "badges", "flash",
        "scenarios", "utilities", "_tags", "_player", "_media", "_form_step",
        data: { turbo_track: "reload" } %>
  <%= javascript_importmap_tags %>
</head>
<body class="player-layout<%= " player-layout--embed" if @embed_mode %>">
  <header class="player-header">
    <div class="player-header__brand">
      <%= render "shared/brand_icon", css_class: "player-header__icon" %>
      <div class="player-header__title">
        <% if content_for?(:workflow_title) %>
          <%= yield(:workflow_title) %>
        <% else %>
          TurboFlows
        <% end %>
      </div>
    </div>
    <div class="player-header__actions">
      <button type="button"
              data-action="click->dark-mode#toggle"
              class="dark-mode-toggle"
              aria-label="Toggle dark mode">
        <%= icon "sun", class: "icon icon--sm is-hidden" %>
        <%= icon "moon", class: "icon icon--sm" %>
      </button>
      <% if current_user %>
        <%= link_to "Exit Player", root_path, class: "player-link" %>
      <% end %>
    </div>
  </header>

  <main class="player-main">
    <% flash.each do |type, message| %>
      <div class="flash flash--<%= type %>"><%= message %></div>
    <% end %>
    <%= yield %>
  </main>

  <footer class="player-footer">
    <span class="player-footer__mark">Powered by TurboFlows</span>
  </footer>
</body>
</html>
