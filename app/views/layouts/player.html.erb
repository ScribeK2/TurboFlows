<!DOCTYPE html>
<html lang="en" data-controller="dark-mode">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= content_for?(:title) ? yield(:title) : "TurboFlows Player" %></title>
  <meta name="csrf-token" content="<%= form_authenticity_token %>">
  <%= csrf_meta_tags %>
  <%= csp_meta_tag %>

  <!-- Initialize theme before page renders to prevent flash -->
  <script nonce="<%= content_security_policy_nonce %>">
    (function() {
      const savedTheme = localStorage.getItem("theme");
      const prefersDark = window.matchMedia("(prefers-color-scheme: dark)").matches;
      document.documentElement.dataset.theme =
        (savedTheme === "dark" || (!savedTheme && prefersDark)) ? "dark" : "light";
    })();
  </script>

  <%= stylesheet_link_tag "application", "_global", "reset", "base",
        "buttons", "forms", "cards", "badges", "flash",
        "scenarios", "utilities", "_tags", "_player", "_media", "_form_step",
        data: { turbo_track: "reload" } %>
  <%= javascript_importmap_tags %>
</head>
<body class="player-layout<%= " player-layout--embed" if @embed_mode %>">
  <header class="player-header">
    <div class="player-header__brand">
      <svg class="player-header__icon" viewBox="0 0 24 24" fill="none" aria-hidden="true">
        <circle cx="5" cy="6" r="2" fill="#10b981" />
        <circle cx="12" cy="18" r="2" fill="#3b82f6" />
        <circle cx="19" cy="6" r="2" fill="#f59e0b" />
        <path stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" d="M5 8v2a4 4 0 004 4h2" />
        <path stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" d="M19 8v2a4 4 0 01-4 4h-2" />
      </svg>
      <div class="player-header__title">
        <% if content_for?(:workflow_title) %>
          <%= yield(:workflow_title) %>
        <% else %>
          TurboFlows
        <% end %>
      </div>
    </div>
    <div class="player-header__actions">
      <button type="button"
              data-action="click->dark-mode#toggle"
              class="dark-mode-toggle"
              aria-label="Toggle dark mode">
        <svg data-dark-mode-target="sunIcon" class="icon icon--sm is-hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z"></path>
        </svg>
        <svg data-dark-mode-target="moonIcon" class="icon icon--sm" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z"></path>
        </svg>
      </button>
      <% if current_user %>
        <%= link_to "Exit Player", play_path, class: "player-link" %>
      <% end %>
    </div>
  </header>

  <main class="player-main">
    <% flash.each do |type, message| %>
      <div class="flash flash--<%= type %>"><%= message %></div>
    <% end %>
    <%= yield %>
  </main>

  <footer class="player-footer">
    <span class="player-footer__mark">Powered by TurboFlows</span>
  </footer>
</body>
</html>
