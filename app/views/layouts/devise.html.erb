<!DOCTYPE html>
<html class="h-full" data-controller="dark-mode">
  <head>
    <title>Flows - Workflow Builder</title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <!-- Initialize dark mode before page renders to prevent flash -->
    <script nonce="<%= content_security_policy_nonce %>">
      (function() {
        const savedTheme = localStorage.getItem("theme");
        const prefersDark = window.matchMedia("(prefers-color-scheme: dark)").matches;
        if (savedTheme === "dark" || (!savedTheme && prefersDark)) {
          document.documentElement.classList.add("dark");
        }
      })();
    </script>

    <!-- Favicon -->
    <link rel="icon" href="/favicon.ico" sizes="any">
    <link rel="icon" href="/favicon.svg" type="image/svg+xml">

    <!-- Google Fonts - Plus Jakarta Sans -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap" rel="stylesheet">

    <%= stylesheet_link_tag "actiontext", "data-turbo-track": "reload" %>
    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= stylesheet_link_tag "tailwind", "data-turbo-track": "reload" %>

    <!-- Importmap for ES modules -->
    <%= javascript_importmap_tags %>
  </head>

  <body class="min-h-screen bg-slate-50 dark:bg-slate-900 transition-colors duration-300 font-sans antialiased">
    <!-- Minimal Auth Header -->
    <nav class="fixed top-0 left-0 right-0 z-50 bg-white dark:bg-slate-800 border-b border-slate-200 dark:border-slate-700 shadow-sm">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex justify-between h-16">
          <div class="flex-shrink-0 flex items-center">
            <%= link_to root_path, class: "inline-flex items-center gap-2 group hover:scale-105 transition-transform duration-300" do %>
              <svg class="w-7 h-7 text-slate-400 dark:text-slate-300 group-hover:rotate-12 transition-transform duration-300" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                <circle cx="5" cy="6" r="2" fill="#10b981" />
                <circle cx="12" cy="18" r="2" fill="#3b82f6" />
                <circle cx="19" cy="6" r="2" fill="#f59e0b" />
                <path stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" d="M5 8v2a4 4 0 004 4h2" />
                <path stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" d="M19 8v2a4 4 0 01-4 4h-2" />
              </svg>
              <span class="text-2xl font-extrabold tracking-tight text-slate-800 dark:text-slate-100">Flows</span>
            <% end %>
          </div>
          <div class="flex items-center">
            <!-- Dark Mode Toggle -->
            <button
              type="button"
              data-action="click->dark-mode#toggle"
              class="p-2 rounded-full bg-slate-100 dark:bg-slate-700 border border-slate-200 dark:border-slate-600 hover:bg-slate-200 dark:hover:bg-slate-600 transition-all duration-200 hover:scale-110 focus:outline-none focus:ring-2 focus:ring-slate-500 focus:ring-offset-2 dark:focus:ring-offset-slate-800"
              aria-label="Toggle dark mode"
            >
              <!-- Sun Icon (shown in dark mode to switch to light) -->
              <svg data-dark-mode-target="sunIcon" class="w-5 h-5 text-yellow-500 hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z"></path>
              </svg>
              <!-- Moon Icon (shown in light mode to switch to dark) -->
              <svg data-dark-mode-target="moonIcon" class="w-5 h-5 text-slate-500 dark:text-slate-400" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z"></path>
              </svg>
            </button>
          </div>
        </div>
      </div>
    </nav>

    <!-- Centered Auth Content -->
    <div class="pt-16 min-h-screen flex flex-col items-center justify-center px-4 sm:px-6 lg:px-8">
      <!-- Flash Messages -->
      <% if notice %>
        <div class="fixed top-20 right-4 z-40 animate-slide-in-right cursor-pointer max-w-md"
             data-controller="alert"
             data-alert-duration-value="5000"
             data-action="click->alert#dismiss">
          <div class="relative bg-emerald-500 dark:bg-emerald-600 text-white px-6 py-3 rounded-xl shadow-lg overflow-hidden" role="alert">
            <span class="block sm:inline font-medium text-sm"><%= notice %></span>
            <div class="absolute bottom-0 left-0 h-0.5 bg-white/40 rounded-b-xl animate-shrink" data-alert-target="progress"></div>
          </div>
        </div>
      <% end %>

      <% if alert %>
        <div class="fixed top-20 right-4 z-40 animate-slide-in-right cursor-pointer max-w-md"
             data-controller="alert"
             data-alert-duration-value="5000"
             data-action="click->alert#dismiss">
          <div class="relative bg-red-500 dark:bg-red-600 text-white px-6 py-3 rounded-xl shadow-lg overflow-hidden" role="alert">
            <span class="block sm:inline font-medium text-sm"><%= alert %></span>
            <div class="absolute bottom-0 left-0 h-0.5 bg-white/40 rounded-b-xl animate-shrink" data-alert-target="progress"></div>
          </div>
        </div>
      <% end %>

      <%= render "devise/shared/workflow_illustration" %>
      <%= yield %>
    </div>
  </body>
</html>
