<div class="auth-card">
  <div class="auth-card__header">
    <h2 class="auth-card__title">Welcome back</h2>
    <p class="auth-card__subtitle">Sign in to your account</p>
  </div>

  <%= form_for(resource, as: resource_name, url: session_path(resource_name), html: { class: "auth-form", data: { turbo: false } }) do |f| %>
    <div class="auth-form__field">
      <%= f.label :email, class: "form-label" %>
      <%= f.email_field :email, autofocus: true, autocomplete: "email", aria: { required: true }, class: "form-input" %>
    </div>

    <div class="auth-form__field" data-controller="password-toggle">
      <%= f.label :password, class: "form-label" %>
      <div class="auth-form__password-wrap">
        <%= f.password_field :password, autocomplete: "current-password", aria: { required: true }, data: { password_toggle_target: "input" }, class: "auth-form__input" %>
        <button type="button" data-action="click->password-toggle#toggle" class="auth-form__password-toggle" aria-label="Toggle password visibility">
          <!-- Eye icon (show password) -->
          <%= icon "eye", class: "icon" %>
          <!-- Eye-off icon (hide password) -->
          <%= icon "eye-slash", class: "icon is-hidden" %>
        </button>
      </div>
    </div>

    <% if devise_mapping.rememberable? %>
      <div class="auth-form__check">
        <%= f.check_box :remember_me, class: "form-checkbox" %>
        <%= f.label :remember_me, class: "form-label" %>
      </div>
    <% end %>

    <div class="auth-form__actions">
      <%= f.submit "Sign in", class: "btn btn--primary w-full" %>
    </div>
  <% end %>

  <div class="auth-links">
    <%= render "devise/shared/links" %>
  </div>
</div>
