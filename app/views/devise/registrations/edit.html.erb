<div class="page-content">
  <!-- Page Header -->
  <div class="mb-6">
    <h1 class="text-xl font-bold">Account Settings</h1>
    <p class="text-sm form-hint">Manage your account information, email, and security settings.</p>
  </div>

  <!-- Account Overview Card - Display Name Only (No Password Required) -->
  <% overview_content = capture do %>
    <p class="text-sm form-hint mb-4">
      This information helps identify you in Flows.
    </p>

    <%= form_for(resource, as: resource_name, url: registration_path(resource_name), html: { method: :patch }) do |f| %>
      <%= render "devise/shared/error_messages", resource: resource %>

      <div class="auth-form__info-row">
        <div class="form-group flex-1">
          <%= f.label :display_name, "Display name", class: "form-label" %>
          <%= f.text_field :display_name, class: "form-input" %>
          <p class="form-hint">
            This name appears in the top bar instead of your email.
          </p>
        </div>

        <div class="form-group">
          <span class="form-label">Role</span>
          <span class="badge <%= case resource.role
             when 'admin' then 'badge--admin'
             when 'editor' then 'badge--editor'
             else 'badge--regular'
             end %>">
            <%= resource.role.capitalize %>
          </span>
        </div>
      </div>

      <div class="auth-form__stats">
        <div>
          <p class="form-hint">Workflows</p>
          <p class="font-semibold"><%= resource.workflows.count %></p>
        </div>
        <div>
          <p class="form-hint">Groups</p>
          <p class="font-semibold"><%= resource.groups.count %></p>
        </div>
        <div>
          <p class="form-hint">Member since</p>
          <p class="font-semibold"><%= l(resource.created_at.to_date, format: :long) %></p>
        </div>
      </div>

      <div class="auth-form__section-footer">
        <%= link_to "Back to dashboard", root_path, class: "btn btn--plain btn--sm" %>
        <%= f.submit "Save display name", class: "btn btn--primary" %>
      </div>
    <% end %>
  <% end %>

  <%= render partial: "shared/card", locals: {
    title: "Account overview",
    icon: icon("user-circle", class: "icon icon--lg"),
    content: overview_content,
    content_class: "space-y-4"
  } %>

  <!-- Email Settings Card (Requires Current Password) -->
  <% email_content = capture do %>
    <p class="text-sm form-hint mb-4">
      Update the email address you use to sign in. We may send a confirmation email to complete this change.
    </p>

    <%= form_for(resource, as: resource_name, url: registration_path(resource_name), html: { method: :patch }) do |f| %>
      <%= render "devise/shared/error_messages", resource: resource %>

      <div class="form-group">
        <%= f.label :email, "Email", class: "form-label" %>
        <%= f.email_field :email, autocomplete: "email", class: "form-input" %>
      </div>

      <div class="form-group mt-4">
        <%= f.label :current_password, "Current password", class: "form-label" %>
        <%= f.password_field :current_password, autocomplete: "current-password", class: "form-input" %>
        <p class="form-hint">We need your current password to confirm this change.</p>
      </div>

      <div class="auth-form__section-footer">
        <%= link_to "Back to dashboard", root_path, class: "btn btn--plain btn--sm" %>
        <%= f.submit "Update email", class: "btn btn--primary" %>
      </div>
    <% end %>
  <% end %>

  <%= render partial: "shared/card", locals: {
    title: "Email settings",
    icon: icon("envelope", class: "icon icon--lg"),
    content: email_content,
    content_class: "space-y-4"
  } %>

  <!-- Password Settings Card (Requires Current Password) -->
  <% password_content = capture do %>
    <p class="text-sm form-hint mb-4">
      Use a strong, unique password to keep your account secure.
    </p>

    <%= form_for(resource, as: resource_name, url: registration_path(resource_name), html: { method: :patch }) do |f| %>
      <%= render "devise/shared/error_messages", resource: resource %>

      <div class="form-group">
        <%= f.label :current_password, "Current password", class: "form-label" %>
        <%= f.password_field :current_password, autocomplete: "current-password", class: "form-input" %>
        <p class="form-hint">We need your current password to confirm your changes.</p>
      </div>

      <div class="form-group">
        <%= f.label :password, "New password", class: "form-label" %>
        <% if @minimum_password_length %>
          <em class="form-hint">(<%= @minimum_password_length %> characters minimum)</em>
        <% end %>
        <%= f.password_field :password, autocomplete: "new-password", class: "form-input" %>
      </div>

      <div class="form-group">
        <%= f.label :password_confirmation, "Confirm new password", class: "form-label" %>
        <%= f.password_field :password_confirmation, autocomplete: "new-password", class: "form-input" %>
      </div>

      <div class="auth-form__section-footer">
        <%= link_to "Back to dashboard", root_path, class: "btn btn--plain btn--sm" %>
        <%= f.submit "Update password", class: "btn btn--primary" %>
      </div>
    <% end %>
  <% end %>

  <%= render partial: "shared/card", locals: {
    title: "Security",
    icon: icon("lock-closed", class: "icon icon--lg"),
    content: password_content,
    content_class: "space-y-4"
  } %>
</div>
