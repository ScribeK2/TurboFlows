<div class="auth-card">
  <div class="auth-card__header">
    <h2 class="auth-card__title">Create your account</h2>
    <p class="auth-card__subtitle">Get started with Flows</p>
  </div>

  <%= form_for(resource, as: resource_name, url: registration_path(resource_name), html: { class: "auth-form" }) do |f| %>
    <%= render "devise/shared/error_messages", resource: resource %>

    <div class="auth-form__field">
      <%= f.label :email, class: "form-label" %>
      <%= f.email_field :email, autofocus: true, autocomplete: "email", aria: { required: true }, class: "form-input" %>
    </div>

    <div class="auth-form__field" data-controller="password-toggle">
      <div class="auth-form__label-row">
        <%= f.label :password, class: "form-label" %>
        <% if @minimum_password_length %>
          <span class="text-xs form-hint"><%= @minimum_password_length %> characters minimum</span>
        <% end %>
      </div>
      <div class="auth-form__password-wrap">
        <%= f.password_field :password, autocomplete: "new-password", aria: { required: true }, data: { password_toggle_target: "input" }, class: "form-input" %>
        <button type="button" data-action="click->password-toggle#toggle" class="auth-form__password-toggle" aria-label="Toggle password visibility">
          <%= icon "eye", class: "icon" %>
          <%= icon "eye-slash", class: "icon is-hidden" %>
        </button>
      </div>
    </div>

    <div class="auth-form__field" data-controller="password-toggle">
      <%= f.label :password_confirmation, class: "form-label" %>
      <div class="auth-form__password-wrap">
        <%= f.password_field :password_confirmation, autocomplete: "new-password", aria: { required: true }, data: { password_toggle_target: "input" }, class: "form-input" %>
        <button type="button" data-action="click->password-toggle#toggle" class="auth-form__password-toggle" aria-label="Toggle password visibility">
          <%= icon "eye", class: "icon" %>
          <%= icon "eye-slash", class: "icon is-hidden" %>
        </button>
      </div>
    </div>

    <div class="auth-form__actions">
      <%= f.submit "Create account", class: "btn btn--primary w-full" %>
    </div>
  <% end %>

  <div class="auth-links">
    <%= render "devise/shared/links" %>
  </div>
</div>
