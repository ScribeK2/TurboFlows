<div class="dashboard-layout">
  <%# -- A. Personalized Header -- %>
  <div class="page-header-section animate-fade-in">
    <h1 class="page-header-section__title">Dashboard</h1>
    <p class="page-header-section__subtitle">
      Welcome back, <span class="font-medium"><%= current_user.display_label %></span>
    </p>
  </div>

  <%# -- B. Quick Actions Row (editors/admins only) -- %>
  <% if current_user&.can_create_workflows? %>
    <div class="dashboard-actions animate-fade-in">
      <%= link_to new_workflow_path, class: "btn btn--primary", aria: { label: "Create a new workflow" } do %>
        <svg class="icon icon--sm" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4" />
        </svg>
        Create Workflow
      <% end %>
      <%= link_to templates_path, class: "btn btn--secondary", aria: { label: "Browse workflow templates" } do %>
        <svg class="icon icon--sm" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10" />
        </svg>
        Browse Templates
      <% end %>
    </div>
  <% end %>

  <%# -- C. Stat Cards Grid -- %>
  <div class="stat-grid">
    <%# Card 1: Total Workflows %>
    <div class="stat-card animate-fade-in-up hover-lift" style="animation-delay: 0.1s;" aria-label="Total workflows: <%= @workflow_count %>">
      <div>
        <p class="stat-card__value"><%= @workflow_count %></p>
        <p class="stat-card__label">Total Workflows</p>
      </div>
      <div class="stat-card__icon">
        <svg class="icon icon--xl" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
        </svg>
      </div>
    </div>

    <%# Card 2: Published %>
    <div class="stat-card animate-fade-in-up hover-lift" style="animation-delay: 0.15s;" aria-label="Published workflows: <%= @published_count %>">
      <div>
        <p class="stat-card__value"><%= @published_count %></p>
        <p class="stat-card__label">Published</p>
        <% if @draft_count > 0 %>
          <p class="stat-card__detail"><%= @draft_count %> draft<%= @draft_count == 1 ? "" : "s" %></p>
        <% end %>
      </div>
      <div class="stat-card__icon">
        <svg class="icon icon--xl" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
        </svg>
      </div>
    </div>

    <%# Card 3: Scenarios Run %>
    <div class="stat-card animate-fade-in-up hover-lift" style="animation-delay: 0.2s;" aria-label="Scenarios run: <%= @scenario_total %>">
      <div>
        <p class="stat-card__value"><%= @scenario_total %></p>
        <p class="stat-card__label">Scenarios Run</p>
        <% if @scenario_active > 0 %>
          <p class="stat-card__detail">
            <span class="status-dot" style="background: var(--color-positive);" aria-hidden="true"></span>
            <%= @scenario_active %> active
          </p>
        <% end %>
      </div>
      <div class="stat-card__icon">
        <svg class="icon icon--xl" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14.752 11.168l-3.197-2.132A1 1 0 0010 9.87v4.263a1 1 0 001.555.832l3.197-2.132a1 1 0 000-1.664z" />
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
        </svg>
      </div>
    </div>

    <%# Card 4: Completion Rate %>
    <div class="stat-card animate-fade-in-up hover-lift" style="animation-delay: 0.25s;" aria-label="Scenario completion rate: <%= @scenario_completion_rate %>%">
      <div>
        <p class="stat-card__value"><%= @scenario_completion_rate %>%</p>
        <p class="stat-card__label">Completion Rate</p>
        <% if @scenario_total > 0 %>
          <p class="stat-card__detail"><%= @scenario_completed %> of <%= @scenario_total %></p>
        <% end %>
      </div>
      <div class="stat-card__progress">
        <svg class="stat-card__progress-svg" viewBox="0 0 48 48">
          <circle class="stat-card__progress-track" cx="24" cy="24" r="20" fill="none" stroke-width="3" />
          <circle class="stat-card__progress-fill" cx="24" cy="24" r="20" fill="none" stroke-width="3" stroke-linecap="round" stroke-dasharray="<%= (125.66).round(2) %>" stroke-dashoffset="<%= (125.66 * (1 - @scenario_completion_rate / 100.0)).round(2) %>" />
        </svg>
        <div class="stat-card__progress-icon">
          <svg class="icon icon--sm" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
          </svg>
        </div>
      </div>
    </div>
  </div>

  <%# -- D. Section Separator -- %>
  <hr class="dashboard-divider">

  <%# -- E. Two-Column Content -- %>
  <div class="dashboard-grid">
    <%# Left: Recent Workflows (2/3) %>
    <div class="recent-section animate-fade-in-up" style="animation-delay: 0.3s;">
      <div class="recent-section__header">
        <div>
          <h2 class="recent-section__title">Recent Workflows</h2>
          <p class="recent-section__subtitle">Your most recently created workflows</p>
        </div>
        <%= link_to "View all", workflows_path, class: "btn btn--plain btn--sm", aria: { label: "View all workflows" } %>
      </div>
      <div class="wf-list">
        <% if @workflows.any? %>
          <% @workflows.each_with_index do |workflow, index| %>
            <div class="wf-list-item animate-fade-in-up" style="animation-delay: <%= 0.35 + (index * 0.05) %>s;">
              <div class="wf-list-item__info">
                <div class="wf-list-item__title">
                  <%= link_to workflow.title, workflow_path(workflow), aria: { label: "View workflow: #{workflow.title}" } %>
                  <%= workflow_status_badge(workflow) %>
                </div>
                <div class="wf-list-item__meta">
                  Created <%= time_ago_in_words(workflow.created_at) %> ago
                </div>
              </div>
              <div class="wf-list-item__actions">
                <%= link_to start_workflow_path(workflow), class: "btn btn--positive btn--sm", aria: { label: "Start scenario for #{workflow.title}" } do %>
                  <svg class="icon icon--xs" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14.752 11.168l-3.197-2.132A1 1 0 0010 9.87v4.263a1 1 0 001.555.832l3.197-2.132a1 1 0 000-1.664z" />
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                  </svg>
                  Start
                <% end %>
                <%= link_to workflow_path(workflow), class: "btn btn--secondary btn--sm", aria: { label: "View workflow: #{workflow.title}" } do %>
                  View
                <% end %>
                <% if workflow.can_be_edited_by?(current_user) %>
                  <%= link_to edit_workflow_path(workflow), class: "btn btn--secondary btn--sm", aria: { label: "Edit workflow: #{workflow.title}" } do %>
                    Edit
                  <% end %>
                <% end %>
              </div>
            </div>
          <% end %>
        <% else %>
          <div class="empty-state">
            <div class="empty-state__icon">
              <svg class="icon icon--xl" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
              </svg>
            </div>
            <h3 class="empty-state__title">No workflows yet</h3>
            <% if current_user&.can_create_workflows? %>
              <p class="empty-state__message">Get started by creating your first workflow or browsing templates.</p>
              <div class="empty-state__actions">
                <%= link_to new_workflow_path, class: "btn btn--primary btn--sm", aria: { label: "Create your first workflow" } do %>
                  <svg class="icon icon--xs" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4" />
                  </svg>
                  Create Workflow
                <% end %>
                <%= link_to templates_path, class: "btn btn--secondary btn--sm", aria: { label: "Browse workflow templates" } do %>
                  Browse Templates
                <% end %>
              </div>
            <% else %>
              <p class="empty-state__message">Browse public workflows or templates to get started.</p>
            <% end %>
          </div>
        <% end %>
      </div>
    </div>

    <%# Right: Recent Activity / Scenarios (1/3) %>
    <div class="recent-section animate-fade-in-up" style="animation-delay: 0.35s;">
      <div class="recent-section__header">
        <div>
          <h2 class="recent-section__title">Recent Activity</h2>
          <p class="recent-section__subtitle">Your latest scenarios</p>
        </div>
      </div>
      <div class="activity-feed">
        <% if @recent_scenarios.any? %>
          <% @recent_scenarios.each do |scenario| %>
            <% workflow = scenario.workflow %>
            <% if workflow %>
              <%= link_to scenario_path(scenario), class: "activity-feed__item", aria: { label: "View scenario for #{workflow.title}" } do %>
                <div class="activity-feed__dot activity-feed__dot--<%= scenario.status %>" aria-hidden="true"></div>
                <div class="activity-feed__body">
                  <p class="font-medium truncate"><%= workflow.title %></p>
                  <p class="activity-feed__meta">
                    <%= scenario.status.capitalize %> &middot; <%= time_ago_in_words(scenario.created_at) %> ago
                  </p>
                </div>
              <% end %>
            <% else %>
              <div class="activity-feed__item">
                <div class="activity-feed__dot" aria-hidden="true"></div>
                <div class="activity-feed__body">
                  <p class="text-sm italic truncate" style="color: var(--color-ink-muted);">Deleted workflow</p>
                  <p class="activity-feed__meta">
                    <%= scenario.status.capitalize %> &middot; <%= time_ago_in_words(scenario.created_at) %> ago
                  </p>
                </div>
              </div>
            <% end %>
          <% end %>
        <% else %>
          <div class="empty-state">
            <div class="empty-state__icon">
              <svg class="icon icon--xl" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14.752 11.168l-3.197-2.132A1 1 0 0010 9.87v4.263a1 1 0 001.555.832l3.197-2.132a1 1 0 000-1.664z" />
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
            </div>
            <p class="empty-state__message">Start a workflow to see your activity here</p>
          </div>
        <% end %>
      </div>
    </div>
  </div>
</div>
