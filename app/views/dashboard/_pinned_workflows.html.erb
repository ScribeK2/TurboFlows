<div id="pinned-workflows-section">
  <% pinned = dashboard.pinned_workflows %>
  <% if pinned.any? %>
    <div class="pinned-section animate-fade-in-up">
      <div class="recent-section__header recent-section__header--plain">
        <div>
          <h2 class="recent-section__title">Pinned Workflows</h2>
          <p class="recent-section__subtitle">Your quick-access flows</p>
        </div>
      </div>

      <div class="carousel-wrapper" data-controller="carousel">
        <button class="carousel-arrow carousel-arrow--left"
                data-carousel-target="leftArrow"
                data-action="click->carousel#scrollLeft"
                aria-label="Scroll left">
          <%= icon "chevron-left", class: "icon icon--sm" %>
        </button>

        <div class="carousel-track" data-carousel-target="track">
          <% pinned.each_with_index do |workflow, index| %>
            <%= button_to play_workflow_path(workflow), method: :post,
                  class: "carousel-card card animate-fade-in-up",
                  style: "animation-delay: #{0.05 * index}s;",
                  aria: { label: "Run #{workflow.title}" } do %>
              <span class="carousel-card__title"><%= workflow.title %></span>
              <% if workflow.description.present? %>
                <span class="carousel-card__desc"><%= workflow.description.to_plain_text.truncate(80) %></span>
              <% end %>
              <span class="carousel-card__meta">
                <%= icon "clipboard", class: "icon icon--xs" %>
                <%= pluralize(workflow.steps.size, "step") %>
              </span>
            <% end %>
          <% end %>

          <% if pinned.size >= UserWorkflowPin::MAX_PINS %>
            <%= link_to workflows_path, class: "carousel-card carousel-card--manage" do %>
              <span class="carousel-card__manage-text">Manage Pinned</span>
              <%= icon "arrow-right", class: "icon icon--sm" %>
            <% end %>
          <% end %>
        </div>

        <button class="carousel-arrow carousel-arrow--right"
                data-carousel-target="rightArrow"
                data-action="click->carousel#scrollRight"
                aria-label="Scroll right">
          <%= icon "chevron-right", class: "icon icon--sm" %>
        </button>
      </div>
    </div>
  <% else %>
    <div class="dashboard-empty animate-fade-in-up">
      <div class="dashboard-empty__icon">
        <%= icon "bookmark", class: "icon icon--xl" %>
      </div>
      <h3 class="dashboard-empty__title">No pinned workflows</h3>
      <p class="dashboard-empty__text">Pin your most-used flows for instant access</p>
      <div class="empty-state__actions">
        <%= link_to "Browse workflows", workflows_path, class: "btn btn--plain btn--sm" %>
      </div>
    </div>
  <% end %>
</div>
