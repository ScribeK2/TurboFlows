<div class="auth-card">
  <div class="auth-card__header">
    <h2 class="auth-card__title">Set up TurboFlows</h2>
    <p class="auth-card__subtitle">Create the administrator account to get started</p>
  </div>

  <%= form_with model: @user, url: first_run_path, html: { class: "auth-form" } do |f| %>
    <% if @user.errors.any? %>
      <div id="error_explanation" class="flash flash--alert mb-4">
        <div class="flash__body">
          <div class="flash__text">
            <strong><%= pluralize(@user.errors.count, "error") %> prohibited this account from being saved:</strong>
            <ul class="mt-1 pl-5 list-disc">
              <% @user.errors.full_messages.each do |message| %>
                <li><%= message %></li>
              <% end %>
            </ul>
          </div>
        </div>
      </div>
    <% end %>

    <div class="auth-form__field">
      <%= f.label :email, class: "form-label" %>
      <%= f.email_field :email, autofocus: true, autocomplete: "email",
          aria: { required: true }, class: "form-input" %>
    </div>

    <div class="auth-form__field" data-controller="password-toggle">
      <div class="auth-form__label-row">
        <%= f.label :password, class: "form-label" %>
        <span class="text-xs form-hint"><%= @minimum_password_length %> characters minimum</span>
      </div>
      <div class="auth-form__password-wrap">
        <%= f.password_field :password, autocomplete: "new-password",
            aria: { required: true },
            data: { password_toggle_target: "input" },
            class: "form-input" %>
        <button type="button" data-action="click->password-toggle#toggle"
                class="auth-form__password-toggle" aria-label="Toggle password visibility">
          <%= icon "eye", class: "icon" %>
          <%= icon "eye-slash", class: "icon is-hidden" %>
        </button>
      </div>
    </div>

    <div class="auth-form__field" data-controller="password-toggle">
      <%= f.label :password_confirmation, class: "form-label" %>
      <div class="auth-form__password-wrap">
        <%= f.password_field :password_confirmation, autocomplete: "new-password",
            aria: { required: true },
            data: { password_toggle_target: "input" },
            class: "form-input" %>
        <button type="button" data-action="click->password-toggle#toggle"
                class="auth-form__password-toggle" aria-label="Toggle password visibility">
          <%= icon "eye", class: "icon" %>
          <%= icon "eye-slash", class: "icon is-hidden" %>
        </button>
      </div>
    </div>

    <div class="auth-form__actions">
      <%= f.submit "Create admin account", class: "btn btn--primary w-full" %>
    </div>
  <% end %>

  <%# No auth-links section — there are no accounts yet, nothing to link to %>
</div>
