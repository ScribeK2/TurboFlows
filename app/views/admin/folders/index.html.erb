<div class="page-content">
  <div class="mb-4 flex items-center justify-between">
    <div>
      <h1>Folders in <%= @group.name %></h1>
      <p class="text-sm mt-1">Organize workflows into folders within this group.</p>
    </div>
    <div class="flex gap-2">
      <%= link_to admin_groups_path, class: "btn btn--secondary" do %>
        Back to Groups
      <% end %>
      <%= link_to new_admin_group_folder_path(@group), class: "btn btn--primary" do %>
        New Folder
      <% end %>
    </div>
  </div>

  <% if @folders.any? %>
    <div class="card">
      <ul data-controller="sortable-folders" data-sortable-folders-url-value="<%= admin_group_reorder_folders_path(@group) %>">
        <% @folders.each do |folder| %>
          <li class="wf-list-item" data-folder-id="<%= folder.id %>">
            <div class="flex items-center flex-1 min-w-0">
              <svg class="icon icon--sm mr-3 cursor-move flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 8h16M4 16h16" />
              </svg>
              <div>
                <span class="font-medium"><%= folder.name %></span>
                <span class="text-xs ml-2"><%= pluralize(folder.workflows_count, "workflow") %></span>
                <% if folder.description.present? %>
                  <p class="text-xs mt-0.5"><%= truncate(folder.description, length: 80) %></p>
                <% end %>
              </div>
            </div>
            <div class="flex items-center gap-2">
              <%= link_to edit_admin_group_folder_path(@group, folder), class: "btn btn--sm btn--secondary" do %>
                Edit
              <% end %>
              <%= link_to admin_group_folder_path(@group, folder), data: { turbo_method: :delete, turbo_confirm: "Delete folder '#{folder.name}'? Workflows will be moved to Uncategorized." }, class: "btn btn--sm btn--negative" do %>
                Delete
              <% end %>
            </div>
          </li>
        <% end %>
      </ul>
    </div>
  <% else %>
    <div class="empty-state">
      <p class="empty-state__text">No folders yet. Create one to start organizing workflows.</p>
    </div>
  <% end %>
</div>
