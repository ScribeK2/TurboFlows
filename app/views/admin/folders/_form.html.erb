<%= form_with(model: [:admin, group, folder], class: "card") do |f| %>
  <% if folder.errors.any? %>
    <div class="card__body">
      <div class="flash flash--alert">
        <div class="flash__body">
          <p class="font-medium"><%= pluralize(folder.errors.count, "error") %> prevented saving:</p>
          <ul class="mt-2 text-sm list-disc pl-5">
            <% folder.errors.full_messages.each do |msg| %>
              <li><%= msg %></li>
            <% end %>
          </ul>
        </div>
      </div>
    </div>
  <% end %>

  <div class="card__body">
    <div class="form-group">
      <%= f.label :name, class: "form-label" %>
      <%= f.text_field :name, class: "form-input", placeholder: "e.g. Website Issues" %>
    </div>

    <div class="form-group">
      <%= f.label :description, class: "form-label" %>
      <%= f.text_area :description, rows: 2, class: "form-textarea", placeholder: "Optional description" %>
    </div>
  </div>

  <div class="card__footer flex justify-end gap-3">
    <%= link_to "Cancel", admin_group_folders_path(group), class: "btn btn--plain" %>
    <%= f.submit folder.persisted? ? "Update Folder" : "Create Folder", class: "btn btn--primary" %>
  </div>
<% end %>
