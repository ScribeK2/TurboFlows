<li class="group-tree__node" data-group-id="<%= group.id %>">
  <div class="flex items-center justify-between py-2 px-3 rounded" style="padding-left: <%= level * 1.5 + 0.75 %>rem;">
    <div class="flex items-center flex-1 min-w-0">
      <% if group.children.any? %>
        <button type="button"
                class="group-toggle mr-2 p-1 rounded"
                data-action="click->group-tree#toggle"
                data-group-id="<%= group.id %>"
                aria-label="Toggle group">
          <%= icon "chevron-right", class: "icon icon--sm" %>
        </button>
      <% else %>
        <span class="w-6 mr-2"></span>
      <% end %>

      <div class="flex items-center gap-2 flex-1 min-w-0">
        <%= icon "folder", class: "icon icon--sm flex-shrink-0" %>
        <div class="flex-1 min-w-0">
          <div class="flex items-center gap-2">
            <%= link_to admin_group_path(group), class: "font-semibold" do %>
              <%= group.name %>
            <% end %>
            <span class="badge">
              <%= pluralize(group.workflows_count(include_descendants: true), 'workflow') %>
            </span>
          </div>
          <% if group.description.present? %>
            <p class="text-sm mt-0.5 truncate"><%= group.description %></p>
          <% end %>
        </div>
      </div>
    </div>

    <div class="flex items-center gap-2 ml-4">
      <%= link_to new_admin_group_path(parent_id: group.id),
                  class: "btn btn--sm btn--plain",
                  title: "Add subgroup" do %>
        <%= icon "plus", class: "icon icon--sm" %>
      <% end %>
      <%= link_to edit_admin_group_path(group),
                  class: "btn btn--sm btn--plain",
                  title: "Edit group" do %>
        <%= icon "pencil-square", class: "icon icon--sm" %>
      <% end %>
      <%= link_to admin_group_path(group),
                  data: {
                    turbo_method: :delete,
                    turbo_confirm: "Are you sure you want to delete the group '#{group.name}'? This action cannot be undone.#{group.children.any? ? ' Note: This group has subgroups that must be deleted or reassigned first.' : ''}#{group.workflows.any? ? ' Note: This group contains workflows that must be reassigned first.' : ''}"
                  },
                  class: "btn btn--sm btn--negative",
                  title: "Delete group" do %>
        <%= icon "trash", class: "icon icon--sm" %>
      <% end %>
    </div>
  </div>

  <% if group.children.any? %>
    <ul class="children is-hidden group-tree__indent" data-children data-group-id="<%= group.id %>">
      <% group.children.order(:position, :name).each do |child| %>
        <%= render partial: "admin/groups/tree_node", locals: { group: child, level: level + 1 } %>
      <% end %>
    </ul>
  <% end %>
</li>
