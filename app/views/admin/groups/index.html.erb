<div class="page-content">
  <!-- Header Section -->
  <div class="mb-4 flex items-center justify-between">
    <div>
      <h1>Group Management</h1>
      <p class="text-sm mt-1">
        Organize workflows into hierarchical groups and subgroups.
      </p>
    </div>
    <div class="flex gap-2">
      <%= link_to admin_root_path, class: "btn btn--secondary flex items-center gap-2" do %>
        <%= icon "arrow-left", class: "icon icon--sm" %>
        Back to Dashboard
      <% end %>
      <%= link_to new_admin_group_path, class: "btn btn--primary flex items-center gap-2" do %>
        <%= icon "plus", class: "icon icon--sm" %>
        New Group
      <% end %>
    </div>
  </div>

  <!-- Groups Tree -->
  <% if @groups.any? %>
    <div class="card">
      <div class="card__header">
        <h2>Groups</h2>
      </div>
      <div class="card__body">
        <ul class="group-tree" data-controller="group-tree">
          <% @groups.each do |group| %>
            <%= render partial: "admin/groups/tree_node", locals: { group: group, level: 0 } %>
          <% end %>
        </ul>
      </div>
    </div>
  <% else %>
    <div class="empty-state">
      <%= icon "lock-closed", class: "empty-state__icon" %>
      <h3 class="empty-state__title">No groups</h3>
      <p class="empty-state__text">Get started by creating a new group.</p>
      <div class="mt-4">
        <%= link_to new_admin_group_path, class: "btn btn--primary flex items-center gap-2" do %>
          <%= icon "plus", class: "icon icon--sm" %>
          New Group
        <% end %>
      </div>
    </div>
  <% end %>
</div>
