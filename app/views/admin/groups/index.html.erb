<div class="page-content">
  <!-- Header Section -->
  <div class="mb-4 flex items-center justify-between">
    <div>
      <h1>Group Management</h1>
      <p class="text-sm mt-1">
        Organize workflows into hierarchical groups and subgroups.
      </p>
    </div>
    <div class="flex gap-2">
      <%= link_to admin_root_path, class: "btn btn--secondary flex items-center gap-2" do %>
        <svg class="icon icon--sm" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
        </svg>
        Back to Dashboard
      <% end %>
      <%= link_to new_admin_group_path, class: "btn btn--primary flex items-center gap-2" do %>
        <svg class="icon icon--sm" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4" />
        </svg>
        New Group
      <% end %>
    </div>
  </div>

  <!-- Groups Tree -->
  <% if @groups.any? %>
    <div class="card">
      <div class="card__header">
        <h2>Groups</h2>
      </div>
      <div class="card__body">
        <ul class="group-tree" data-controller="group-tree">
          <% @groups.each do |group| %>
            <%= render partial: "admin/groups/tree_node", locals: { group: group, level: 0 } %>
          <% end %>
        </ul>
      </div>
    </div>
  <% else %>
    <div class="empty-state">
      <svg class="empty-state__icon" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10" />
      </svg>
      <h3 class="empty-state__title">No groups</h3>
      <p class="empty-state__text">Get started by creating a new group.</p>
      <div class="mt-4">
        <%= link_to new_admin_group_path, class: "btn btn--primary flex items-center gap-2" do %>
          <svg class="icon icon--sm" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4" />
          </svg>
          New Group
        <% end %>
      </div>
    </div>
  <% end %>
</div>
