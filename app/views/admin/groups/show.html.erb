<div class="page-content">
  <!-- Breadcrumb -->
  <nav class="mb-4">
    <ol class="flex items-center gap-2 text-sm">
      <li><%= link_to "Admin", admin_root_path %></li>
      <li><span>/</span></li>
      <li><%= link_to "Groups", admin_groups_path %></li>
      <li><span>/</span></li>
      <li class="font-medium"><%= @group.name %></li>
    </ol>
  </nav>

  <!-- Header Section -->
  <div class="mb-4 flex items-center justify-between">
    <div>
      <h1><%= @group.name %></h1>
      <% if @group.description.present? %>
        <p class="text-sm mt-1"><%= @group.description %></p>
      <% end %>
      <div class="flex items-center gap-4 text-sm mt-2">
        <span>Path: <%= @group.full_path %></span>
        <span>&bull;</span>
        <span><%= pluralize(@group.workflows_count(include_descendants: true), 'workflow') %></span>
        <% if @group.parent.present? %>
          <span>&bull;</span>
          <span>Parent: <%= link_to @group.parent.name, admin_group_path(@group.parent) %></span>
        <% end %>
      </div>
    </div>
    <div class="flex gap-2">
      <%= link_to admin_groups_path, class: "btn btn--secondary flex items-center gap-2" do %>
        <%= icon "arrow-left", class: "icon icon--sm" %>
        Back to Groups
      <% end %>
      <%= link_to edit_admin_group_path(@group), class: "btn btn--secondary flex items-center gap-2" do %>
        <%= icon "pencil-square", class: "icon icon--sm" %>
        Edit Group
      <% end %>
    </div>
  </div>

  <!-- Workflows in this Group -->
  <% if @workflows.any? %>
    <div class="card">
      <div class="card__header">
        <h2>Workflows in this Group</h2>
      </div>
      <% @workflows.each do |workflow| %>
        <div class="wf-list-item">
          <div class="wf-list-item__info">
            <div class="flex items-center gap-2 mb-1">
              <%= link_to workflow.title, workflow_path(workflow), class: "wf-list-item__title" %>
              <% if workflow.is_public? %>
                <span class="badge badge--published">Public</span>
              <% end %>
            </div>
            <p class="wf-list-item__meta">
              by <%= workflow.user.email %> &bull; <%= pluralize(workflow.steps.size, "step") %> &bull; Created <%= time_ago_in_words(workflow.created_at) %> ago
            </p>
          </div>
        </div>
      <% end %>
    </div>
  <% else %>
    <div class="empty-state">
      <%= icon "document-text", class: "empty-state__icon" %>
      <h3 class="empty-state__title">No workflows in this group</h3>
      <p class="empty-state__text">Workflows assigned to this group will appear here.</p>
    </div>
  <% end %>
</div>
