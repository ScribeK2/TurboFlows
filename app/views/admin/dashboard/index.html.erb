<div class="page-content">
  <!-- Header Section -->
  <div class="page-header-section">
    <h1 class="page-header-section__title">Admin Dashboard</h1>
    <p class="page-header-section__subtitle">
      Manage users, workflows, and system settings.
    </p>
  </div>

  <!-- Quick Action Buttons -->
  <div class="admin-grid mb-4">
    <%= link_to admin_users_path, class: "btn btn--secondary flex items-center gap-2 justify-center" do %>
      <svg class="icon icon--sm" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z" />
      </svg>
      Manage Users
    <% end %>
    <%= link_to admin_workflows_path, class: "btn btn--secondary flex items-center gap-2 justify-center" do %>
      <svg class="icon icon--sm" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
      </svg>
      All Workflows
    <% end %>
    <%= link_to admin_groups_path, class: "btn btn--secondary flex items-center gap-2 justify-center" do %>
      <svg class="icon icon--sm" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 7v10a2 2 0 002 2h14a2 2 0 002-2V9a2 2 0 00-2-2h-6l-2-2H5a2 2 0 00-2 2z" />
      </svg>
      Manage Groups
    <% end %>
    <%= link_to admin_analytics_path, class: "btn btn--secondary flex items-center gap-2 justify-center" do %>
      <svg class="icon icon--sm" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z" />
      </svg>
      Analytics
    <% end %>
  </div>

  <!-- Stats Cards Grid -->
  <div class="stat-grid mb-4">
    <!-- Users Card -->
    <div class="stat-card">
      <div class="flex items-center justify-between">
        <div>
          <p class="stat-card__value"><%= @users_count %></p>
          <p class="stat-card__label">Total Users</p>
        </div>
        <svg class="icon icon--xl" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z" />
        </svg>
      </div>
    </div>

    <!-- Workflows Card -->
    <div class="stat-card">
      <div class="flex items-center justify-between">
        <div>
          <p class="stat-card__value"><%= @workflows_count %></p>
          <p class="stat-card__label">Total Workflows</p>
        </div>
        <svg class="icon icon--xl" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
        </svg>
      </div>
    </div>

    <!-- Public Workflows Card -->
    <div class="stat-card">
      <div class="flex items-center justify-between">
        <div>
          <p class="stat-card__value"><%= @public_workflows_count %></p>
          <p class="stat-card__label">Public Workflows</p>
        </div>
        <svg class="icon icon--xl" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
        </svg>
      </div>
    </div>

    <!-- Templates Card -->
    <div class="stat-card">
      <div class="flex items-center justify-between">
        <div>
          <p class="stat-card__value"><%= @templates_count %></p>
          <p class="stat-card__label">Templates</p>
        </div>
        <svg class="icon icon--xl" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10" />
        </svg>
      </div>
    </div>
  </div>

  <!-- Recent Activity Section -->
  <div class="admin-grid">
    <!-- Recent Users -->
    <div class="admin-recent">
      <div class="card__header">
        <h3>Recent Users</h3>
      </div>
      <% if @recent_users.any? %>
        <% @recent_users.each do |user| %>
          <div class="admin-recent__item">
            <div class="flex items-center gap-2">
              <span class="font-medium truncate"><%= user.email %></span>
              <%
                badge_mod = case user.role
                  when 'admin' then 'badge--admin'
                  when 'editor' then 'badge--editor'
                  else 'badge--regular'
                end
              %>
              <span class="badge <%= badge_mod %>"><%= user.role.capitalize %></span>
            </div>
            <p class="text-xs mt-1">
              Joined <%= time_ago_in_words(user.created_at) %> ago
            </p>
          </div>
        <% end %>
      <% else %>
        <div class="empty-state p-4">
          <p class="empty-state__text">No users yet</p>
        </div>
      <% end %>
    </div>

    <!-- Recent Workflows -->
    <div class="admin-recent">
      <div class="card__header">
        <h3>Recent Workflows</h3>
      </div>
      <% if @recent_workflows.any? %>
        <% @recent_workflows.each do |workflow| %>
          <div class="admin-recent__item">
            <p class="font-medium">
              <%= link_to workflow.title, workflow_path(workflow) %>
            </p>
            <p class="text-xs mt-1">
              by <%= workflow.user.email %> - <%= workflow.is_public? ? "Public" : "Private" %> - <%= time_ago_in_words(workflow.created_at) %> ago
            </p>
          </div>
        <% end %>
      <% else %>
        <div class="empty-state p-4">
          <p class="empty-state__text">No workflows yet</p>
        </div>
      <% end %>
    </div>
  </div>

</div>
