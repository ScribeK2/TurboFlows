<div class="page-content">
  <!-- Header Section -->
  <div class="admin-page-header">
    <div class="admin-page-header__body">
      <div class="admin-page-header__title-row">
        <h1><%= @workflow.title %></h1>
        <% if @workflow.is_public? %>
          <span class="badge badge--published">Public</span>
        <% end %>
      </div>
      <p class="text-sm mb-2">
        by <%= @workflow.user.email %> &bull; Created <%= time_ago_in_words(@workflow.created_at) %> ago
      </p>
      <% if @workflow.description? %>
        <div class="prose prose-sm mt-3">
          <%= @workflow.description %>
        </div>
      <% end %>
    </div>
    <div class="admin-page-header__actions">
      <%= link_to admin_workflows_path, class: "btn btn--secondary" do %>
        <svg class="icon icon--sm" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
        </svg>
        Back to List
      <% end %>
      <%= link_to workflow_path(@workflow), class: "btn btn--primary" do %>
        Open Workflow
      <% end %>
    </div>
  </div>

  <!-- Workflow Steps Section -->
  <div class="card">
    <div class="card__header">
      <h2>Workflow Steps</h2>
    </div>
    <% if @workflow.steps.any? %>
      <div class="card__body">
        <% @workflow.steps.order(:position).each_with_index do |step, index| %>
          <div class="card mb-3">
            <div class="card__body">
              <div class="admin-step-layout">
                <span class="admin-step-number mr-3 flex-shrink-0">
                  <%= index + 1 %>
                </span>
                <div class="admin-step-layout__body">
                  <div class="admin-step-layout__title-row">
                    <h3 class="font-semibold"><%= step.title %></h3>
                    <span class="badge ml-3"><%= step.step_type %></span>
                  </div>
                  <% if step.is_a?(Steps::Question) && step.question.present? %>
                    <p class="text-sm mt-1">Q: <%= step.question %></p>
                  <% end %>
                  <% if step.is_a?(Steps::Action) && step.instructions.present? %>
                    <div class="mt-2 text-sm">
                      <strong>Instructions:</strong> <%= step.instructions %>
                    </div>
                  <% end %>
                </div>
              </div>
            </div>
          </div>
        <% end %>
      </div>
    <% else %>
      <div class="empty-state p-4">
        <p class="empty-state__text">No steps defined in this workflow.</p>
      </div>
    <% end %>
  </div>
</div>
