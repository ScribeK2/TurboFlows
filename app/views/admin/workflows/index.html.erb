<div class="page-content">
  <!-- Header Section -->
  <div class="mb-4 flex items-center justify-between">
    <div>
      <h1>All Workflows</h1>
      <p class="text-sm mt-1">View and manage all workflows across the system.</p>
    </div>
    <%= link_to admin_root_path, class: "btn btn--secondary flex items-center gap-2" do %>
      <%= icon "arrow-left", class: "icon icon--sm" %>
      Back to Dashboard
    <% end %>
  </div>

  <%= turbo_frame_tag "admin-workflows-list" do %>
    <% if @workflows.any? %>
      <div class="card">
        <% @workflows.each do |workflow| %>
          <div class="wf-list-item" id="<%= dom_id(workflow) %>">
            <div class="flex items-center flex-1 min-w-0">
              <div class="flex-shrink-0 mr-4">
                <%= workflow_list_icon(workflow) %>
              </div>
              <div class="wf-list-item__info flex-1 min-w-0">
                <div class="flex items-center gap-2 mb-1">
                  <%= link_to workflow.title, admin_workflow_path(workflow), class: "wf-list-item__title" %>
                  <% if workflow.is_public? %>
                    <span class="badge badge--published" title="Public workflow">Public</span>
                  <% end %>
                  <span class="text-xs">by <%= workflow.user.email %></span>
                </div>
                <div class="text-sm mb-1">
                  <%= truncate(workflow.description_text.presence || "No description", length: 100) %>
                </div>
                <div class="wf-list-item__meta">
                  <%= pluralize(workflow.steps.size, "step") %> &bull; Created <%= time_ago_in_words(workflow.created_at) %> ago
                </div>
              </div>
            </div>
            <div class="flex items-center gap-2 ml-4">
              <%= link_to admin_workflow_path(workflow), class: "btn btn--secondary btn--sm" do %>
                View
              <% end %>
              <%= link_to workflow_path(workflow), class: "btn btn--plain btn--sm" do %>
                Open
              <% end %>
              <%= link_to admin_workflow_path(workflow), data: { turbo_method: :delete, turbo_confirm: "Are you sure you want to delete '#{workflow.title}'? This cannot be undone." }, class: "btn btn--plain btn--sm wf-list-item__delete", title: "Delete workflow" do %>
                <%= icon "trash", class: "icon icon--sm" %>
              <% end %>
            </div>
          </div>
        <% end %>
      </div>

      <% if @total_pages > 1 %>
        <%= render "admin/workflows/pagination" %>
      <% end %>
    <% else %>
      <div class="empty-state">
        <%= icon "document-text", class: "empty-state__icon" %>
        <h3 class="empty-state__title">No workflows</h3>
        <p class="empty-state__text">No workflows found in the system.</p>
      </div>
    <% end %>
  <% end %>
</div>
