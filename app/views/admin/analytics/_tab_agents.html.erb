<div class="card">
  <div class="card__header">
    <h3>Agent Activity</h3>
  </div>
  <% if @agent_stats.any? %>
    <div class="table-wrap">
      <table class="table">
        <thead>
          <tr>
            <th>Agent</th>
            <th>Total Runs</th>
            <th>Completed</th>
            <th>Escalated</th>
            <th>Avg Duration</th>
            <th>Last Active</th>
          </tr>
        </thead>
        <tbody>
          <% @agent_stats.each do |row| %>
            <tr>
              <td class="font-medium">
                <%= row.user_display_name.presence || row.user_email %>
              </td>
              <td><%= number_with_delimiter(row.total_runs) %></td>
              <td><%= number_with_delimiter(row.completed_count) %></td>
              <td><%= number_with_delimiter(row.escalated_count) %></td>
              <td>
                <% avg = row.avg_duration.to_i %>
                <%= avg > 60 ? "#{avg / 60}m #{avg % 60}s" : "#{avg}s" %>
              </td>
              <td><%= row.last_active ? time_ago_in_words(row.last_active) + " ago" : "Never" %></td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  <% else %>
    <div class="empty-state p-4">
      <p class="empty-state__text">No agent data for this period</p>
      <p class="text-sm mt-1">Agent activity will appear as team members run scenarios.</p>
    </div>
  <% end %>
</div>
