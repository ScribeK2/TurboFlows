<div class="stat-grid mb-4">
  <%# Total Runs %>
  <div class="stat-card">
    <div class="flex items-center justify-between">
      <div>
        <p class="stat-card__value"><%= number_with_delimiter(@total_runs) %></p>
        <p class="stat-card__label">Total Runs</p>
      </div>
      <svg class="icon icon--xl" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6" />
      </svg>
    </div>
  </div>

  <%# Completion Rate %>
  <div class="stat-card">
    <div class="flex items-center justify-between">
      <div>
        <p class="stat-card__value"><%= @completion_rate %>%</p>
        <p class="stat-card__label">Completion Rate</p>
      </div>
      <svg class="icon icon--xl" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
      </svg>
    </div>
  </div>

  <%# Avg Duration %>
  <div class="stat-card">
    <div class="flex items-center justify-between">
      <div>
        <% minutes = @avg_duration / 60 %>
        <% seconds = @avg_duration % 60 %>
        <p class="stat-card__value">
          <%= minutes > 0 ? "#{minutes}m #{seconds}s" : "#{seconds}s" %>
        </p>
        <p class="stat-card__label">Avg Duration</p>
      </div>
      <svg class="icon icon--xl" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
      </svg>
    </div>
  </div>

  <%# Escalation Rate %>
  <div class="stat-card">
    <div class="flex items-center justify-between">
      <div>
        <p class="stat-card__value"><%= @escalation_rate %>%</p>
        <p class="stat-card__label">Escalation Rate</p>
      </div>
      <svg class="icon icon--xl" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z" />
      </svg>
    </div>
  </div>
</div>
