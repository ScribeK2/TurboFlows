<div class="flex flex-col gap-6">
  <%# Outcome Breakdown %>
  <div class="card">
    <div class="card__header">
      <h3>Outcome Breakdown</h3>
    </div>
    <% if @outcome_breakdown.any? %>
      <div class="table-wrap">
        <table class="table">
          <thead>
            <tr>
              <th>Outcome</th>
              <th>Count</th>
              <th>% of Total</th>
            </tr>
          </thead>
          <tbody>
            <% @outcome_breakdown.each do |outcome, count| %>
              <% pct = @total_runs > 0 ? (count.to_f / @total_runs * 100).round(1) : 0 %>
              <%
                badge_mod = case outcome
                  when "resolved" then "badge--resolve"
                  when "completed" then "badge--published"
                  when "escalated" then "badge--escalate"
                  when "error" then "badge--alert"
                  else ""
                end
                bar_class = case outcome
                  when "resolved" then "analytics-bar--resolved"
                  when "completed" then "analytics-bar--completed"
                  when "escalated" then "analytics-bar--escalated"
                  when "error" then "analytics-bar--error"
                  else "analytics-bar--default"
                end
              %>
              <tr>
                <td>
                  <span class="badge <%= badge_mod %>">
                    <%= outcome&.capitalize || "Unknown" %>
                  </span>
                </td>
                <td><%= number_with_delimiter(count) %></td>
                <td>
                  <div class="flex items-center gap-3">
                    <div class="analytics-bar-track">
                      <div class="analytics-bar <%= bar_class %>" style="width: <%= pct %>%"></div>
                    </div>
                    <span class="tabular-nums"><%= pct %>%</span>
                  </div>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    <% else %>
      <div class="empty-state p-4">
        <p class="empty-state__text">No scenario data for this period</p>
        <p class="text-sm mt-1">Run workflows to see outcome breakdowns here.</p>
      </div>
    <% end %>
  </div>

  <%# Runs Over Time %>
  <div class="card">
    <div class="card__header">
      <h3>Runs Over Time</h3>
    </div>
    <% if @runs_over_time.any? %>
      <% max_runs = @runs_over_time.values.max %>
      <div class="table-wrap">
        <table class="table">
          <thead>
            <tr>
              <th class="w-48">Period</th>
              <th>Runs</th>
            </tr>
          </thead>
          <tbody>
            <% @runs_over_time.sort.each do |period, count| %>
              <% bar_pct = max_runs > 0 ? (count.to_f / max_runs * 100).round : 0 %>
              <tr>
                <td>
                  <% date = period.is_a?(Date) ? period : Date.parse(period.to_s) %>
                  <%= @runs_grouped_by_week ? "Week of #{date.strftime("%b %-d, %Y")}" : date.strftime("%b %-d, %Y") %>
                </td>
                <td>
                  <div class="flex items-center gap-3">
                    <div class="analytics-bar-track">
                      <div class="analytics-bar analytics-bar--default" style="width: <%= bar_pct %>%"></div>
                    </div>
                    <span class="tabular-nums font-medium w-8 text-right"><%= number_with_delimiter(count) %></span>
                  </div>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    <% else %>
      <div class="empty-state p-4">
        <p class="empty-state__text">No scenario data for this period</p>
        <p class="text-sm mt-1">Activity trends will appear as scenarios are run.</p>
      </div>
    <% end %>
  </div>
</div>
