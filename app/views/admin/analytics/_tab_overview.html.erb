<div class="space-y-8">
  <%# Outcome Breakdown %>
  <div class="solid-card overflow-hidden">
    <div class="px-6 py-5 border-b border-slate-200 dark:border-slate-700">
      <h3 class="text-xl font-bold text-gray-900 dark:text-gray-100 tracking-tight">Outcome Breakdown</h3>
    </div>
    <% if @outcome_breakdown.any? %>
      <div class="overflow-x-auto">
        <table class="min-w-full divide-y divide-slate-200 dark:divide-slate-700">
          <thead class="bg-slate-50 dark:bg-slate-800/50">
            <tr>
              <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider">Outcome</th>
              <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider">Count</th>
              <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider">% of Total</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-slate-200 dark:divide-slate-700">
            <% @outcome_breakdown.each do |outcome, count| %>
              <tr class="even:bg-slate-50 dark:even:bg-slate-800/50">
                <td class="px-6 py-4 whitespace-nowrap">
                  <%
                    badge_class = case outcome
                      when "resolved" then "bg-emerald-100 text-emerald-700 dark:bg-emerald-900/30 dark:text-emerald-400"
                      when "completed" then "bg-blue-100 text-blue-700 dark:bg-blue-900/30 dark:text-blue-400"
                      when "escalated" then "bg-amber-100 text-amber-700 dark:bg-amber-900/30 dark:text-amber-400"
                      when "error" then "bg-red-100 text-red-700 dark:bg-red-900/30 dark:text-red-400"
                      else "bg-slate-100 text-slate-600 dark:bg-slate-700 dark:text-slate-400"
                    end
                  %>
                  <span class="inline-flex px-2.5 py-0.5 text-xs font-medium rounded-full <%= badge_class %>">
                    <%= outcome&.capitalize || "Unknown" %>
                  </span>
                </td>
                <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900 dark:text-gray-100"><%= number_with_delimiter(count) %></td>
                <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500 dark:text-gray-400">
                  <%= @total_runs > 0 ? "#{(count.to_f / @total_runs * 100).round(1)}%" : "0%" %>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    <% else %>
      <div class="px-6 py-12 text-center">
        <p class="text-gray-500 dark:text-gray-400">No scenario data for this period.</p>
      </div>
    <% end %>
  </div>

  <%# Runs Over Time %>
  <div class="solid-card overflow-hidden">
    <div class="px-6 py-5 border-b border-slate-200 dark:border-slate-700">
      <h3 class="text-xl font-bold text-gray-900 dark:text-gray-100 tracking-tight">Runs Over Time</h3>
    </div>
    <% if @runs_over_time.any? %>
      <div class="overflow-x-auto">
        <table class="min-w-full divide-y divide-slate-200 dark:divide-slate-700">
          <thead class="bg-slate-50 dark:bg-slate-800/50">
            <tr>
              <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider">Period</th>
              <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider">Runs</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-slate-200 dark:divide-slate-700">
            <% @runs_over_time.sort.each do |period, count| %>
              <tr class="even:bg-slate-50 dark:even:bg-slate-800/50">
                <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900 dark:text-gray-100">
                  <% if @runs_grouped_by_week %>
                    <% year, week = period.split("-").map(&:to_i) %>
                    Week of <%= Date.commercial(year, [week, 1].max, 1).strftime("%b %-d, %Y") %>
                  <% else %>
                    <%= Date.parse(period).strftime("%b %-d, %Y") %>
                  <% end %>
                </td>
                <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900 dark:text-gray-100"><%= number_with_delimiter(count) %></td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    <% else %>
      <div class="px-6 py-12 text-center">
        <p class="text-gray-500 dark:text-gray-400">No scenario data for this period.</p>
      </div>
    <% end %>
  </div>
</div>
