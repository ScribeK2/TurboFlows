<div class="page-content">
  <%# Header %>
  <div class="mb-4 flex items-center justify-between">
    <div>
      <h1>Analytics</h1>
      <p class="text-sm mt-1">Workflow usage, agent performance, and operational insights.</p>
    </div>
    <div class="flex items-center gap-3">
      <%= link_to admin_analytics_path(format: :csv, **request.query_parameters), class: "btn btn--secondary flex items-center gap-2" do %>
        <%= icon "document-arrow-down", class: "icon icon--sm" %>
        Export CSV
      <% end %>
      <%= link_to admin_root_path, class: "btn btn--secondary flex items-center gap-2" do %>
        <%= icon "arrow-left", class: "icon icon--sm" %>
        Back to Dashboard
      <% end %>
    </div>
  </div>

  <%# Filters %>
  <%= render "filters" %>

  <%# Stat Cards %>
  <%= render "stat_cards" %>

  <%# Tabs %>
  <% active_tab = (params[:tab] || "0").to_i %>
  <div class="mt-6" data-controller="tabs" data-tabs-active-value="<%= active_tab %>">
    <div class="wf-status-tabs mb-4">
      <% %w[Overview Workflows Agents Operations Step\ Performance].each_with_index do |label, i| %>
        <% is_active = i == active_tab %>
        <button data-tabs-target="tab" data-action="click->tabs#switch"
                class="wf-status-tabs__tab <%= 'wf-status-tabs__tab--active' if is_active %>"
                aria-selected="<%= is_active %>">
          <%= label %>
        </button>
      <% end %>
    </div>

    <%# Tab Panels %>
    <div data-tabs-target="panel" class="<%= 'is-hidden' unless active_tab == 0 %>">
      <%= render "tab_overview" %>
    </div>
    <div data-tabs-target="panel" class="<%= 'is-hidden' unless active_tab == 1 %>">
      <%= render "tab_workflows" %>
    </div>
    <div data-tabs-target="panel" class="<%= 'is-hidden' unless active_tab == 2 %>">
      <%= render "tab_agents" %>
    </div>
    <div data-tabs-target="panel" class="<%= 'is-hidden' unless active_tab == 3 %>">
      <%= render "tab_operations" %>
    </div>
    <div data-tabs-target="panel" class="<%= 'is-hidden' unless active_tab == 4 %>">
      <%= render "tab_step_performance" %>
    </div>
  </div>
</div>
