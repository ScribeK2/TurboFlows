<%= form_tag admin_analytics_path, method: :get, class: "solid-card px-6 py-4 mb-6 animate-fade-in-up", data: { turbo_frame: "_top" } do %>
  <div class="flex flex-wrap items-end gap-4">
    <%# Date Range %>
    <div>
      <label class="block text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider mb-2">Date Range</label>
      <div class="inline-flex rounded-lg overflow-hidden border border-slate-200 dark:border-slate-700">
        <% %w[7d 30d 90d all].each do |range| %>
          <% active = (params[:range] || "30d") == range %>
          <button type="submit" name="range" value="<%= range %>"
                  class="px-3 py-1.5 text-sm font-medium transition-colors duration-150
                         <%= active ? 'bg-slate-700 text-white dark:bg-slate-500' : 'bg-white dark:bg-slate-800 text-gray-600 dark:text-gray-400 hover:bg-slate-50 dark:hover:bg-slate-700' %>">
            <%= range == "all" ? "All" : range %>
          </button>
        <% end %>
      </div>
    </div>

    <%# Purpose %>
    <div>
      <label class="block text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider mb-2">Purpose</label>
      <div class="inline-flex rounded-lg overflow-hidden border border-slate-200 dark:border-slate-700">
        <% %w[all simulation live].each do |purpose| %>
          <% active = (params[:purpose] || "all") == purpose %>
          <button type="submit" name="purpose" value="<%= purpose %>"
                  class="px-3 py-1.5 text-sm font-medium transition-colors duration-150
                         <%= active ? 'bg-slate-700 text-white dark:bg-slate-500' : 'bg-white dark:bg-slate-800 text-gray-600 dark:text-gray-400 hover:bg-slate-50 dark:hover:bg-slate-700' %>">
            <%= purpose.capitalize %>
          </button>
        <% end %>
      </div>
    </div>

    <%# Workflow %>
    <div>
      <label class="block text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider mb-2">Workflow</label>
      <%= select_tag :workflow_id,
            options_from_collection_for_select(@workflows_for_filter, :id, :title, params[:workflow_id]&.to_i),
            include_blank: "All Workflows",
            class: "rounded-lg border-slate-200 dark:border-slate-700 bg-white dark:bg-slate-800 text-sm text-gray-700 dark:text-gray-300 focus:ring-slate-500 focus:border-slate-500",
            onchange: "this.form.requestSubmit()" %>
    </div>

    <%# User %>
    <div>
      <label class="block text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider mb-2">Agent</label>
      <%= select_tag :user_id,
            options_from_collection_for_select(@users_for_filter, :id, :email, params[:user_id]&.to_i),
            include_blank: "All Agents",
            class: "rounded-lg border-slate-200 dark:border-slate-700 bg-white dark:bg-slate-800 text-sm text-gray-700 dark:text-gray-300 focus:ring-slate-500 focus:border-slate-500",
            onchange: "this.form.requestSubmit()" %>
    </div>

    <%# Group %>
    <div>
      <label class="block text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider mb-2">Group</label>
      <%= select_tag :group_id,
            options_from_collection_for_select(@groups_for_filter, :id, :name, params[:group_id]&.to_i),
            include_blank: "All Groups",
            class: "rounded-lg border-slate-200 dark:border-slate-700 bg-white dark:bg-slate-800 text-sm text-gray-700 dark:text-gray-300 focus:ring-slate-500 focus:border-slate-500",
            onchange: "this.form.requestSubmit()" %>
    </div>

    <%# Hidden fields to preserve other filter params %>
    <%= hidden_field_tag :range, params[:range] || "30d" %>
    <%= hidden_field_tag :purpose, params[:purpose] || "all" %>
  </div>
<% end %>
