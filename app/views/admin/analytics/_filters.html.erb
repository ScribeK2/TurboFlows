<%= form_tag admin_analytics_path, method: :get, class: "card card__body mb-4", data: { controller: "analytics-filters" } do %>
  <div class="flex flex-wrap items-end gap-4">
    <%# Date Range %>
    <div>
      <label class="form-label text-xs uppercase tracking-wider mb-2">Date Range</label>
      <div class="inline-flex rounded border overflow-hidden">
        <% current_range = params[:range] || "30d" %>
        <% %w[7d 30d 90d all].each do |range| %>
          <% active = current_range == range %>
          <button type="button"
                  class="btn btn--sm <%= active ? 'btn--primary' : 'btn--plain' %>"
                  data-action="click->analytics-filters#selectRange"
                  data-value="<%= range %>">
            <%= range == "all" ? "All" : range %>
          </button>
        <% end %>
      </div>
    </div>

    <%# Purpose %>
    <div>
      <label class="form-label text-xs uppercase tracking-wider mb-2">Purpose</label>
      <div class="inline-flex rounded border overflow-hidden">
        <% current_purpose = params[:purpose] || "all" %>
        <% %w[all simulation live].each do |purpose| %>
          <% active = current_purpose == purpose %>
          <button type="button"
                  class="btn btn--sm <%= active ? 'btn--primary' : 'btn--plain' %>"
                  data-action="click->analytics-filters#selectPurpose"
                  data-value="<%= purpose %>">
            <%= purpose.capitalize %>
          </button>
        <% end %>
      </div>
    </div>

    <%# Workflow %>
    <div>
      <label class="form-label text-xs uppercase tracking-wider mb-2">Workflow</label>
      <%= select_tag :workflow_id,
            options_from_collection_for_select(@workflows_for_filter, :id, :title, params[:workflow_id]&.to_i),
            include_blank: "All Workflows",
            class: "form-select",
            onchange: "this.form.requestSubmit()" %>
    </div>

    <%# User %>
    <div>
      <label class="form-label text-xs uppercase tracking-wider mb-2">Agent</label>
      <%= select_tag :user_id,
            options_from_collection_for_select(@users_for_filter, :id, :email, params[:user_id]&.to_i),
            include_blank: "All Agents",
            class: "form-select",
            onchange: "this.form.requestSubmit()" %>
    </div>

    <%# Group %>
    <div>
      <label class="form-label text-xs uppercase tracking-wider mb-2">Group</label>
      <%= select_tag :group_id,
            options_from_collection_for_select(@groups_for_filter, :id, :name, params[:group_id]&.to_i),
            include_blank: "All Groups",
            class: "form-select",
            onchange: "this.form.requestSubmit()" %>
    </div>

    <%# Hidden fields for filter state %>
    <%= hidden_field_tag :range, current_range, data: { analytics_filters_target: "rangeField" } %>
    <%= hidden_field_tag :purpose, current_purpose, data: { analytics_filters_target: "purposeField" } %>
    <%= hidden_field_tag :tab, params[:tab] || "0", data: { analytics_filters_target: "tabField" } %>
  </div>
<% end %>
