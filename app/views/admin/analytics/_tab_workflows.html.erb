<div class="card">
  <div class="card__header">
    <h3>Workflow Usage</h3>
  </div>
  <% if @workflow_stats.any? %>
    <div class="table-wrap">
      <table class="table">
        <thead>
          <tr>
            <th>Workflow</th>
            <th>Total Runs</th>
            <th>Completion Rate</th>
            <th>Avg Duration</th>
            <th>Escalation Rate</th>
            <th>Last Run</th>
          </tr>
        </thead>
        <tbody>
          <% @workflow_stats.each do |row| %>
            <% total = row.total_runs.to_i %>
            <tr>
              <td class="font-medium">
                <%= link_to row.workflow_title, workflow_path(row.workflow_id) %>
              </td>
              <td><%= number_with_delimiter(total) %></td>
              <td><%= total > 0 ? "#{(row.completed_count.to_f / total * 100).round(1)}%" : "0%" %></td>
              <td>
                <% avg = row.avg_duration.to_i %>
                <%= avg > 60 ? "#{avg / 60}m #{avg % 60}s" : "#{avg}s" %>
              </td>
              <td><%= total > 0 ? "#{(row.escalated_count.to_f / total * 100).round(1)}%" : "0%" %></td>
              <td><%= row.last_run ? time_ago_in_words(row.last_run) + " ago" : "Never" %></td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  <% else %>
    <div class="empty-state p-4">
      <p class="empty-state__text">No workflow data for this period</p>
      <p class="text-sm mt-1">Workflow usage stats appear after scenarios are run.</p>
    </div>
  <% end %>
</div>
