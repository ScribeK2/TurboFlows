<div class="solid-card overflow-hidden">
  <div class="px-6 py-5 border-b border-slate-200 dark:border-slate-700">
    <h3 class="text-xl font-bold text-gray-900 dark:text-gray-100 tracking-tight">Workflow Usage</h3>
  </div>
  <% if @workflow_stats.any? %>
    <div class="overflow-x-auto">
      <table class="min-w-full divide-y divide-slate-200 dark:divide-slate-700">
        <thead class="bg-slate-50 dark:bg-slate-800/50">
          <tr>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider">Workflow</th>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider">Total Runs</th>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider">Completion Rate</th>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider">Avg Duration</th>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider">Escalation Rate</th>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider">Last Run</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-slate-200 dark:divide-slate-700">
          <% @workflow_stats.each do |row| %>
            <% total = row.total_runs.to_i %>
            <tr class="even:bg-slate-50 dark:even:bg-slate-800/50">
              <td class="px-6 py-4 whitespace-nowrap text-sm font-medium text-gray-900 dark:text-gray-100">
                <%= link_to row.workflow_title, workflow_path(row.workflow_id), class: "hover:text-slate-600 dark:hover:text-slate-400 transition-colors duration-200" %>
              </td>
              <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900 dark:text-gray-100"><%= number_with_delimiter(total) %></td>
              <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900 dark:text-gray-100">
                <%= total > 0 ? "#{(row.completed_count.to_f / total * 100).round(1)}%" : "0%" %>
              </td>
              <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500 dark:text-gray-400">
                <% avg = row.avg_duration.to_i %>
                <%= avg > 60 ? "#{avg / 60}m #{avg % 60}s" : "#{avg}s" %>
              </td>
              <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900 dark:text-gray-100">
                <%= total > 0 ? "#{(row.escalated_count.to_f / total * 100).round(1)}%" : "0%" %>
              </td>
              <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500 dark:text-gray-400">
                <%= row.last_run ? time_ago_in_words(row.last_run) + " ago" : "Never" %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  <% else %>
    <div class="px-6 py-12 text-center">
      <p class="text-gray-500 dark:text-gray-400">No workflow data for this period.</p>
    </div>
  <% end %>
</div>
