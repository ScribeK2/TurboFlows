<div class="flex flex-col gap-6">
  <%# Drop-off Points %>
  <div class="card">
    <div class="card__header">
      <div>
        <h3>Drop-off Points</h3>
        <p class="text-sm mt-1">Steps where scenarios were abandoned most frequently.</p>
      </div>
    </div>
    <% if @dropoff_points.any? %>
      <div class="table-wrap">
        <table class="table">
          <thead>
            <tr>
              <th>Step</th>
              <th>Workflow</th>
              <th>Abandon Count</th>
            </tr>
          </thead>
          <tbody>
            <% @dropoff_points.each do |point| %>
              <tr>
                <td class="font-medium"><%= point[:step_title] %></td>
                <td>
                  <%= link_to point[:workflow_title], workflow_path(point[:workflow_id]) %>
                </td>
                <td><%= number_with_delimiter(point[:count]) %></td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    <% else %>
      <div class="empty-state p-4">
        <p class="empty-state__text">No drop-off data for this period</p>
        <p class="text-sm mt-1">Abandoned scenarios will show which steps agents leave most often.</p>
      </div>
    <% end %>
  </div>

  <%# Busiest Hours %>
  <div class="card">
    <div class="card__header flex items-center justify-between">
      <div>
        <h3>Busiest Hours</h3>
        <p class="text-sm mt-1">Scenario runs grouped by hour of day.</p>
      </div>
      <span class="badge">
        Times in <%= Time.zone.name %>
      </span>
    </div>
    <% if @busiest_hours.any? %>
      <% max_count = @busiest_hours.map { |_, c| c }.max %>
      <div class="table-wrap">
        <table class="table">
          <thead>
            <tr>
              <th class="w-48">Hour</th>
              <th>Run Count</th>
            </tr>
          </thead>
          <tbody>
            <% @busiest_hours.each do |hour, count| %>
              <% bar_pct = max_count > 0 ? (count.to_f / max_count * 100).round : 0 %>
              <tr>
                <td class="font-medium">
                  <%= "#{hour.to_i.to_s.rjust(2, '0')}:00 - #{hour.to_i.to_s.rjust(2, '0')}:59" %>
                </td>
                <td>
                  <div class="flex items-center gap-3">
                    <div class="analytics-bar-track">
                      <div class="analytics-bar <%= bar_pct >= 80 ? 'analytics-bar--resolved' : bar_pct >= 40 ? 'analytics-bar--default' : 'analytics-bar--muted' %>"
                           style="width: <%= bar_pct %>%"></div>
                    </div>
                    <span class="tabular-nums font-medium w-8 text-right"><%= number_with_delimiter(count) %></span>
                  </div>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    <% else %>
      <div class="empty-state p-4">
        <p class="empty-state__text">No hourly data for this period</p>
        <p class="text-sm mt-1">Run scenarios to see peak activity hours.</p>
      </div>
    <% end %>
  </div>
</div>
