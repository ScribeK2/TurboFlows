<div class="group-checkbox-item py-1" style="padding-left: <%= level * 1.5 %>rem;">
  <label class="flex items-start cursor-pointer group-tree__node">
    <input type="checkbox"
           name="group_ids[]"
           value="<%= group.id %>"
           <%= 'checked' if user && user.groups.include?(group) %>
           class="form-checkbox mt-0.5">
    <div class="ml-2 flex-1 min-w-0">
      <div class="flex items-center gap-2">
        <% if level > 0 %>
          <svg class="icon icon--xs flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
          </svg>
        <% end %>
        <span class="text-sm font-semibold">
          <%= group.name %>
        </span>
      </div>
      <% if group.description.present? %>
        <p class="mt-0.5 text-xs truncate">
          <%= truncate(group.description, length: 60) %>
        </p>
      <% end %>
    </div>
  </label>

  <% if group.children.any? %>
    <div class="group-tree__indent">
      <% group.children.order(:position, :name).each do |child| %>
        <%= render partial: "admin/users/group_checkbox", locals: { group: child, user: user, level: level + 1 } %>
      <% end %>
    </div>
  <% end %>
</div>
