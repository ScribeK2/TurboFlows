<div class="page-content" data-controller="admin-users" data-admin-users-total-count-value="<%= @total_count %>">
  <!-- Header Section -->
  <div class="mb-4 flex items-center justify-between">
    <div>
      <h1>User Management</h1>
      <p class="text-sm mt-1">
        Manage user roles, permissions, and group assignments across the system.
      </p>
    </div>
    <%= link_to admin_root_path, class: "btn btn--secondary flex items-center gap-2" do %>
      <svg class="icon icon--sm" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
      </svg>
      Back to Dashboard
    <% end %>
  </div>

  <!-- Users Table -->
  <div class="card">
    <turbo-frame id="users-table" data-turbo-action="advance">
      <div class="card__header flex items-center justify-between">
        <h2>All Users</h2>
        <button type="button"
                data-admin-users-target="bulkToggleBtn"
                data-action="click->admin-users#toggleBulk"
                class="btn btn--secondary btn--sm flex items-center gap-2">
          <svg class="icon icon--sm" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z" />
          </svg>
          Bulk Assign Groups
        </button>
      </div>

      <%= render "filter_toolbar" %>

      <% if @users.any? %>
        <div class="table-wrap">
          <table class="table">
            <thead>
              <tr>
                <th class="bulk-select-column" style="display: none;">
                  <input type="checkbox" data-admin-users-target="selectAll" data-action="change->admin-users#toggleAll" class="form-checkbox">
                </th>
                <th>Email</th>
                <th>Role</th>
                <th>Groups</th>
                <th>Workflows</th>
                <th>Joined</th>
                <th>Actions</th>
              </tr>
            </thead>
            <tbody>
              <% @users.each do |user| %>
                <tr class="<%= 'admin-user-row--deactivated' if user.access_locked? %>">
                  <td class="bulk-select-column" style="display: none;">
                    <input type="checkbox" name="user_ids[]" value="<%= user.id %>" data-admin-users-target="userCheckbox" data-action="change->admin-users#updateSelectedCount" class="form-checkbox">
                  </td>
                  <td>
                    <span class="font-medium"><%= user.email %></span>
                    <% if user.access_locked? %><span class="badge badge--muted ml-1">Deactivated</span><% end %>
                  </td>
                  <td>
                    <span class="badge <%= user.avatar_role_badge_classes %>">
                      <%= user.role.capitalize %>
                    </span>
                  </td>
                  <td>
                    <div class="flex flex-wrap gap-1">
                      <% if user.groups.any? %>
                        <% user.groups.each do |group| %>
                          <span class="badge" title="<%= group.full_path %>">
                            <%= group.name %>
                          </span>
                        <% end %>
                      <% else %>
                        <span class="text-xs">None</span>
                      <% end %>
                    </div>
                  </td>
                  <td class="text-sm">
                    <%= user.workflows.size %>
                  </td>
                  <td class="text-sm">
                    <%= time_ago_in_words(user.created_at) %> ago
                  </td>
                  <td>
                    <div class="flex items-center gap-2">
                      <%= form_with url: update_role_admin_user_path(user), method: :patch, data: { turbo: false, controller: "auto-submit" }, class: "inline-flex items-center" do |form| %>
                        <%= form.select :role, options_for_select(User.roles.map { |key, _| [key.capitalize, key] }, user.role), {}, { class: "form-select", data: { action: "change->auto-submit#submit" } } %>
                      <% end %>
                      <button type="button"
                              class="btn btn--secondary btn--sm flex items-center gap-1"
                              data-action="click->admin-users#openGroupModal"
                              data-modal-id="group-modal-<%= user.id %>"
                              title="Assign groups">
                        <svg class="icon icon--xs" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 7v10a2 2 0 002 2h14a2 2 0 002-2V9a2 2 0 00-2-2h-6l-2-2H5a2 2 0 00-2 2z" />
                        </svg>
                        Groups
                      </button>
                      <button type="button"
                              class="btn btn--sm flex items-center gap-1"
                              data-action="click->admin-users#resetPassword"
                              data-user-id="<%= user.id %>"
                              data-user-email="<%= user.email %>"
                              title="Generate temporary password">
                        <svg class="icon icon--xs" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 7a2 2 0 012 2m4 0a6 6 0 01-7.743 5.743L11 17H9v2H7v2H4a1 1 0 01-1-1v-2.586a1 1 0 01.293-.707l5.964-5.964A6 6 0 1121 9z" />
                        </svg>
                        Reset
                      </button>
                    </div>
                  </td>
                </tr>
              <% end %>
            </tbody>
          </table>
        </div>

        <%= render "pagination" if @total_count > 0 %>
      <% else %>
        <div class="empty-state p-4">
          <p class="empty-state__text">No users found</p>
        </div>
      <% end %>
    </turbo-frame>
  </div>

<%# Group Assignment Modals %>
<% @users.each do |user| %>
  <div id="group-modal-<%= user.id %>"
       class="dialog-overlay is-hidden"
       data-controller="modal">
    <div class="dialog"
         data-modal-target="content"
         data-action="click->modal#stop">
      <%= form_with url: update_groups_admin_user_path(user), method: :patch, local: true do |form| %>
        <div class="dialog__header">
          <div>
            <h3 class="dialog__title">Assign Groups</h3>
            <p class="text-sm font-medium mt-1"><%= user.email %></p>
          </div>
          <button type="button"
                  class="dialog__close"
                  data-action="click->admin-users#closeGroupModal"
                  data-modal-id="group-modal-<%= user.id %>">
            <span class="sr-only">Close</span>
            <svg class="icon" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
            </svg>
          </button>
        </div>

        <div class="dialog__body">
          <p class="text-sm mb-3">
            Select groups to grant this user access to. Users will only see workflows in their assigned groups (unless they are admins).
          </p>

          <div class="admin-group-list">
            <% if @all_groups.any? %>
              <% @all_groups.roots.includes(:children).order(:position, :name).each do |root_group| %>
                <%= render partial: "admin/users/group_checkbox", locals: { group: root_group, user: user, level: 0 } %>
              <% end %>
            <% else %>
              <div class="empty-state p-4 text-center">
                <svg class="icon icon--xl mx-auto mb-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 7v10a2 2 0 002 2h14a2 2 0 002-2V9a2 2 0 00-2-2h-6l-2-2H5a2 2 0 00-2 2z" />
                </svg>
                <p class="text-sm">No groups available. Create groups first.</p>
              </div>
            <% end %>
          </div>
        </div>

        <div class="dialog__footer">
          <button type="button"
                  class="btn btn--plain"
                  data-action="click->admin-users#closeGroupModal"
                  data-modal-id="group-modal-<%= user.id %>">
            Cancel
          </button>
          <%= form.submit "Save Groups", class: "btn btn--primary" %>
        </div>
      <% end %>
    </div>
  </div>
<% end %>

<%# Bulk Group Assignment Modal %>
<div data-admin-users-target="bulkModal"
     class="dialog-overlay is-hidden"
     data-controller="modal">
  <div class="dialog"
       data-modal-target="content"
       data-action="click->modal#stop">
    <%= form_with url: bulk_assign_groups_admin_users_path, method: :patch, local: true, data: { admin_users_target: "bulkForm" } do |form| %>
      <div class="dialog__header">
        <h3 class="dialog__title">Bulk Assign Groups</h3>
        <button type="button"
                class="dialog__close"
                data-action="click->admin-users#closeBulkModal">
          <span class="sr-only">Close</span>
          <svg class="icon" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
          </svg>
        </button>
      </div>

      <div class="dialog__body">
        <p class="text-sm mb-3">
          Select groups to assign to the selected users. This will replace their existing group assignments.
        </p>

        <div data-admin-users-target="selectedCount" class="text-sm font-medium mb-3">
          No users selected
        </div>

        <div class="admin-group-list">
          <% if @all_groups.any? %>
            <% @all_groups.roots.includes(:children).order(:position, :name).each do |root_group| %>
              <%= render partial: "admin/users/group_checkbox", locals: { group: root_group, user: nil, level: 0 } %>
            <% end %>
          <% else %>
            <div class="empty-state p-4 text-center">
              <svg class="icon icon--xl mx-auto mb-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 7v10a2 2 0 002 2h14a2 2 0 002-2V9a2 2 0 00-2-2h-6l-2-2H5a2 2 0 00-2 2z" />
              </svg>
              <p class="text-sm">No groups available. Create groups first.</p>
            </div>
          <% end %>
        </div>
      </div>

      <div class="dialog__footer">
        <button type="button"
                class="btn btn--plain"
                data-action="click->admin-users#closeBulkModal">
          Cancel
        </button>
        <%= form.submit "Assign to Selected Users", class: "btn btn--primary" %>
      </div>
    <% end %>
  </div>
</div>

<%# Password Reset Modal %>
<div data-admin-users-target="resetModal"
     class="dialog-overlay is-hidden"
     data-controller="modal">
  <div class="dialog"
       data-modal-target="content"
       data-action="click->modal#stop">
    <div class="dialog__header">
      <div>
        <h3 class="dialog__title">Password Reset</h3>
        <p class="text-sm font-medium mt-1" data-admin-users-target="resetEmail"></p>
      </div>
      <button type="button"
              data-action="click->admin-users#closeResetModal"
              class="dialog__close">
        <span class="sr-only">Close</span>
        <svg class="icon" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
        </svg>
      </button>
    </div>

    <div class="dialog__body">
      <div class="admin-info-box admin-info-box--info mb-3">
        <div class="flex items-start gap-3">
          <svg class="icon icon--sm flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
          </svg>
          <div class="text-sm">
            <p class="font-semibold mb-1">New Temporary Password Generated</p>
            <p data-admin-users-target="tempPasswordDisplay" class="font-mono text-lg mt-2 font-bold">
              Loading...
            </p>
            <p class="mt-2 text-xs">
              Copy this password and give it to the user. They should change it immediately after logging in.
            </p>
          </div>
        </div>
      </div>

      <div class="admin-info-box admin-info-box--warning">
        <div class="flex items-start gap-3">
          <svg class="icon icon--sm flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-2.5L13.732 4c-.77-.833-1.964-.833-2.732 0L4.082 15.5c-.77.833.192 2.5 1.732 2.5z" />
          </svg>
          <div class="text-sm">
            <p class="font-semibold mb-1">Important Security Note</p>
            <ul class="list-disc list-inside text-xs">
              <li>This is a one-time temporary password</li>
              <li>User should change it immediately after first login</li>
              <li>The password is secure and randomly generated</li>
              <li>This action has been logged for security purposes</li>
            </ul>
          </div>
        </div>
      </div>
    </div>

    <div class="dialog__footer">
      <button type="button"
              data-action="click->admin-users#copyPassword"
              class="btn btn--plain flex items-center gap-2">
        <svg class="icon icon--sm" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 5H6a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2v-1M8 5a2 2 0 002 2h2a2 2 0 002-2M8 5a2 2 0 012-2h2a2 2 0 012 2m0 0h2a2 2 0 012 2v3m2 4H10m0 0l3-3m-3 3l3 3" />
        </svg>
        Copy Password
      </button>
      <button type="button"
              data-action="click->admin-users#closeResetModal"
              class="btn btn--positive flex items-center gap-2">
        <svg class="icon icon--sm" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
        </svg>
        Done
      </button>
    </div>
  </div>
</div>

<%# Bulk Action Bar (sticky bottom) %>
<div class="admin-bulk-bar is-hidden" data-admin-users-target="bulkBar">
  <span data-admin-users-target="bulkCount">0 users selected</span>
  <div class="admin-bulk-bar__actions">
    <button type="button" class="admin-bulk-bar__btn" data-action="click->admin-users#openBulkModal">
      Assign Groups
    </button>
    <button type="button" class="admin-bulk-bar__btn" data-action="click->admin-users#openRoleModal">
      Change Role
    </button>
    <button type="button" class="admin-bulk-bar__btn admin-bulk-bar__btn--danger" data-action="click->admin-users#bulkDeactivate">
      Deactivate
    </button>
  </div>
</div>

<%# Bulk Role Change Modal %>
<div data-admin-users-target="roleModal" class="dialog-overlay is-hidden" data-controller="modal">
  <div class="dialog" data-modal-target="content" data-action="click->modal#stop">
    <%= form_with url: bulk_update_role_admin_users_path, method: :patch, local: true, data: { admin_users_target: "roleForm" } do |form| %>
      <div class="dialog__header">
        <h3 class="dialog__title">Change Role</h3>
        <button type="button" class="dialog__close" data-action="click->admin-users#closeRoleModal">
          <span class="sr-only">Close</span>
          <svg class="icon" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
          </svg>
        </button>
      </div>
      <div class="dialog__body">
        <p class="text-sm mb-3">Select the new role for the selected users:</p>
        <%= form.select :role, options_for_select([["Admin", "admin"], ["Editor", "editor"], ["Regular", "user"]]), {}, { class: "form-select" } %>
      </div>
      <div class="dialog__footer">
        <button type="button" class="btn btn--plain" data-action="click->admin-users#closeRoleModal">Cancel</button>
        <%= form.submit "Update Role", class: "btn btn--primary" %>
      </div>
    <% end %>
  </div>
</div>

<%# Bulk Deactivate Form (hidden) %>
<%= form_with url: bulk_deactivate_admin_users_path, method: :patch, local: true, data: { admin_users_target: "deactivateForm" }, style: "display:none" do |form| %>
<% end %>

</div>
