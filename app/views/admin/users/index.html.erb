<div class="page-content">
  <!-- Header Section -->
  <div class="mb-4 flex items-center justify-between">
    <div>
      <h1>User Management</h1>
      <p class="text-sm mt-1">
        Manage user roles, permissions, and group assignments across the system.
      </p>
    </div>
    <%= link_to admin_root_path, class: "btn btn--secondary flex items-center gap-2" do %>
      <svg class="icon icon--sm" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
      </svg>
      Back to Dashboard
    <% end %>
  </div>

  <!-- Users Table -->
  <div class="card">
    <div class="card__header flex items-center justify-between">
      <h2>All Users</h2>
      <button type="button"
              id="bulk-toggle-btn"
              class="btn btn--secondary btn--sm flex items-center gap-2">
        <svg class="icon icon--sm" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z" />
        </svg>
        Bulk Assign Groups
      </button>
    </div>
    <% if @users.any? %>
      <div class="table-wrap">
        <table class="table">
          <thead>
            <tr>
              <th class="bulk-select-column" style="display: none;">
                <input type="checkbox" id="select-all-users" class="form-checkbox">
              </th>
              <th>Email</th>
              <th>Role</th>
              <th>Groups</th>
              <th>Workflows</th>
              <th>Joined</th>
              <th>Actions</th>
            </tr>
          </thead>
          <tbody>
            <% @users.each do |user| %>
              <tr>
                <td class="bulk-select-column" style="display: none;">
                  <input type="checkbox" name="user_ids[]" value="<%= user.id %>" class="user-checkbox form-checkbox">
                </td>
                <td>
                  <span class="font-medium"><%= user.email %></span>
                </td>
                <td>
                  <span class="badge <%= user.avatar_role_badge_classes %>">
                    <%= user.role.capitalize %>
                  </span>
                </td>
                <td>
                  <div class="flex flex-wrap gap-1">
                    <% if user.groups.any? %>
                      <% user.groups.each do |group| %>
                        <span class="badge" title="<%= group.full_path %>">
                          <%= group.name %>
                        </span>
                      <% end %>
                    <% else %>
                      <span class="text-xs">None</span>
                    <% end %>
                  </div>
                </td>
                <td class="text-sm">
                  <%= user.workflows.size %>
                </td>
                <td class="text-sm">
                  <%= time_ago_in_words(user.created_at) %> ago
                </td>
                <td>
                  <div class="flex items-center gap-2">
                    <%= form_with url: update_role_admin_user_path(user), method: :patch, data: { turbo: false, controller: "auto-submit" }, class: "inline-flex items-center" do |form| %>
                      <%= form.select :role, options_for_select(User.roles.map { |key, _| [key.capitalize, key] }, user.role), {}, { class: "form-select", data: { action: "change->auto-submit#submit" } } %>
                    <% end %>
                    <button type="button"
                            class="open-group-modal-btn btn btn--secondary btn--sm flex items-center gap-1"
                            data-modal-id="group-modal-<%= user.id %>"
                            title="Assign groups">
                      <svg class="icon icon--xs" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 7v10a2 2 0 002 2h14a2 2 0 002-2V9a2 2 0 00-2-2h-6l-2-2H5a2 2 0 00-2 2z" />
                      </svg>
                      Groups
                    </button>
                    <button type="button"
                            class="reset-password-btn btn btn--sm flex items-center gap-1"
                            data-user-id="<%= user.id %>"
                            data-user-email="<%= user.email %>"
                            title="Generate temporary password">
                      <svg class="icon icon--xs" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 7a2 2 0 012 2m4 0a6 6 0 01-7.743 5.743L11 17H9v2H7v2H4a1 1 0 01-1-1v-2.586a1 1 0 01.293-.707l5.964-5.964A6 6 0 1121 9z" />
                      </svg>
                      Reset
                    </button>
                  </div>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    <% else %>
      <div class="empty-state p-4">
        <p class="empty-state__text">No users found</p>
      </div>
    <% end %>
  </div>
</div>

<%# Group Assignment Modals %>
<% @users.each do |user| %>
  <div id="group-modal-<%= user.id %>"
       class="dialog-overlay is-hidden"
       data-controller="modal">
    <div class="dialog"
         data-modal-target="content"
         data-action="click->modal#stop">
      <%= form_with url: update_groups_admin_user_path(user), method: :patch, local: true do |form| %>
        <div class="dialog__header">
          <div>
            <h3 class="dialog__title">Assign Groups</h3>
            <p class="text-sm font-medium mt-1"><%= user.email %></p>
          </div>
          <button type="button"
                  class="dialog__close close-group-modal-btn"
                  data-modal-id="group-modal-<%= user.id %>">
            <span class="sr-only">Close</span>
            <svg class="icon" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
            </svg>
          </button>
        </div>

        <div class="dialog__body">
          <p class="text-sm mb-3">
            Select groups to grant this user access to. Users will only see workflows in their assigned groups (unless they are admins).
          </p>

          <div class="admin-group-list">
            <% if @all_groups.any? %>
              <% @all_groups.roots.includes(:children).order(:position, :name).each do |root_group| %>
                <%= render partial: "admin/users/group_checkbox", locals: { group: root_group, user: user, level: 0 } %>
              <% end %>
            <% else %>
              <div class="empty-state p-4 text-center">
                <svg class="icon icon--xl mx-auto mb-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 7v10a2 2 0 002 2h14a2 2 0 002-2V9a2 2 0 00-2-2h-6l-2-2H5a2 2 0 00-2 2z" />
                </svg>
                <p class="text-sm">No groups available. Create groups first.</p>
              </div>
            <% end %>
          </div>
        </div>

        <div class="dialog__footer">
          <button type="button"
                  class="close-group-modal-btn btn btn--plain"
                  data-modal-id="group-modal-<%= user.id %>">
            Cancel
          </button>
          <%= form.submit "Save Groups", class: "btn btn--primary" %>
        </div>
      <% end %>
    </div>
  </div>
<% end %>

<%# Bulk Group Assignment Modal %>
<div id="bulk-group-modal"
     class="dialog-overlay is-hidden"
     data-controller="modal">
  <div class="dialog"
       data-modal-target="content"
       data-action="click->modal#stop">
    <%= form_with url: bulk_assign_groups_admin_users_path, method: :patch, local: true do |form| %>
      <div class="dialog__header">
        <h3 class="dialog__title">Bulk Assign Groups</h3>
        <button type="button"
                class="dialog__close close-bulk-modal-btn">
          <span class="sr-only">Close</span>
          <svg class="icon" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
          </svg>
        </button>
      </div>

      <div class="dialog__body">
        <p class="text-sm mb-3">
          Select groups to assign to the selected users. This will replace their existing group assignments.
        </p>

        <div id="selected-users-count" class="text-sm font-medium mb-3">
          No users selected
        </div>

        <div class="admin-group-list">
          <% if @all_groups.any? %>
            <% @all_groups.roots.includes(:children).order(:position, :name).each do |root_group| %>
              <%= render partial: "admin/users/group_checkbox", locals: { group: root_group, user: nil, level: 0 } %>
            <% end %>
          <% else %>
            <div class="empty-state p-4 text-center">
              <svg class="icon icon--xl mx-auto mb-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 7v10a2 2 0 002 2h14a2 2 0 002-2V9a2 2 0 00-2-2h-6l-2-2H5a2 2 0 00-2 2z" />
              </svg>
              <p class="text-sm">No groups available. Create groups first.</p>
            </div>
          <% end %>
        </div>
      </div>

      <div class="dialog__footer">
        <button type="button"
                class="close-bulk-modal-btn btn btn--plain">
          Cancel
        </button>
        <%= form.submit "Assign to Selected Users", class: "btn btn--primary" %>
      </div>
    <% end %>
  </div>
</div>

<%# Password Reset Modal %>
<div id="password-reset-modal"
     class="dialog-overlay is-hidden"
     data-controller="modal">
  <div class="dialog"
       data-modal-target="content"
       data-action="click->modal#stop">
    <div class="dialog__header">
      <div>
        <h3 class="dialog__title">Password Reset</h3>
        <p class="text-sm font-medium mt-1" id="reset-modal-user-email"></p>
      </div>
      <button type="button"
              id="password-reset-modal-close-x"
              class="dialog__close">
        <span class="sr-only">Close</span>
        <svg class="icon" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
        </svg>
      </button>
    </div>

    <div class="dialog__body">
      <div class="admin-info-box admin-info-box--info mb-3">
        <div class="flex items-start gap-3">
          <svg class="icon icon--sm flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
          </svg>
          <div class="text-sm">
            <p class="font-semibold mb-1">New Temporary Password Generated</p>
            <p id="temp-password-display" class="font-mono text-lg mt-2 font-bold">
              Loading...
            </p>
            <p class="mt-2 text-xs">
              Copy this password and give it to the user. They should change it immediately after logging in.
            </p>
          </div>
        </div>
      </div>

      <div class="admin-info-box admin-info-box--warning">
        <div class="flex items-start gap-3">
          <svg class="icon icon--sm flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-2.5L13.732 4c-.77-.833-1.964-.833-2.732 0L4.082 15.5c-.77.833.192 2.5 1.732 2.5z" />
          </svg>
          <div class="text-sm">
            <p class="font-semibold mb-1">Important Security Note</p>
            <ul class="list-disc list-inside text-xs">
              <li>This is a one-time temporary password</li>
              <li>User should change it immediately after first login</li>
              <li>The password is secure and randomly generated</li>
              <li>This action has been logged for security purposes</li>
            </ul>
          </div>
        </div>
      </div>
    </div>

    <div class="dialog__footer">
      <button type="button"
              id="password-reset-modal-copy"
              class="btn btn--plain flex items-center gap-2">
        <svg class="icon icon--sm" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 5H6a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2v-1M8 5a2 2 0 002 2h2a2 2 0 002-2M8 5a2 2 0 012-2h2a2 2 0 012 2m0 0h2a2 2 0 012 2v3m2 4H10m0 0l3-3m-3 3l3 3" />
        </svg>
        Copy Password
      </button>
      <button type="button"
              id="password-reset-modal-done"
              class="btn btn--positive flex items-center gap-2">
        <svg class="icon icon--sm" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
        </svg>
        Done
      </button>
    </div>
  </div>
</div>

<script nonce="<%= content_security_policy_nonce %>">
  let bulkMode = false;
  let currentTempPassword = '';

  function getCSRFToken() {
    const token = document.querySelector('meta[name="csrf-token"]');
    return token ? token.getAttribute('content') : '';
  }

  async function resetUserPassword(userId, userEmail, buttonElement) {
    if (!confirm('Are you sure you want to generate a temporary password for ' + userEmail + '? They will be able to log in immediately with this password.')) {
      return;
    }

    const originalHTML = buttonElement.innerHTML;
    buttonElement.disabled = true;
    buttonElement.textContent = 'Generating...';

    try {
      const csrfToken = getCSRFToken();
      if (!csrfToken) {
        throw new Error('CSRF token not found. Please refresh the page.');
      }

      const response = await fetch('/admin/users/' + userId + '/reset_password', {
        method: 'POST',
        headers: {
          'X-CSRF-Token': csrfToken,
          'Content-Type': 'application/json',
          'Accept': 'application/json'
        },
        credentials: 'same-origin'
      });

      const data = await response.json();

      if (!response.ok) {
        throw new Error(data.error || 'Server error: ' + response.status);
      }

      if (data && data.success && data.password) {
        currentTempPassword = data.password;
        document.getElementById('reset-modal-user-email').textContent = data.email || userEmail;
        document.getElementById('temp-password-display').textContent = data.password;
        document.getElementById('password-reset-modal').classList.remove('is-hidden');
      } else {
        alert('Failed to generate temporary password. Please try again.');
      }
    } catch (error) {
      console.error('Password reset error:', error);
      alert('An error occurred while generating the temporary password. Please try again.');
    } finally {
      buttonElement.disabled = false;
      buttonElement.innerHTML = originalHTML;
    }
  }

  function copyTempPassword(buttonElement) {
    if (currentTempPassword) {
      navigator.clipboard.writeText(currentTempPassword).then(function() {
        const originalText = buttonElement.textContent;
        buttonElement.textContent = 'Copied!';
        setTimeout(function() {
          buttonElement.textContent = originalText;
        }, 2000);
      }).catch(function(err) {
        alert('Failed to copy password. Please copy it manually.');
        console.error('Failed to copy:', err);
      });
    }
  }

  function toggleBulkMode() {
    bulkMode = !bulkMode;
    const columns = document.querySelectorAll('.bulk-select-column');
    const btn = document.getElementById('bulk-toggle-btn');

    columns.forEach(function(col) {
      col.style.display = bulkMode ? 'table-cell' : 'none';
    });

    if (bulkMode) {
      btn.textContent = 'Cancel Bulk Mode';
      btn.classList.add('btn--negative');
    } else {
      btn.textContent = 'Bulk Assign Groups';
      btn.classList.remove('btn--negative');
      document.querySelectorAll('.user-checkbox').forEach(function(cb) { cb.checked = false; });
      document.getElementById('select-all-users').checked = false;
      updateSelectedCount();
    }
  }

  function toggleAllUsers(checkbox) {
    document.querySelectorAll('.user-checkbox').forEach(function(cb) {
      cb.checked = checkbox.checked;
    });
    updateSelectedCount();
  }

  function updateSelectedCount() {
    const selected = document.querySelectorAll('.user-checkbox:checked').length;
    const countEl = document.getElementById('selected-users-count');
    if (countEl) {
      countEl.textContent = selected > 0 ? (selected + ' user' + (selected > 1 ? 's' : '') + ' selected') : 'No users selected';
    }
  }

  function openBulkModal() {
    const selectedIds = Array.from(document.querySelectorAll('.user-checkbox:checked')).map(function(cb) { return cb.value; });
    const form = document.querySelector('#bulk-group-modal form');
    if (form) {
      form.querySelectorAll('input[name="user_ids[]"]').forEach(function(input) { input.remove(); });
      selectedIds.forEach(function(id) {
        const input = document.createElement('input');
        input.type = 'hidden';
        input.name = 'user_ids[]';
        input.value = id;
        form.appendChild(input);
      });
    }
    document.getElementById('bulk-group-modal').classList.remove('is-hidden');
  }

  function attachAdminUserListeners() {
    const bulkBtn = document.getElementById('bulk-toggle-btn');
    if (bulkBtn && !bulkBtn.dataset.listenerAttached) {
      bulkBtn.dataset.listenerAttached = 'true';
      bulkBtn.addEventListener('click', function() {
        if (bulkMode && document.querySelectorAll('.user-checkbox:checked').length > 0) {
          openBulkModal();
        } else {
          toggleBulkMode();
        }
      });
    }

    const selectAll = document.getElementById('select-all-users');
    if (selectAll && !selectAll.dataset.listenerAttached) {
      selectAll.dataset.listenerAttached = 'true';
      selectAll.addEventListener('change', function() { toggleAllUsers(this); });
    }

    document.querySelectorAll('.open-group-modal-btn').forEach(function(btn) {
      if (btn.dataset.listenerAttached === 'true') return;
      btn.dataset.listenerAttached = 'true';
      btn.addEventListener('click', function() {
        var modal = document.getElementById(btn.dataset.modalId);
        if (modal) modal.classList.remove('is-hidden');
      });
    });

    document.querySelectorAll('.close-group-modal-btn').forEach(function(btn) {
      if (btn.dataset.listenerAttached === 'true') return;
      btn.dataset.listenerAttached = 'true';
      btn.addEventListener('click', function() {
        var modal = document.getElementById(btn.dataset.modalId);
        if (modal) modal.classList.add('is-hidden');
      });
    });

    document.querySelectorAll('.close-bulk-modal-btn').forEach(function(btn) {
      if (btn.dataset.listenerAttached === 'true') return;
      btn.dataset.listenerAttached = 'true';
      btn.addEventListener('click', function() {
        document.getElementById('bulk-group-modal').classList.add('is-hidden');
      });
    });

    document.querySelectorAll('.user-checkbox').forEach(function(cb) {
      if (cb.dataset.listenerAttached === 'true') return;
      cb.dataset.listenerAttached = 'true';
      cb.addEventListener('change', updateSelectedCount);
    });
  }

  function attachResetListeners() {
    document.querySelectorAll('.reset-password-btn').forEach(function(buttonElement) {
      if (buttonElement.dataset.listenerAttached === 'true') return;
      buttonElement.dataset.listenerAttached = 'true';
      buttonElement.addEventListener('click', function(e) {
        e.preventDefault();
        e.stopPropagation();
        resetUserPassword(buttonElement.dataset.userId, buttonElement.dataset.userEmail, buttonElement);
      });
    });
  }

  function attachModalCloseListeners() {
    const modal = document.getElementById('password-reset-modal');
    if (!modal) return;

    const closeXBtn = document.getElementById('password-reset-modal-close-x');
    if (closeXBtn && !closeXBtn.dataset.listenerAttached) {
      closeXBtn.dataset.listenerAttached = 'true';
      closeXBtn.addEventListener('click', function() { modal.classList.add('is-hidden'); });
    }

    const doneBtn = document.getElementById('password-reset-modal-done');
    if (doneBtn && !doneBtn.dataset.listenerAttached) {
      doneBtn.dataset.listenerAttached = 'true';
      doneBtn.addEventListener('click', function() { modal.classList.add('is-hidden'); });
    }

    const copyBtn = document.getElementById('password-reset-modal-copy');
    if (copyBtn && !copyBtn.dataset.listenerAttached) {
      copyBtn.dataset.listenerAttached = 'true';
      copyBtn.addEventListener('click', function() { copyTempPassword(copyBtn); });
    }
  }

  function attachAllListeners() {
    attachAdminUserListeners();
    attachResetListeners();
    attachModalCloseListeners();
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', attachAllListeners);
  } else {
    attachAllListeners();
  }

  document.addEventListener('turbo:load', attachAllListeners);
</script>
