<div class="page-content page-narrow">
  <div class="flex items-center justify-between mb-6">
    <div>
      <h1 class="page-title">
        <%= @version.metadata_snapshot["title"] %> — v<%= @version.version_number %>
      </h1>
      <p class="text-sm mt-1">
        Published by <%= @version.published_by.email %> on <%= @version.published_at.strftime("%b %d, %Y %H:%M") %>
      </p>
      <% if @version.changelog.present? %>
        <p class="text-sm mt-2 italic"><%= @version.changelog %></p>
      <% end %>
    </div>
    <div class="flex gap-3">
      <% if @workflow.can_be_edited_by?(current_user) && @version != @workflow.published_version %>
        <%= button_to "Restore This Version", workflow_restore_version_path(@workflow, @version),
            method: :post,
            class: "btn btn--secondary",
            data: { turbo_confirm: "Restore this version? This will overwrite the current draft steps." } %>
      <% end %>
      <%= link_to "All Versions", workflow_versions_path(@workflow),
          class: "btn btn--plain" %>
    </div>
  </div>

  <div class="card p-6">
    <h2 class="font-semibold mb-4">
      Steps (<%= @version.steps_snapshot.length %>)
    </h2>
    <div class="flex-col-gap-3">
      <% @version.steps_snapshot.each_with_index do |step, index| %>
        <div class="version-step-item card">
          <div class="flex items-center gap-3">
            <span class="step-card__number">
              <%= index + 1 %>
            </span>
            <span class="badge badge--<%= step['type'] || 'default' %>">
              <%= step['type']&.humanize %>
            </span>
            <span class="text-sm font-medium"><%= step['title'] %></span>
          </div>
        </div>
      <% end %>
    </div>
  </div>
</div>
