<div class="page-content">
  <%# === Header Section === %>
  <div class="page-header-section">
    <div class="scenario-header">
      <div>
        <p class="text-xs font-semibold uppercase tracking-widest mb-1">Scenario</p>
        <h1 class="page-header-section__title">Scenario Results</h1>
        <% if @scenario.complete? && !@scenario.stopped? %>
          <%
            path = flattened_execution_path(@scenario)
            duration_seconds = (@scenario.updated_at - @scenario.created_at).to_i
            duration_text = duration_seconds < 60 ? "#{duration_seconds}s" : "#{duration_seconds / 60}m #{duration_seconds % 60}s"
            questions_count = path.count { |p| p['step_type'] == 'question' || p['type'] == 'question' }
          %>
          <div class="scenario-stats">
            <span class="badge flex items-center gap-1.5">
              <%= icon "clock", class: "icon icon--xs" %>
              <%= duration_text %>
            </span>
            <span class="badge flex items-center gap-1.5">
              <%= icon "clipboard", class: "icon icon--xs" %>
              <%= pluralize(path.length, 'step') %>
            </span>
            <% if questions_count > 0 %>
              <span class="badge flex items-center gap-1.5">
                <%= icon "question-mark-circle", class: "icon icon--xs" %>
                <%= pluralize(questions_count, 'question') %> answered
              </span>
            <% end %>
            <% resolution = @scenario.results&.dig('_resolution') %>
            <% if resolution.present? && resolution['type'].present? %>
              <span class="badge badge--resolve flex items-center gap-1.5">
                <%= icon "check-circle", class: "icon icon--xs" %>
                <%= resolution['type']&.titleize %>
              </span>
            <% end %>
          </div>
        <% else %>
          <p class="mt-2 text-sm">Execution path and results for <%= @workflow.title %></p>
        <% end %>
      </div>
      <% if @scenario.stopped? %>
        <div class="badge badge--alert scenario-status-badge" role="status">
          <%= icon "x-mark", class: "icon icon--sm" %>
          Workflow Stopped
        </div>
      <% elsif @scenario.timed_out? %>
        <div class="badge badge--alert scenario-status-badge" role="status">
          <%= icon "clock", class: "icon icon--sm" %>
          Timed Out
        </div>
      <% elsif @scenario.errored? %>
        <div class="badge badge--alert scenario-status-badge" role="status">
          <%= icon "exclamation-circle", class: "icon icon--sm" %>
          Error
        </div>
      <% elsif @scenario.complete? %>
        <div class="badge badge--published scenario-status-badge" role="status">
          <%= icon "check", class: "icon icon--sm" %>
          Completed
        </div>
      <% else %>
        <div class="badge scenario-status-badge" role="status">
          <%= icon "clock", class: "icon icon--sm" %>
          In Progress
        </div>
      <% end %>
    </div>
  </div>

  <%# === Status Warning Cards === %>
  <% if @scenario.stopped? %>
    <div class="card card--escalate mb-4">
      <div class="card__body scenario-warning__inner">
        <%= icon "exclamation-triangle", class: "icon icon--lg flex-shrink-0 mt-0.5" %>
        <div class="scenario-warning__content">
          <h3 class="font-semibold mb-2">Workflow Stopped</h3>
          <p class="text-sm mb-2">
            This workflow was stopped before completion.
            <% if @scenario.stopped_at_step_index.present? %>
              It was stopped at step <%= @scenario.stopped_at_step_index + 1 %>.
            <% end %>
          </p>
          <p class="text-xs mb-4">
            Stopped on <%= @scenario.updated_at.strftime("%B %d, %Y at %I:%M %p") %>
          </p>
          <%= link_to new_workflow_scenario_path(@workflow), class: "btn btn--sm flex items-center gap-1.5" do %>
            <%= icon "arrow-path", class: "icon icon--xs" %>
            Run Again
          <% end %>
        </div>
      </div>
    </div>
  <% end %>

  <% if @scenario.timed_out? %>
    <div class="card mb-4">
      <div class="card__body scenario-warning__inner">
        <%= icon "clock", class: "icon icon--lg flex-shrink-0 mt-0.5" %>
        <div class="scenario-warning__content">
          <h3 class="font-semibold mb-2">Scenario Timed Out</h3>
          <p class="text-sm mb-2">
            The scenario exceeded the maximum execution time. This usually happens when a workflow contains an infinite loop or overly complex routing logic.
          </p>
          <p class="text-xs mb-4">
            Timed out on <%= @scenario.updated_at.strftime("%B %d, %Y at %I:%M %p") %>
          </p>
          <%= link_to new_workflow_scenario_path(@workflow), class: "btn btn--sm flex items-center gap-1.5" do %>
            <%= icon "arrow-path", class: "icon icon--xs" %>
            Try Again
          <% end %>
        </div>
      </div>
    </div>
  <% elsif @scenario.errored? %>
    <div class="card mb-4">
      <div class="card__body scenario-warning__inner">
        <%= icon "exclamation-circle", class: "icon icon--lg flex-shrink-0 mt-0.5" %>
        <div class="scenario-warning__content">
          <h3 class="font-semibold mb-2">Scenario Error</h3>
          <p class="text-sm mb-2">
            An error occurred during scenario execution. This may be caused by invalid step configuration or missing references in the workflow.
          </p>
          <p class="text-xs mb-4">
            Error occurred on <%= @scenario.updated_at.strftime("%B %d, %Y at %I:%M %p") %>
          </p>
          <%= link_to new_workflow_scenario_path(@workflow), class: "btn btn--sm flex items-center gap-1.5" do %>
            <%= icon "arrow-path", class: "icon icon--xs" %>
            Try Again
          <% end %>
        </div>
      </div>
    </div>
  <% end %>

  <%# === Tabbed Content === %>
  <div data-controller="tabs" data-tabs-active-value="0">
    <div class="wf-status-tabs mb-4" role="tablist">
      <button type="button"
              class="wf-status-tabs__tab wf-status-tabs__tab--active"
              data-tabs-target="tab"
              data-action="click->tabs#switch"
              role="tab"
              aria-selected="true">
        <%= icon "chevron-right", class: "icon icon--xs inline mr-1.5" %>
        Execution Path
      </button>
      <button type="button"
              class="wf-status-tabs__tab"
              data-tabs-target="tab"
              data-action="click->tabs#switch"
              role="tab"
              aria-selected="false">
        <%= icon "document-chart-bar", class: "icon icon--xs inline mr-1.5" %>
        Results Summary
      </button>
    </div>

    <%# === Panel 1: Execution Path === %>
    <div data-tabs-target="panel">
      <div class="card mb-4" data-controller="scenario-results">
        <div class="card__header scenario-card-header">
          <h2>Execution Path</h2>
          <% flat_path = flattened_execution_path(@scenario) %>
          <% if flat_path.present? && flat_path.length > 1 %>
            <div class="scenario-card-header__actions">
              <button type="button"
                      class="btn btn--plain btn--sm"
                      data-action="click->scenario-results#expandAll">
                Expand All
              </button>
              <span>|</span>
              <button type="button"
                      class="btn btn--plain btn--sm"
                      data-action="click->scenario-results#collapseAll">
                Collapse All
              </button>
            </div>
          <% end %>
        </div>
        <% if flat_path.present? && flat_path.any? %>
          <div class="card__body" role="list">
            <% flat_path.each_with_index do |path_item, index| %>
              <% step_type = path_item['step_type'] || path_item['type'] %>
              <div class="exec-step exec-step--<%= step_type %> mb-2"
                   role="listitem"
                   aria-label="Step <%= index + 1 %>: <%= path_item['step_title'] %> - <%= step_type %>"
                   data-scenario-results-target="item">
                <button type="button"
                        class="scenario-exec-toggle"
                        data-action="click->scenario-results#toggle"
                        aria-expanded="false">
                  <span class="scenario-result-badge badge badge--published">
                    <%= icon "check", class: "icon icon--sm" %>
                  </span>
                  <div class="scenario-exec-toggle__body">
                    <span class="mr-2 flex-shrink-0">
                      <%= step_type_svg_icon(step_type, css_classes: "icon icon--sm") %>
                    </span>
                    <h3 class="font-semibold truncate"><%= path_item['step_title'] %></h3>
                    <span class="ml-3 flex-shrink-0 <%= step_type_badge_classes(step_type) %>">
                      <%= step_type_label(step_type) %>
                    </span>
                    <span class="ml-2 text-xs flex-shrink-0"><%= index + 1 %></span>
                  </div>
                  <%= icon "chevron-right", class: "icon icon--sm ml-2 flex-shrink-0 transition-transform duration-200" %>
                </button>
                <div class="is-hidden mt-2 ml-11" data-scenario-results-target="details">
                  <% if path_item['answer'].present? %>
                    <p class="text-sm">
                      <strong>Answer:</strong>
                      <span class="font-medium"><%= path_item['answer'] %></span>
                    </p>
                  <% end %>
                  <% if path_item['condition_result'].present? %>
                    <p class="text-sm mt-1">
                      <strong>Routing:</strong>
                      <span class="badge ml-1">
                        <%= icon "arrows-up-down", class: "icon icon--xs inline mr-1" %>
                        <% if path_item['condition_result'].is_a?(String) %>
                          <%= path_item['condition_result'] %>
                        <% else %>
                          <%= path_item['condition_result'] ? 'True' : 'False' %>
                        <% end %>
                      </span>
                    </p>
                  <% end %>
                  <% if path_item['action_completed'].present? %>
                    <p class="text-sm mt-1">Action completed</p>
                  <% end %>
                  <% if path_item['message_displayed'].present? %>
                    <p class="text-sm mt-1">Message displayed</p>
                    <% if path_item['content'].present? %>
                      <p class="text-sm mt-1"><%= path_item['content'] %></p>
                    <% end %>
                  <% end %>
                  <% if path_item['escalated'].present? %>
                    <p class="text-sm mt-1">Escalated</p>
                  <% end %>
                  <% if path_item['resolved'] == true %>
                    <p class="text-sm mt-1">Issue resolved</p>
                  <% end %>
                </div>
              </div>
            <% end %>
          </div>
        <% else %>
          <div class="empty-state p-4">
            <p class="empty-state__text">No execution path recorded.</p>
          </div>
        <% end %>
      </div>
    </div>

    <%# === Panel 2: Results Summary === %>
    <div data-tabs-target="panel">
      <div class="card mb-4">
        <div class="card__header">
          <h2>Results Summary</h2>
        </div>
        <% if @scenario.results.present? %>
          <div class="card__body">
            <%# Display escalation info if present %>
            <% if @scenario.results['_escalation'].present? %>
              <% escalation = @scenario.results['_escalation'] %>
              <div class="admin-info-box admin-info-box--warning mb-4">
                <div class="scenario-warning__inner">
                  <%= icon "arrow-up", class: "icon icon--sm flex-shrink-0 mt-0.5" %>
                  <div class="scenario-warning__content">
                    <h3 class="text-sm font-semibold mb-2">Escalation Details</h3>
                    <dl class="text-sm">
                      <% if escalation['type'].present? %>
                        <div class="scenario-detail-row">
                          <dt class="scenario-detail-row__label">Target:</dt>
                          <dd><%= escalation['type']&.titleize %><%= " - #{escalation['value']}" if escalation['value'].present? %></dd>
                        </div>
                      <% end %>
                      <% if escalation['priority'].present? && !%w[normal medium].include?(escalation['priority']) %>
                        <div class="scenario-detail-row">
                          <dt class="scenario-detail-row__label">Priority:</dt>
                          <dd><%= escalation['priority']&.titleize %></dd>
                        </div>
                      <% end %>
                      <% if escalation['notes'].present? %>
                        <div class="scenario-detail-row">
                          <dt class="scenario-detail-row__label">Notes:</dt>
                          <dd><%= escalation['notes'] %></dd>
                        </div>
                      <% end %>
                    </dl>
                  </div>
                </div>
              </div>
            <% end %>

            <%# Display resolution info if present %>
            <% if @scenario.results['_resolution'].present? %>
              <% resolution = @scenario.results['_resolution'] %>
              <div class="admin-info-box admin-info-box--info mb-4">
                <div class="scenario-warning__inner">
                  <%= icon "check-circle", class: "icon icon--sm flex-shrink-0 mt-0.5" %>
                  <div class="scenario-warning__content">
                    <h3 class="text-sm font-semibold mb-2">Resolution Details</h3>
                    <dl class="text-sm">
                      <% if resolution['type'].present? %>
                        <div class="scenario-detail-row">
                          <dt class="scenario-detail-row__label">Type:</dt>
                          <dd><%= resolution['type']&.titleize %></dd>
                        </div>
                      <% end %>
                    </dl>
                  </div>
                </div>
              </div>
            <% end %>

            <%# Display error info if present %>
            <% if @scenario.results['_error'].present? %>
              <div class="flash flash--alert mb-4">
                <div class="flash__body">
                  <p class="font-semibold mb-1">Error</p>
                  <p class="text-sm"><%= @scenario.results['_error'] %></p>
                </div>
              </div>
            <% end %>

            <%# Display categorized regular results %>
            <% result_groups = categorize_scenario_results(@scenario) %>
            <% if result_groups.any? %>
              <% result_groups.each do |group| %>
                <div class="mb-4">
                  <h3 class="text-sm font-semibold uppercase tracking-wide mb-3"><%= group[:label] %></h3>
                  <div class="scenario-results-grid">
                    <% group[:results].each do |key, value| %>
                      <dt class="text-sm font-medium py-1"><%= format_result_key(key) %></dt>
                      <dd class="text-sm py-1 flex items-center justify-between scenario-result__row" data-controller="clipboard">
                        <span data-clipboard-target="source"><%= value.is_a?(Hash) ? value.to_json : value %></span>
                        <button type="button"
                                class="btn btn--plain btn--sm scenario-result__copy ml-2"
                                title="Copy value"
                                data-action="click->clipboard#copy"
                                data-clipboard-target="button">
                          <%= icon "clipboard-document-list", class: "icon icon--xs" %>
                        </button>
                      </dd>
                    <% end %>
                  </div>
                </div>
              <% end %>
            <% elsif @scenario.results.keys.all? { |k| k.to_s.start_with?('_') } %>
              <%# All results are internal, don't show "No results" message %>
            <% end %>
          </div>
        <% else %>
          <div class="empty-state p-4">
            <p class="empty-state__text">No results recorded.</p>
          </div>
        <% end %>
      </div>
    </div>
  </div>

  <%# === Footer CTAs === %>
  <div class="scenario-footer">
    <div class="scenario-footer__group">
      <%= link_to workflow_path(@workflow), class: "btn btn--plain flex items-center gap-1.5" do %>
        <%= icon "chevron-left", class: "icon icon--sm" %>
        Back to Workflow
      <% end %>
      <% if current_user&.can_create_workflows? %>
        <%= link_to edit_workflow_path(@workflow), class: "btn btn--plain flex items-center gap-1.5" do %>
          <%= icon "pencil-square", class: "icon icon--sm" %>
          Edit Workflow
        <% end %>
      <% end %>
    </div>
    <div class="scenario-footer__group">
      <div data-controller="clipboard">
        <span class="is-hidden" data-clipboard-target="source"><%= scenario_url(@scenario) %></span>
        <button type="button"
                class="btn btn--plain flex items-center gap-1.5"
                data-action="click->clipboard#copy"
                data-clipboard-target="button">
          <%= icon "link", class: "icon icon--sm" %>
          Copy Link
        </button>
      </div>
      <%= link_to new_workflow_scenario_path(@workflow), class: "btn btn--positive flex items-center gap-1.5" do %>
        <%= icon "arrow-path", class: "icon icon--sm" %>
        Run Again
      <% end %>
    </div>
  </div>
</div>
