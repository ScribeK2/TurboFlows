<% content_for(:workflow_title) { @workflow.title } %>
<% content_for(:title) { "#{@workflow.title} — Complete — TurboFlows Player" } %>

<div class="player-step">
  <div class="player-step__header">
    <h2 class="player-step__title">
      <% if @scenario.completed? %>
        Workflow Complete
      <% else %>
        Workflow Stopped
      <% end %>
    </h2>
  </div>

  <div class="player-step__content">
    <% if @scenario.results.present? %>
      <% resolution = @scenario.results["_resolution"] %>
      <% if resolution %>
        <p>Resolution: <%= resolution["type"]&.humanize %></p>
      <% end %>

      <% escalation = @scenario.results["_escalation"] %>
      <% if escalation %>
        <p>Escalated to: <%= escalation["type"] %> — <%= escalation["value"] %></p>
      <% end %>
    <% end %>
  </div>

  <div class="player-step__actions">
    <%= link_to "Back to Workflows", play_path, class: "btn btn--primary" %>
    <%= button_to "Replay", play_workflow_path(@workflow), method: :post, class: "btn btn--plain" %>
  </div>
</div>
