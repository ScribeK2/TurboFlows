<% content_for(:workflow_title) { @workflow.title } %>
<% content_for(:title) { "#{@workflow.title} — Complete — TurboFlows Player" } %>

<%
  is_completed = @scenario.completed?
  resolution = @scenario.results&.dig("_resolution")
  escalation = @scenario.results&.dig("_escalation")
  steps_completed = @scenario.execution_path&.size || 0
  duration = if @scenario.started_at && @scenario.completed_at
    distance_of_time_in_words(@scenario.started_at, @scenario.completed_at)
  elsif @scenario.started_at
    distance_of_time_in_words(@scenario.started_at, Time.current)
  end
%>

<div class="player-completion">
  <%# ── Status Icon ── %>
  <div class="player-completion__icon-wrap player-completion__icon-wrap--<%= is_completed ? 'success' : 'stopped' %>">
    <% if escalation %>
      <%= icon "exclamation-triangle", class: "player-completion__icon" %>
    <% elsif is_completed %>
      <%= icon "check-circle", class: "player-completion__icon" %>
    <% else %>
      <%= icon "pause-circle", class: "player-completion__icon" %>
    <% end %>
  </div>

  <%# ── Heading ── %>
  <h1 class="player-completion__title">
    <% if escalation %>
      Escalation Required
    <% elsif is_completed %>
      Workflow Complete
    <% else %>
      Workflow Stopped
    <% end %>
  </h1>

  <%# ── Resolution/Escalation Details ── %>
  <% if resolution || escalation %>
    <div class="player-completion__details card">
      <div class="card__body">
        <% if resolution %>
          <div class="player-completion__detail-row">
            <span class="player-completion__detail-label">Resolution</span>
            <span class="badge badge--resolve"><%= resolution["type"].presence&.humanize || "Resolved" %></span>
          </div>
        <% end %>
        <% if escalation %>
          <div class="player-completion__detail-row">
            <span class="player-completion__detail-label">Escalated to</span>
            <span><%= escalation["type"] %><%= " — #{escalation["value"]}" if escalation["value"].present? %></span>
          </div>
        <% end %>
      </div>
    </div>
  <% end %>

  <%# ── Stats ── %>
  <div class="player-completion__stats">
    <div class="player-completion__stat">
      <span class="player-completion__stat-value"><%= steps_completed %></span>
      <span class="player-completion__stat-label">Steps completed</span>
    </div>
    <% if duration %>
      <div class="player-completion__stat">
        <span class="player-completion__stat-value"><%= duration %></span>
        <span class="player-completion__stat-label">Duration</span>
      </div>
    <% end %>
    <% if resolution %>
      <% outcome_label = resolution["type"].presence&.titleize || "Resolved" %>
      <div class="player-completion__stat">
        <span class="player-completion__stat-value"><%= outcome_label %></span>
        <span class="player-completion__stat-label">Outcome</span>
      </div>
    <% end %>
  </div>

  <%# ── Actions ── %>
  <div class="player-completion__actions">
    <%= button_to "Run Again", play_workflow_path(@workflow), method: :post, class: "btn btn--primary" %>
    <%= link_to "Back to Workflows", play_path, class: "btn btn--plain" %>
  </div>
</div>
