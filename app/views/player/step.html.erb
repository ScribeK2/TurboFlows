<% content_for(:workflow_title) { @workflow.title } %>
<% content_for(:title) { "#{@workflow.title} — TurboFlows Player" } %>

<% if @current_step %>
  <%
    stype = @current_step.step_type
    step_number = (@scenario.execution_path&.size || 0) + 1
    total_steps = @workflow.steps.size
    progress_pct = total_steps > 0 ? ((step_number.to_f / total_steps) * 100).clamp(0, 100).round : 0
    auto_advance = %w[yes_no multiple_choice].include?(@current_step.try(:answer_type))
    step_info_text = "Step #{step_number}: #{@current_step.title}"
  %>

  <%# ── Progress Bar ── %>
  <div class="player-progress">
    <div class="player-progress__bar">
      <div class="player-progress__fill" style="width: <%= progress_pct %>%"></div>
    </div>
    <div class="player-progress__text">Step <%= step_number %> of <%= total_steps %></div>
  </div>

  <%# ── Step Card ── %>
  <div class="card player-step-card"
       data-controller="scenario-step"
       data-scenario-step-auto-advance-value="<%= auto_advance %>"
       data-scenario-step-step-info-value="<%= step_info_text %>"
       data-scenario-step-cancel-url-value="<%= play_path %>">
    <div class="card__body">
      <div aria-live="polite" class="sr-only" data-scenario-step-target="announce"></div>
      <%# ── Step Header ── %>
      <div class="scenario-step-header">
        <div class="scenario-step-header__info">
          <span class="<%= scenario_step_number_classes(stype) %>">
            <%= step_number %>
          </span>
          <div>
            <h2 class="player-step-card__title"><%= VariableInterpolator.interpolate(@current_step.title, @scenario.results || {}) %></h2>
            <span class="<%= step_type_badge_classes(stype) %>">
              <%= step_type_svg_icon(stype, css_classes: "icon icon--xs") %>
              <%= step_type_label(stype) %>
            </span>
            <% if @current_step.reference_url.present? %>
              <a href="<%= @current_step.reference_url %>" target="_blank" rel="noopener"
                 class="step-reference-link">
                <%= icon "link", class: "icon icon--xs" %>
                More info
              </a>
            <% end %>
          </div>
        </div>
      </div>

      <%# ── Help Text (coaching callout) ── %>
      <% if @current_step.help_text.present? %>
        <div class="step-help-text" role="note">
          <%= @current_step.help_text %>
        </div>
      <% end %>

      <%# ── Description ── %>
      <% if stype != "message" && @current_step.respond_to?(:description) && @current_step.description.present? %>
        <div class="text-sm mb-4 player-step-card__desc"><%= render_step_content(@current_step, 'description', @scenario.results || {}) %></div>
      <% end %>

      <%# ── Rich Content ── %>
      <% if @current_step.respond_to?(:content) && @current_step.content.present? && stype != "message" %>
        <div class="player-step-card__content"><%= render_step_content(@current_step, 'content', @scenario.results || {}) %></div>
      <% end %>

      <%# ── Step Type Content ── %>
      <% case stype %>
      <% when "question" %>
        <%= form_with url: player_scenario_next_path(@scenario), method: :post, class: "space-y-4", data: { scenario_step_target: "form" } do |f| %>
          <div>
            <label class="form-label"><%= VariableInterpolator.interpolate(@current_step.question.presence || @current_step.title, @scenario.results || {}) %></label>

            <% if @current_step.respond_to?(:answer_type) && @current_step.answer_type == "yes_no" %>
              <div class="grid grid-cols-2 gap-3">
                <label class="radio-card radio-card-yes">
                  <%= f.radio_button :answer, "yes", required: true, data: { action: "change->scenario-step#inputChanged", scenario_step_target: "input" } %>
                  <span class="radio-icon radio-icon-yes">
                    <%= icon "check", class: "icon icon--sm" %>
                  </span>
                  <span class="radio-dot"></span>
                  <span class="radio-label">Yes</span>
                </label>
                <label class="radio-card radio-card-no">
                  <%= f.radio_button :answer, "no", required: true, data: { action: "change->scenario-step#inputChanged", scenario_step_target: "input" } %>
                  <span class="radio-icon radio-icon-no">
                    <%= icon "x-mark", class: "icon icon--sm" %>
                  </span>
                  <span class="radio-dot"></span>
                  <span class="radio-label">No</span>
                </label>
              </div>

            <% elsif @current_step.respond_to?(:answer_type) && @current_step.answer_type == "multiple_choice" && @current_step.respond_to?(:options) && @current_step.options.present? %>
              <div class="space-y-2.5">
                <% @current_step.options.each do |option| %>
                  <% opt_val = option.is_a?(Hash) ? (option["value"] || option["label"]) : option %>
                  <% opt_label = option.is_a?(Hash) ? (option["label"] || option["value"]) : option %>
                  <label class="radio-card">
                    <%= f.radio_button :answer, opt_val, required: true, data: { action: "change->scenario-step#inputChanged", scenario_step_target: "input" } %>
                    <span class="radio-dot"></span>
                    <span class="radio-label"><%= opt_label %></span>
                  </label>
                <% end %>
              </div>

            <% elsif @current_step.respond_to?(:answer_type) && @current_step.answer_type == "dropdown" && @current_step.respond_to?(:options) && @current_step.options.present? %>
              <div class="scenario-input-wrap">
                <%= f.select :answer,
                  @current_step.options.map { |opt|
                    opt_label = opt.is_a?(Hash) ? (opt["label"] || opt["value"]) : opt
                    opt_val = opt.is_a?(Hash) ? (opt["value"] || opt["label"]) : opt
                    [opt_label, opt_val]
                  },
                  { prompt: "-- Select an option --" },
                  { class: "scenario-input scenario-select", required: true,
                    data: { action: "change->scenario-step#inputChanged", scenario_step_target: "input" } } %>
              </div>

            <% elsif @current_step.respond_to?(:options) && @current_step.options.present? %>
              <div class="space-y-2.5">
                <% @current_step.options.each do |option| %>
                  <% opt_val = option.is_a?(Hash) ? (option["value"] || option["label"]) : option %>
                  <% opt_label = option.is_a?(Hash) ? (option["label"] || option["value"]) : option %>
                  <label class="radio-card">
                    <%= f.radio_button :answer, opt_val, required: true, data: { action: "change->scenario-step#inputChanged", scenario_step_target: "input" } %>
                    <span class="radio-dot"></span>
                    <span class="radio-label"><%= opt_label %></span>
                  </label>
                <% end %>
              </div>

            <% else %>
              <%# Text, Number, Date inputs with type-specific icons %>
              <div class="scenario-input-wrap">
                <span class="scenario-input-icon">
                  <% answer_type = @current_step.try(:answer_type) %>
                  <% if answer_type == "number" %>
                    <%= icon "hashtag", class: "icon icon--sm" %>
                  <% elsif answer_type == "date" %>
                    <%= icon "calendar-days", class: "icon icon--sm" %>
                  <% else %>
                    <%= icon "pencil-square", class: "icon icon--sm" %>
                  <% end %>
                </span>
                <%
                  input_type = case answer_type
                               when "number" then "number"
                               when "date" then "date"
                               else "text"
                               end
                  placeholder = case answer_type
                                when "number" then "Enter a number"
                                when "date" then "YYYY-MM-DD"
                                else "Type your answer..."
                                end
                %>
                <%= f.text_field :answer, type: input_type, class: "scenario-input", required: true, placeholder: placeholder %>
              </div>
            <% end %>
          </div>

          <div class="scenario-button-bar">
            <div>
              <%= player_back_button(@scenario) %>
            </div>
            <div class="scenario-btn-group">
              <% if current_user %>
                <%= link_to "Cancel", play_path, class: "scenario-btn-cancel", data: { turbo_confirm: "Are you sure you want to cancel? Your progress will be lost." } %>
              <% end %>
              <%= f.submit "Continue", class: "btn btn--primary", disabled: auto_advance, data: { scenario_step_target: "submit" } %>
            </div>
          </div>
        <% end %>

      <% when "action" %>
        <div class="step-content-box step-content-box--action mb-4" data-controller="clipboard">
          <div class="step-content-box__accent"></div>
          <div class="step-content-box__body">
            <div class="scenario-content-layout--between">
              <div class="scenario-content-layout flex-1">
                <div class="step-content-box__icon-wrap mr-3 mt-0.5">
                  <%= icon "check", class: "icon icon--sm" %>
                </div>
                <div class="flex-1">
                  <h3 class="step-content-box__label">Instructions</h3>
                  <% if @current_step.respond_to?(:instructions) && @current_step.instructions.present? %>
                    <div class="text-sm" data-clipboard-target="source"><%= render_step_content(@current_step, 'instructions', @scenario.results || {}) %></div>
                  <% end %>
                  <% if @current_step.respond_to?(:output_fields) && @current_step.output_fields.present? %>
                    <div class="mt-3">
                      <h4 class="text-xs font-semibold mb-1 text-muted uppercase tracking-wider">Output Fields</h4>
                      <% @current_step.output_fields.each do |field| %>
                        <div class="text-sm flex gap-2 py-1">
                          <strong><%= field["name"] %>:</strong>
                          <span class="text-subtle"><%= field["value"].presence || "—" %></span>
                        </div>
                      <% end %>
                    </div>
                  <% end %>
                </div>
              </div>
              <button type="button"
                      class="btn btn--plain btn--sm ml-3 mt-1 flex-shrink-0"
                      title="Copy instructions to clipboard"
                      data-action="click->clipboard#copy"
                      data-clipboard-target="button">
                <%= icon "clipboard-document-list", class: "icon icon--sm" %>
              </button>
            </div>
          </div>
        </div>

        <%= form_with url: player_scenario_next_path(@scenario), method: :post do %>
          <input type="hidden" name="answer" value="completed">
          <div class="scenario-button-bar">
            <div>
              <%= player_back_button(@scenario) %>
            </div>
            <div class="scenario-btn-group">
              <% if current_user %>
                <%= link_to "Cancel", play_path, class: "scenario-btn-cancel", data: { turbo_confirm: "Are you sure you want to cancel? Your progress will be lost." } %>
              <% end %>
              <button type="submit" class="btn btn--primary">Continue</button>
            </div>
          </div>
        <% end %>

      <% when "message" %>
        <div class="step-content-box step-content-box--message mb-4">
          <div class="step-content-box__accent"></div>
          <div class="step-content-box__body">
            <div class="scenario-content-layout">
              <div class="step-content-box__icon-wrap mr-3 mt-0.5">
                <%= icon "chat-bubble-bottom-center-text", class: "icon icon--sm" %>
              </div>
              <div class="flex-1">
                <h3 class="step-content-box__label">Message</h3>
                <% if @current_step.respond_to?(:content) && @current_step.content.present? %>
                  <div class="text-sm"><%= render_step_content(@current_step, 'content', @scenario.results || {}) %></div>
                <% else %>
                  <p class="text-sm italic text-muted">No message content provided.</p>
                <% end %>
              </div>
            </div>
          </div>
        </div>

        <div class="scenario-button-bar">
          <div>
            <%= player_back_button(@scenario) %>
          </div>
          <div class="scenario-btn-group">
            <% if current_user %>
              <%= link_to "Cancel", play_path, class: "scenario-btn-cancel", data: { turbo_confirm: "Are you sure you want to cancel? Your progress will be lost." } %>
            <% end %>
            <%= button_to "Continue", player_scenario_next_path(@scenario), method: :post, params: { answer: "" }, class: "btn btn--primary" %>
          </div>
        </div>

      <% when "escalate" %>
        <div class="step-content-box step-content-box--escalate mb-4">
          <div class="step-content-box__accent"></div>
          <div class="step-content-box__body">
            <div class="scenario-content-layout">
              <div class="step-content-box__icon-wrap mr-3 mt-0.5">
                <%= icon "exclamation-triangle", class: "icon icon--sm" %>
              </div>
              <div class="flex-1">
                <h3 class="step-content-box__label">Escalation Required</h3>
                <% if @current_step.respond_to?(:target_type) && @current_step.target_type.present? %>
                  <p class="text-sm mb-2">
                    <strong>Target:</strong>
                    <%= @current_step.target_type&.titleize %><%= " — #{@current_step.target_value}" if @current_step.respond_to?(:target_value) && @current_step.target_value.present? %>
                  </p>
                <% end %>
                <% if @current_step.respond_to?(:priority) && @current_step.priority.present? && !%w[normal medium].include?(@current_step.priority) %>
                  <p class="text-sm mb-2">
                    <strong>Priority:</strong>
                    <%
                      priority_mod = if %w[urgent critical].include?(@current_step.priority)
                        "badge--alert"
                      elsif @current_step.priority == "high"
                        "badge--warning"
                      else
                        ""
                      end
                    %>
                    <span class="badge <%= priority_mod %>"><%= @current_step.priority&.titleize %></span>
                  </p>
                <% end %>
                <% if @current_step.respond_to?(:notes) && @current_step.notes.present? %>
                  <div class="text-sm mt-2"><%= render_step_content(@current_step, 'notes', @scenario.results || {}) %></div>
                <% end %>
              </div>
            </div>
          </div>
        </div>

        <%= form_with url: player_scenario_next_path(@scenario), method: :post do |f| %>
          <% if @current_step.respond_to?(:reason_required) && @current_step.reason_required %>
            <div class="form-group mb-3">
              <label class="form-label is-required">Escalation Reason</label>
              <%= f.text_area :escalation_reason, class: "form-input", rows: 3,
                  required: true, aria: { required: true, describedby: "escalation-reason-error" },
                  placeholder: "Describe why this is being escalated..." %>
              <span id="escalation-reason-error" class="form-error" style="display: none;">Escalation reason is required</span>
            </div>
          <% end %>
          <input type="hidden" name="answer" value="">
          <div class="scenario-button-bar">
            <div>
              <%= player_back_button(@scenario) %>
            </div>
            <div class="scenario-btn-group">
              <% if current_user %>
                <%= link_to "Cancel", play_path, class: "scenario-btn-cancel", data: { turbo_confirm: "Are you sure you want to cancel? Your progress will be lost." } %>
              <% end %>
              <%= f.submit "Continue", class: "btn btn--primary" %>
            </div>
          </div>
        <% end %>

      <% when "resolve" %>
        <div class="step-content-box step-content-box--resolve mb-4">
          <div class="step-content-box__accent"></div>
          <div class="step-content-box__body">
            <div class="scenario-content-layout">
              <div class="step-content-box__icon-wrap mr-3 mt-0.5">
                <%= icon "check-circle", class: "icon icon--sm" %>
              </div>
              <div class="flex-1">
                <h3 class="step-content-box__label">Resolution</h3>
                <% if @current_step.respond_to?(:resolution_type) && @current_step.resolution_type.present? %>
                  <p class="text-sm mb-2">
                    <strong>Type:</strong>
                    <%
                      res_mod = case @current_step.resolution_type
                      when "success" then "badge--resolve"
                      when "failure" then "badge--alert"
                      when "transfer", "ticket" then "badge--info"
                      when "manager_escalation" then "badge--warning"
                      else ""
                      end
                    %>
                    <span class="badge <%= res_mod %>"><%= @current_step.resolution_type&.titleize %></span>
                  </p>
                <% end %>
                <% if @current_step.respond_to?(:resolution_description) %>
                  <% desc = @current_step.resolution_description %>
                  <% if desc.present? %>
                    <div class="text-sm mb-2"><%= desc.is_a?(String) ? desc : render_step_content(@current_step, 'description', @scenario.results || {}) %></div>
                  <% end %>
                <% end %>
              </div>
            </div>
          </div>
        </div>

        <%= form_with url: player_scenario_next_path(@scenario), method: :post do |f| %>
          <% if @current_step.respond_to?(:notes_required) && @current_step.notes_required %>
            <div class="form-group mb-3">
              <label class="form-label is-required">Resolution Notes</label>
              <%= f.text_area :resolution_notes, class: "form-input", rows: 3,
                  required: true, aria: { required: true, describedby: "resolution-notes-error" },
                  placeholder: "Add notes about this resolution..." %>
              <span id="resolution-notes-error" class="form-error" style="display: none;">Resolution notes are required</span>
            </div>
          <% end %>
          <input type="hidden" name="answer" value="">
          <div class="scenario-button-bar">
            <div>
              <%= player_back_button(@scenario) %>
            </div>
            <div class="scenario-btn-group">
              <% if current_user %>
                <%= link_to "Cancel", play_path, class: "scenario-btn-cancel", data: { turbo_confirm: "Are you sure you want to cancel? Your progress will be lost." } %>
              <% end %>
              <%= f.submit "Complete Workflow", class: "btn btn--positive" %>
            </div>
          </div>
        <% end %>

      <% when "sub_flow" %>
        <%= form_with url: player_scenario_next_path(@scenario), method: :post, data: { controller: "auto-advance" } do |form| %>
          <%= form.hidden_field :answer, value: "" %>
        <% end %>

      <% when "form" %>
        <% if @current_step.instructions.present? %>
          <div class="step-content-box step-content-box--form mb-4">
            <div class="step-content-box__accent"></div>
            <div class="step-content-box__body">
              <div class="scenario-content-layout">
                <div class="step-content-box__icon-wrap mr-3 mt-0.5">
                  <%= icon "document-text", class: "icon icon--sm" %>
                </div>
                <div class="flex-1">
                  <h3 class="step-content-box__label">Instructions</h3>
                  <div class="text-sm"><%= render_step_content(@current_step, 'instructions', @scenario.results || {}) %></div>
                </div>
              </div>
            </div>
          </div>
        <% end %>
        <%= form_with url: player_scenario_next_path(@scenario), method: :post, class: "space-y-4" do |form| %>
          <%= render "scenarios/form_step", step: @current_step %>
          <div class="scenario-button-bar">
            <div>
              <%= player_back_button(@scenario) %>
            </div>
            <div class="scenario-btn-group">
              <% if current_user %>
                <%= link_to "Cancel", play_path, class: "scenario-btn-cancel", data: { turbo_confirm: "Are you sure you want to cancel? Your progress will be lost." } %>
              <% end %>
              <%= form.submit "Submit Form", class: "btn btn--primary" %>
            </div>
          </div>
        <% end %>

      <% else %>
        <div class="scenario-button-bar">
          <div>
            <%= player_back_button(@scenario) %>
          </div>
          <div class="scenario-btn-group">
            <% if current_user %>
              <%= link_to "Cancel", play_path, class: "scenario-btn-cancel", data: { turbo_confirm: "Are you sure you want to cancel? Your progress will be lost." } %>
            <% end %>
            <%= button_to "Continue", player_scenario_next_path(@scenario), method: :post, params: { answer: "" }, class: "btn btn--primary" %>
          </div>
        </div>
      <% end %>

      <%# ── Media Attachments ── %>
      <% if @current_step.respond_to?(:media_attachments) && @current_step.media_attachments.any? %>
        <%= render "steps/media_attachments", step: @current_step %>
      <% end %>
    </div>
  </div>
<% else %>
  <div class="card">
    <div class="card__body" style="padding: var(--space-8); text-align: center;">
      <p style="color: var(--color-ink-muted); margin-bottom: var(--space-4);">This workflow has no steps available.</p>
      <%= link_to "Back to Workflows", play_path, class: "btn btn--primary btn--sm" %>
    </div>
  </div>
<% end %>
