<% content_for(:title) { "Play — TurboFlows" } %>

<div class="player-index" data-controller="player-filter">
  <div class="player-index__header">
    <h1 class="player-index__title">Workflows</h1>
    <p class="player-index__subtitle">Choose a workflow to begin</p>
  </div>

  <% if @workflows.any? %>
    <%# ── Search Filter ── %>
    <div class="player-search">
      <svg class="player-search__icon icon icon--sm" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
        <circle cx="11" cy="11" r="8" />
        <path stroke-linecap="round" d="m21 21-4.35-4.35" />
      </svg>
      <input type="text"
             class="player-search__input"
             placeholder="Search workflows..."
             autocomplete="off"
             aria-label="Search workflows"
             data-player-filter-target="input"
             data-action="input->player-filter#filter">
    </div>

    <%# ── Workflow Grid ── %>
    <div class="player-workflow-grid">
      <% @workflows.each do |workflow| %>
        <%
          first_step = workflow.start_step || workflow.steps.first
          step_type = first_step&.step_type || "question"
        %>
        <%= button_to play_workflow_path(workflow), method: :post,
              class: "player-workflow-card player-workflow-card--#{step_type}",
              data: {
                player_filter_target: "card",
                title: workflow.title,
                description: workflow.description_text.to_s
              } do %>
          <div class="player-workflow-card__body">
            <div style="margin-bottom: var(--space-2);">
              <span class="badge badge--<%= step_type %>"><%= step_type.titleize.gsub("Sub Flow", "Sub-Flow") %></span>
            </div>
            <div class="player-workflow-card__title"><%= workflow.title %></div>
            <% if workflow.description.present? %>
              <p class="player-workflow-card__desc"><%= truncate(strip_tags(workflow.description.to_s), length: 120) %></p>
            <% end %>
            <div class="player-workflow-card__footer">
              <span class="player-workflow-card__meta">
                <svg class="icon icon--xs" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2" />
                </svg>
                <%= workflow.steps.size %> steps
              </span>
              <% if workflow.versions.any? %>
                <span class="badge badge--subtle">v<%= workflow.versions.last.version_number %></span>
              <% end %>
            </div>
            <% if workflow.tags.any? %>
              <div class="player-workflow-card__tags">
                <% workflow.tags.first(3).each do |tag| %>
                  <span class="tag-pill"><%= tag.name %></span>
                <% end %>
                <% if workflow.tags.size > 3 %>
                  <span class="player-workflow-card__meta">+<%= workflow.tags.size - 3 %> more</span>
                <% end %>
              </div>
            <% end %>
          </div>
          <div class="player-workflow-card__arrow">
            <svg class="icon icon--sm" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
            </svg>
          </div>
        <% end %>
      <% end %>
    </div>

    <%# ── No Results (hidden by default, shown by filter controller) ── %>
    <div class="player-empty" hidden data-player-filter-target="empty">
      <svg class="player-empty__icon" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5">
        <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
      </svg>
      <p class="player-empty__text">No workflows match your search.</p>
    </div>

  <% else %>
    <div class="player-empty">
      <svg class="player-empty__icon" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5">
        <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 00-3.375-3.375h-1.5A1.125 1.125 0 0113.5 7.125v-1.5a3.375 3.375 0 00-3.375-3.375H8.25m0 12.75h7.5m-7.5 3H12M10.5 2.25H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 00-9-9z" />
      </svg>
      <p class="player-empty__text">No published workflows available yet.</p>
    </div>
  <% end %>
</div>
