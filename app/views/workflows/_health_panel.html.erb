<%#
  Health Panel — workflow validation results in the builder panel.

  Local variables:
  - workflow: Workflow object
  - health: WorkflowHealthCheck::Result
%>
<turbo-frame id="builder-panel">
  <div class="builder__panel-header">
    <div class="builder__panel-header-left">
      <strong>Health</strong>
    </div>
    <button class="builder__panel-close"
            data-action="click->builder#closePanel"
            title="Close panel">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M18 6 6 18"/><path d="m6 6 12 12"/>
      </svg>
    </button>
  </div>

  <div class="builder__panel-body">
    <% if health.clean? %>
      <%# === All Clear === %>
      <div class="health-panel__clean">
        <svg class="health-panel__clean-icon" width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/>
          <polyline points="22 4 12 14.01 9 11.01"/>
        </svg>
        <h3 class="health-panel__clean-title">All checks passing</h3>
        <ul class="health-panel__checklist">
          <li>Reachability from start</li>
          <li>No cycles detected</li>
          <li>All terminals are Resolve steps</li>
          <li>No circular sub-flows</li>
          <li>All required fields present</li>
        </ul>
      </div>
    <% else %>
      <%# === Summary === %>
      <div class="health-panel__summary">
        <% if health.summary[:errors] > 0 %>
          <span class="health-panel__count health-panel__count--error">
            <%= health.summary[:errors] %> <%= "error".pluralize(health.summary[:errors]) %>
          </span>
        <% end %>
        <% if health.summary[:warnings] > 0 %>
          <span class="health-panel__count health-panel__count--warning">
            <%= health.summary[:warnings] %> <%= "warning".pluralize(health.summary[:warnings]) %>
          </span>
        <% end %>
      </div>

      <%# === Errors Section === %>
      <% errors = health.issues.select { |_uuid, issues| issues.any? { |i| i[:severity] == :error } } %>
      <% if errors.any? %>
        <div class="health-panel__section">
          <h4 class="health-panel__section-title health-panel__section-title--error">Errors</h4>
          <% errors.each do |uuid, issues| %>
            <% step = workflow.steps.find { |s| s.uuid == uuid } %>
            <% issues.select { |i| i[:severity] == :error }.each do |issue| %>
              <div class="health-panel__issue health-panel__issue--error">
                <div class="health-panel__issue-icon">
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/>
                  </svg>
                </div>
                <div class="health-panel__issue-body">
                  <div class="health-panel__issue-message"><%= issue[:message] %></div>
                  <% if step %>
                    <button type="button"
                            class="health-panel__issue-step"
                            data-action="click->builder#openStep"
                            data-builder-url-param="<%= panel_edit_workflow_step_path(workflow, step) %>">
                      Step <%= step.position %>: <%= step.title.presence || "Untitled" %>
                    </button>
                  <% end %>
                </div>
                <% if issue[:fixable] && issue[:fix_type] %>
                  <%= button_to workflow_health_fix_path(workflow),
                      params: { fix_type: issue[:fix_type], step_uuid: uuid },
                      method: :post,
                      class: "btn btn--sm health-panel__issue-fix",
                      data: { turbo_stream: true,
                              turbo_confirm: issue[:fix_type] == "connect_next" ?
                                "Connect \"#{step&.title}\" to the next step?" :
                                "Add a new Resolve step after \"#{step&.title}\"?" } do %>
                    Fix
                  <% end %>
                <% end %>
              </div>
            <% end %>
          <% end %>
        </div>
      <% end %>

      <%# === Warnings Section === %>
      <% warnings = health.issues.select { |_uuid, issues| issues.any? { |i| i[:severity] == :warning } } %>
      <% if warnings.any? %>
        <div class="health-panel__section">
          <h4 class="health-panel__section-title health-panel__section-title--warning">Warnings</h4>
          <% warnings.each do |uuid, issues| %>
            <% step = workflow.steps.find { |s| s.uuid == uuid } %>
            <% issues.select { |i| i[:severity] == :warning }.each do |issue| %>
              <div class="health-panel__issue health-panel__issue--warning">
                <div class="health-panel__issue-icon">
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/>
                  </svg>
                </div>
                <div class="health-panel__issue-body">
                  <div class="health-panel__issue-message"><%= issue[:message] %></div>
                  <% if step %>
                    <button type="button"
                            class="health-panel__issue-step"
                            data-action="click->builder#openStep"
                            data-builder-url-param="<%= panel_edit_workflow_step_path(workflow, step) %>">
                      Step <%= step.position %>: <%= step.title.presence || "Untitled" %>
                    </button>
                  <% end %>
                </div>
                <% if issue[:fixable] && issue[:fix_type] %>
                  <%= button_to workflow_health_fix_path(workflow),
                      params: { fix_type: issue[:fix_type], step_uuid: uuid },
                      method: :post,
                      class: "btn btn--sm health-panel__issue-fix",
                      data: { turbo_stream: true,
                              turbo_confirm: issue[:fix_type] == "connect_next" ?
                                "Connect \"#{step&.title}\" to the next step?" :
                                "Add a new Resolve step after \"#{step&.title}\"?" } do %>
                    Fix
                  <% end %>
                <% end %>
              </div>
            <% end %>
          <% end %>
        </div>
      <% end %>

      <%# === Passing Checks === %>
      <div class="health-panel__section">
        <h4 class="health-panel__section-title health-panel__section-title--passing">Passing</h4>
        <ul class="health-panel__checklist health-panel__checklist--passing">
          <% passing_checks = [] %>
          <% graph_errors = health.issues.values.flatten.map { |i| i[:message] } %>
          <% passing_checks << "Reachability from start" unless graph_errors.any? { |m| m.include?("reachable") } %>
          <% passing_checks << "No cycles detected" unless graph_errors.any? { |m| m.include?("Cycle") } %>
          <% passing_checks << "All terminals are Resolve steps" unless graph_errors.any? { |m| m.include?("Resolve") } %>
          <% passing_checks << "No circular sub-flows" unless graph_errors.any? { |m| m.include?("sub-flow") || m.include?("Sub-flow") } %>
          <% passing_checks << "All required fields present" unless graph_errors.any? { |m| m.include?("required") } %>
          <% if passing_checks.any? %>
            <% passing_checks.each do |check| %>
              <li><%= check %></li>
            <% end %>
          <% else %>
            <li class="health-panel__checklist--none">No checks passing yet</li>
          <% end %>
        </ul>
      </div>
    <% end %>
  </div>
</turbo-frame>
