<%#
  Health Panel — workflow validation results in the builder panel.
  Wraps _health_panel_inner in a turbo-frame for frame loads (via src).

  Local variables:
  - workflow: Workflow object
  - health: WorkflowHealthCheck::Result
%>
<turbo-frame id="builder-panel"
              data-builder-target="panel"
              data-action="turbo:frame-load->builder#panelLoaded">
  <%= render "workflows/health_panel_inner", workflow: workflow, health: health %>
</turbo-frame>
