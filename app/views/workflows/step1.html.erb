<div class="page-content" style="max-width: 48rem; margin: 0 auto;">
  <div class="mb-6">
    <h1 class="page-title">Create Workflow</h1>
    <p class="text-sm mt-1">Step 1 of 3: Name your workflow and assign it to a group.</p>
  </div>

  <%= render partial: "wizard_progress", locals: { current_step: 1, workflow: @workflow } %>

  <% if @workflow.draft? && @workflow.created_at.present? && @workflow.created_at < 5.days.ago %>
    <div class="alert alert--warning mb-6">
      <div class="flex items-start gap-3">
        <svg class="icon icon--sm flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"/>
        </svg>
        <div>
          <h3 class="font-medium">Draft Expiration Warning</h3>
          <p class="text-sm mt-1">
            This draft will expire in <%= distance_of_time_in_words(@workflow.created_at + 7.days, Time.current) %>.
            Consider publishing it or saving your changes soon.
          </p>
        </div>
      </div>
    </div>
  <% end %>

  <%= form_with model: @workflow, url: update_step1_workflow_path(@workflow), method: :patch, local: true, data: { turbo: false, controller: "wizard-step1-validation" }, html: { class: "card", style: "overflow: visible;" } do |form| %>
    <%= render partial: "shared/error_messages", locals: { object: @workflow, container_class: "card__body" } %>

    <div class="card__body" style="display: flex; flex-direction: column; gap: 1.5rem;">
      <div class="form-group">
        <%= form.label :title, class: "form-label" %>
        <%= form.text_field :title, maxlength: 100, class: "form-input", placeholder: "Enter workflow title", required: true,
            data: { wizard_step1_validation_target: "titleInput", action: "input->wizard-step1-validation#validate" } %>
        <span class="form-hint" data-wizard-step1-validation-target="counter">0/100 characters</span>
      </div>

      <div class="form-group">
        <%= form.label :description, class: "form-label" %>
        <%= form.rich_text_area :description %>
      </div>

      <% if @accessible_groups&.any? %>
        <div class="relative" style="z-index: 10;">
          <%= render partial: "workflows/group_selector", locals: { selected_group_ids: @selected_group_ids || [] } %>
        </div>
      <% end %>

      <%# Folder selector (only shown when primary group has folders) %>
      <% if @selected_group_ids.present? %>
        <% primary_group = Group.find_by(id: @selected_group_ids.first) %>
        <% if primary_group&.folders&.any? %>
          <div class="form-group">
            <label class="form-label">Folder (optional)</label>
            <select name="workflow[folder_id]" class="form-select">
              <option value="">Uncategorized</option>
              <% primary_group.folders.ordered.each do |folder| %>
                <option value="<%= folder.id %>"><%= folder.name %></option>
              <% end %>
            </select>
            <p class="form-hint">Organize this workflow into a folder within the group.</p>
          </div>
        <% end %>
      <% end %>

      <%# Graph Mode Toggle - Hidden when graph mode is the default %>
      <% if show_graph_mode_toggle? %>
        <div class="card card--muted p-4">
          <div class="flex items-center justify-between">
            <div class="flex items-center gap-2">
              <%= form.check_box :graph_mode, class: "form-checkbox", id: "workflow_graph_mode_step1" %>
              <%= form.label :graph_mode, class: "form-label mb-0" do %>
                Enable Graph Mode
                <span class="badge ml-1">Beta</span>
              <% end %>
            </div>
            <% if @workflow.graph_mode? %>
              <span class="badge badge--published text-xs">Active</span>
            <% end %>
          </div>
          <p class="form-hint mt-2">
            Graph mode enables advanced DAG-based workflows with complex branching, sub-flows, and visual connection editing.
            Steps can connect to any other step, not just the next one in sequence.
          </p>
        </div>
      <% else %>
        <%= form.hidden_field :graph_mode, value: @workflow.graph_mode? %>
      <% end %>

      <div class="flex justify-between items-center pt-4" style="border-top: 1px solid var(--color-border);">
        <div class="flex items-center gap-3">
          <%= link_to "Cancel", workflows_path, class: "btn btn--plain" %>
          <%= link_to "Browse Templates", templates_path, class: "btn btn--plain btn--sm" %>
        </div>
        <%= form.submit "Next: Add Steps", class: "btn btn--primary",
            data: { wizard_step1_validation_target: "submitButton" } %>
      </div>
    </div>
  <% end %>
</div>
