<%#
  Step Outline Sidebar

  Sprint 3: Navigation & Visual Improvements
  Sidebar navigation outline for long workflows.
  Shows all steps with quick navigation and status indicators.

  Local variables:
  - workflow: The workflow object
  - show_by_default: Whether to show the sidebar by default (optional, default: true for >5 steps)
%>

<% step_count = workflow&.steps&.size.to_i %>
<% show_by_default = local_assigns.fetch(:show_by_default, step_count > 5) %>

<div data-controller="step-outline"
     class="step-outline-sidebar">

  <%# Sidebar Container %>
  <div data-step-outline-target="outlineContainer"
       class="card" style="width: 16rem; display: flex; flex-direction: column; overflow: hidden;">

    <%# Header %>
    <div class="card__header flex items-center justify-between">
      <div class="flex items-center gap-2">
        <svg class="icon icon--sm" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 10h16M4 14h16M4 18h16"/>
        </svg>
        <span class="font-semibold text-sm">Step Outline</span>
      </div>
      <span data-step-count class="badge">
        <%= step_count %> step<%= step_count != 1 ? 's' : '' %>
      </span>
    </div>

    <%# Quick Actions %>
    <div class="flex gap-2 px-3 py-2" style="border-bottom: 1px solid var(--color-border);" data-controller="step-controls">
      <button type="button"
              data-action="click->step-controls#expandAll"
              class="btn btn--plain btn--sm flex-1"
              title="Expand all steps">
        Expand
      </button>
      <button type="button"
              data-action="click->step-controls#collapseAll"
              class="btn btn--plain btn--sm flex-1"
              title="Collapse all steps">
        Collapse
      </button>
    </div>

    <%# Step List %>
    <div data-step-outline-target="stepList"
         class="flex-1 overflow-y-auto p-2" style="display: flex; flex-direction: column; gap: 0.25rem;">
      <% if step_count > 0 %>
        <% workflow.steps.order(:position).each_with_index do |step, index| %>
          <%
            step_type = step_field(step, 'type')
            step_title = step.title.presence || "Untitled #{step_type&.titleize}"
            step_id = step.uuid || "step-#{index}"

            # Check for incomplete steps
            has_warning = case step_type
              when 'question' then step.respond_to?(:question) && step.question.blank?
              when 'action' then step.respond_to?(:instructions) && step.instructions.blank?
              else false
            end

            # Type colors using CSS custom properties
            type_bg_styles = {
              'question' => 'background-color: #f1f5f9; color: #475569;',
              'action' => 'background-color: #d1fae5; color: #059669;',
              'sub_flow' => 'background-color: #e0e7ff; color: #4338ca;',
              'message' => 'background-color: #cffafe; color: #0891b2;',
              'escalate' => 'background-color: #ffedd5; color: #ea580c;',
              'resolve' => 'background-color: #dcfce7; color: #16a34a;'
            }

            type_icons = {
              'question' => '?',
              'action' => '!',
              'sub_flow' => '↪',
              'message' => 'i',
              'escalate' => '↑',
              'resolve' => '✓'
            }
          %>
          <button type="button"
                  class="step-outline-item"
                  data-action="click->step-outline#scrollToStep"
                  data-step-outline-target="outlineItem"
                  data-step-index="<%= index %>"
                  data-step-id="<%= step_id %>">
            <div class="flex items-center gap-2">
              <span class="step-card__number flex-shrink-0"
                    style="<%= type_bg_styles[step_type] || 'background-color: #f3f4f6; color: #374151;' %>">
                <%= index + 1 %>
              </span>
              <span class="flex-shrink-0 font-bold" title="<%= step_type&.titleize %>">
                <%= type_icons[step_type] || '#' %>
              </span>
              <span class="flex-1 text-sm truncate">
                <%= step_title %>
              </span>
              <% if has_warning %>
                <span class="flex-shrink-0" title="Incomplete" style="color: var(--color-warning);">!</span>
              <% end %>
            </div>
          </button>
        <% end %>
      <% end %>
    </div>

    <%# Empty State %>
    <div data-step-outline-target="emptyState"
         class="<%= step_count > 0 ? 'hidden' : '' %> flex-1 text-center p-4"
         style="display: flex; flex-direction: column; align-items: center; justify-content: center;">
      <svg class="icon icon--xl mx-auto mb-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"/>
      </svg>
      <p class="text-sm">No steps yet</p>
      <p class="form-hint mt-1">Add steps using the buttons above</p>
    </div>

    <%# Footer with help %>
    <div class="card__footer">
      <p class="form-hint mb-0">
        Click a step to jump to it
      </p>
    </div>
  </div>
</div>
