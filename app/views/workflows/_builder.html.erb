<%#
  Builder — unified workflow creation and editing interface.

  Local variables:
  - workflow: Workflow object
  - steps: ordered step collection (preloaded with transitions)
  - mode: "view" or "edit" (default "view")
%>
<% mode = local_assigns.fetch(:mode, "view") %>

<%= turbo_stream_from "workflow_#{workflow.id}" %>

<div class="builder"
     data-controller="builder step-warnings"
     data-builder-mode-value="<%= mode %>"
     data-builder-workflow-id-value="<%= workflow.id %>"
     data-step-warnings-health-url-value="<%= workflow_health_path(workflow, format: :json) %>"
     data-step-warnings-fix-url-value="<%= workflow_health_fix_path(workflow) %>"
     data-step-warnings-mode-value="<%= mode %>"
     data-builder-health-url-value="<%= workflow_health_path(workflow) %>">

  <%# === Header === %>
  <div class="builder__header">
    <div class="builder__header-left">
      <div class="builder__title-wrapper">
        <input type="text"
               class="builder__title"
               value="<%= workflow.title %>"
               data-builder-target="titleInput"
               data-action="blur->builder#saveTitle change->builder#saveTitle"
               data-url="<%= workflow_path(workflow) %>"
               <%= "readonly" if mode == "view" %>
               placeholder="Workflow title...">
        <% if mode == "edit" %>
          <%= icon "pencil", class: "builder__title-pencil" %>
        <% end %>
      </div>

      <span class="builder__status builder__status--<%= workflow.status %>">
        <%= workflow.status.titleize %>
      </span>

      <%= render "workflows/autosave_status", status: :saved %>
    </div>

    <div class="flex items-center gap-2">
      <% if mode == "view" && workflow.can_be_edited_by?(current_user) %>
        <%= link_to workflow_path(workflow, edit: true), class: "btn btn--secondary btn--sm" do %>
          Edit
        <% end %>
      <% end %>

      <% if mode == "view" %>
        <%= link_to new_workflow_scenario_path(workflow), class: "btn btn--positive btn--sm" do %>
          Run Scenario
        <% end %>
      <% end %>

      <% if mode == "edit" %>
        <span class="builder__publish-wrapper">
          <%= button_to workflow_publishing_path(workflow), method: :post,
              class: "btn btn--positive btn--sm builder__edit-only",
              data: { turbo_stream: true } do %>
            Publish
          <% end %>
          <span class="builder__publish-badge" data-step-warnings-target="publishBadge" hidden></span>
        </span>
      <% end %>

      <% if workflow.can_be_viewed_by?(current_user) %>
        <%= link_to workflow_export_path(workflow), class: "btn btn--plain btn--sm" do %>
          Export
        <% end %>
      <% end %>
    </div>
  </div>

  <%# === Toolbar === %>
  <div class="builder__toolbar">
    <span class="builder__toolbar-left" id="step-count">
      <span id="step-count-text"><%= pluralize(steps.size, "step") %></span>
      <button type="button" class="builder__toolbar-issues" data-step-warnings-target="toolbarIssues" data-action="click->builder#openHealth" hidden aria-live="polite"></button>
    </span>
    <div class="builder__toolbar-right">
      <button class="builder__toolbar-btn"
              data-action="click->builder#openFlowDiagram"
              data-builder-flow-url-value="<%= workflow_flow_diagram_path(workflow) %>">
        &#9724; View Flow
      </button>
      <div class="builder__toolbar-item builder__edit-only"
           data-controller="template-picker"
           data-template-picker-workflow-id-value="<%= workflow.id %>">
        <button class="builder__toolbar-btn"
                data-action="click->template-picker#toggle"
                type="button">
          Templates
        </button>
        <div class="builder__template-popover"
             data-template-picker-target="popover"
             hidden>
          <div class="builder__template-popover-header">Start from template</div>
          <% WorkflowTemplate.all.each do |key, template| %>
            <button class="builder__template-popover-item"
                    data-action="click->template-picker#apply"
                    data-template-key="<%= key %>"
                    data-template-name="<%= template['name'] %>"
                    type="button"
                    style="--template-hue: <%= template['hue'] %>">
              <span class="builder__template-dot"></span>
              <%= template["name"] %>
            </button>
          <% end %>
          <div class="builder__template-popover-footer">Replaces current steps</div>
        </div>
      </div>
      <button class="builder__toolbar-btn"
              data-action="click->builder#openSettings"
              data-builder-settings-url-value="<%= workflow_settings_path(workflow) %>">
        &#9881; Details
      </button>
    </div>
  </div>

  <%# === Main Area === %>
  <div class="builder__main">
    <%# Step List %>
    <%= render "workflows/step_list", workflow: workflow, steps: steps %>

    <%# Slide-In Panel (empty frame, loaded on demand) %>
    <div class="builder__panel">
      <turbo-frame id="builder-panel"
                   data-builder-target="panel"
                   data-action="turbo:frame-load->builder#panelLoaded">
      </turbo-frame>
    </div>
  </div>
</div>
