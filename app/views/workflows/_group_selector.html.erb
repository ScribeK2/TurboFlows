<div class="group-selector-container relative z-10" data-controller="group-selector">
  <label class="form-label">
    Group Assignment
  </label>
  <p class="form-hint">
    Select one or more groups to organize this workflow. The first selected group will be the primary group.
  </p>

  <div class="relative z-100">
    <div class="group-selector-input-container">
      <button type="button"
              data-action="click->group-selector#toggle"
              class="form-input text-left w-full flex items-center justify-between">
        <span data-group-selector-target="buttonText" class="text-sm font-medium">Select groups...</span>
        <svg class="icon icon--sm" data-group-selector-target="chevron" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
        </svg>
      </button>

      <div class="is-hidden card" style="position: absolute; top: 100%; left: 0; right: 0; margin-top: 0.25rem; z-index: 100; max-height: 16rem; overflow-y: auto;"
           data-group-selector-target="dropdown">
        <div class="p-3 border-b">
          <input type="text"
                 data-group-selector-target="search"
                 data-action="input->group-selector#filter"
                 placeholder="Search groups..."
                 class="form-input w-full">
        </div>
        <div class="p-2" data-group-selector-target="tree">
          <% if @accessible_groups.any? %>
            <% @accessible_groups.roots.includes(:children).order(:position, :name).each do |root_group| %>
              <%= render partial: "workflows/group_option", locals: { group: root_group, level: 0, selected_ids: selected_group_ids || [] } %>
            <% end %>
          <% else %>
            <div class="px-3 py-4 text-sm text-center">
              <svg class="icon icon--lg mx-auto mb-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 7v10a2 2 0 002 2h14a2 2 0 002-2V9a2 2 0 00-2-2h-6l-2-2H5a2 2 0 00-2 2z" />
              </svg>
              No groups available. Admins can create groups in the admin panel.
            </div>
          <% end %>
        </div>
      </div>
    </div>

    <div class="mt-2 flex flex-wrap gap-2" data-group-selector-target="selected">
      <% if selected_group_ids.present? %>
        <% @accessible_groups.where(id: selected_group_ids).each do |group| %>
          <span class="badge badge--group inline-flex items-center gap-2" data-selected-id="<%= group.id %>">
            <%= group.name %>
            <button type="button"
                    data-action="click->group-selector#remove"
                    data-group-id="<%= group.id %>"
                    class="badge__remove">
              <svg class="icon icon--xs" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
              </svg>
            </button>
            <%= hidden_field_tag "workflow[group_ids][]", group.id %>
          </span>
        <% end %>
      <% end %>
    </div>
  </div>
</div>
