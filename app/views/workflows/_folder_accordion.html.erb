<%# Renders a single folder as an expandable accordion
    Locals: folder, workflows (ActiveRecord relation), selected_group %>
<details class="folder-accordion card mb-3" data-controller="folder-accordion">
  <summary class="folder-accordion__summary"
           data-action="toggle->folder-accordion#toggle">
    <div class="flex items-center gap-3">
      <%# Chevron icon — rotates 90deg when open %>
      <%= icon "chevron-right", class: "icon icon--sm folder-accordion__chevron" %>

      <%# Folder icon %>
      <%= icon "folder", class: "icon icon--sm" %>

      <span class="font-semibold"><%= folder.name %></span>
    </div>

    <span class="badge">
      <%= pluralize(workflows.size, "workflow") %>
    </span>
  </summary>

  <%# Expanded content: workflow cards %>
  <div class="folder-accordion__body">
    <% if workflows.any? %>
      <ul class="wf-list">
        <% workflows.each_with_index do |workflow, index| %>
          <%= render partial: "workflows/workflow_list_item", locals: { workflow: workflow, index: index } %>
        <% end %>
      </ul>
    <% else %>
      <div class="text-center py-6 text-sm">
        No workflows in this folder.
      </div>
    <% end %>
  </div>
</details>
