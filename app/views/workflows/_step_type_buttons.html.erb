<%#
  Step Type Buttons — POST to StepsController#create to add a new step.

  Local variables:
  - workflow: Workflow object
%>
<div class="wf-steps-header">
  <label class="form-label mb-0">
    Workflow Steps
    <% if workflow.steps_count > 0 %>
      <span class="text-xs ml-2">(<%= workflow.steps_count %> step<%= workflow.steps_count != 1 ? 's' : '' %>)</span>
    <% end %>
  </label>
  <div class="wf-btn-group">
    <%= button_to "Question", workflow_steps_path(workflow, step_type: "question"),
        method: :post, class: "btn btn--secondary btn--sm",
        form: { data: { turbo_stream: true } } %>
    <%= button_to "Message", workflow_steps_path(workflow, step_type: "message"),
        method: :post, class: "btn btn--sm",
        style: "background: var(--step-message-color, #06b6d4); color: #fff;",
        form: { data: { turbo_stream: true } } %>
    <%= button_to "Action", workflow_steps_path(workflow, step_type: "action"),
        method: :post, class: "btn btn--positive btn--sm",
        form: { data: { turbo_stream: true } } %>
    <% if workflow.graph_mode? %>
      <%= button_to "Escalate", workflow_steps_path(workflow, step_type: "escalate"),
          method: :post, class: "btn btn--sm",
          style: "background: var(--step-escalate-color, #f97316); color: #fff;",
          form: { data: { turbo_stream: true } } %>
      <%= button_to "Resolve", workflow_steps_path(workflow, step_type: "resolve"),
          method: :post, class: "btn btn--sm",
          style: "background: var(--step-resolve-color, #22c55e); color: #fff;",
          form: { data: { turbo_stream: true } } %>
    <% end %>
    <%= button_to "Sub-flow", workflow_steps_path(workflow, step_type: "sub_flow"),
        method: :post, class: "btn btn--sm",
        style: "background: var(--step-sub-flow-color, #6366f1); color: #fff;",
        form: { data: { turbo_stream: true } } %>
  </div>
</div>
