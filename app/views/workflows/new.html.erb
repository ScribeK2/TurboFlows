<div class="page-content">
  <div class="mb-6">
    <h1 class="page-title">New Workflow</h1>
    <p class="text-sm mt-1">Create a new workflow by adding steps below.</p>
  </div>

  <%= form_with model: @workflow, local: true, class: "card" do |form| %>
    <% if @workflow.errors.any? %>
      <div class="card__body">
        <div class="alert alert--error">
          <h3 class="font-medium mb-1">
            <%= pluralize(@workflow.errors.count, "error") %> prohibited this workflow from being saved:
          </h3>
          <ul class="list-disc pl-5">
            <% @workflow.errors.full_messages.each do |message| %>
              <li class="text-sm"><%= message %></li>
            <% end %>
          </ul>
        </div>
      </div>
    <% end %>

    <div class="card__body flex-col-gap-6">
      <div class="form-group">
        <%= form.label :title, class: "form-label" %>
        <%= form.text_field :title, class: "form-input" %>
      </div>

      <div class="form-group">
        <%= form.label :description, class: "form-label" %>
        <%= form.rich_text_area :description %>
      </div>

      <% if @accessible_groups&.any? %>
        <%= render partial: "workflows/group_selector", locals: { selected_group_ids: [] } %>
      <% end %>

      <%= form.hidden_field :graph_mode, value: true %>

      <div data-controller="workflow-builder" id="workflow-builder-container" data-workflow-builder-graph-mode-value="false" data-workflow-builder-debug-value="<%= Rails.env.development? %>">
        <div class="flex justify-between items-center mb-4">
          <label class="form-label mb-0">Workflow Steps</label>
          <div class="flex gap-2 flex-wrap">
            <button type="button" data-action="click->workflow-builder#addStep" data-workflow-builder-type-param="question" class="btn btn--secondary btn--sm">Add Question</button>
            <button type="button" data-action="click->workflow-builder#addStep" data-workflow-builder-type-param="action" class="btn btn--positive btn--sm">Add Action</button>
            <button type="button" data-action="click->workflow-builder#addStep" data-workflow-builder-type-param="message" class="btn btn--sm btn--step-message">Add Message</button>
            <button type="button" data-action="click->workflow-builder#addStep" data-workflow-builder-type-param="sub_flow" data-step-type="sub_flow" class="btn btn--sm btn--step-subflow">Add Sub-flow</button>
          </div>
        </div>
        <div data-workflow-builder-target="container" class="wf-steps-container">
          <!-- Steps will be added here dynamically -->
        </div>
      </div>

      <div data-controller="flow-preview">
        <%= render partial: "flow_preview" %>
      </div>

      <%# Include step templates data for JavaScript %>
      <script type="application/json" id="step-templates-data">
        {
          "question": <%= raw json_escape(StepTemplate.all_for_type(:question).to_json) %>,
          "action": <%= raw json_escape(StepTemplate.all_for_type(:action).to_json) %>,
          "message": [],
          "sub_flow": []
        }
      </script>

      <div class="flex justify-end gap-3">
        <%= link_to "Cancel", workflows_path, class: "btn btn--plain" %>
        <%= form.submit "Create Workflow", class: "btn btn--primary" %>
      </div>
    </div>
  <% end %>
</div>
