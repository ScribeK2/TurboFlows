<div class="step-palette"
     data-visual-editor-target="palette">
  <p class="step-palette__heading">Step Types</p>

  <div draggable="true"
       data-step-type="question"
       data-action="dragstart->visual-editor#handlePaletteDragStart"
       class="step-palette__item">
    <span class="step-palette__icon step-palette__icon--question">?</span>
    <span class="step-palette__label">Question</span>
  </div>

  <div draggable="true"
       data-step-type="message"
       data-action="dragstart->visual-editor#handlePaletteDragStart"
       class="step-palette__item">
    <span class="step-palette__icon step-palette__icon--message">i</span>
    <span class="step-palette__label">Message</span>
  </div>

  <div draggable="true"
       data-step-type="action"
       data-action="dragstart->visual-editor#handlePaletteDragStart"
       class="step-palette__item">
    <span class="step-palette__icon step-palette__icon--action">!</span>
    <span class="step-palette__label">Action</span>
  </div>

  <div draggable="true"
       data-step-type="escalate"
       data-action="dragstart->visual-editor#handlePaletteDragStart"
       class="step-palette__item">
    <span class="step-palette__icon step-palette__icon--escalate">&uarr;</span>
    <span class="step-palette__label">Escalate</span>
  </div>

  <div draggable="true"
       data-step-type="resolve"
       data-action="dragstart->visual-editor#handlePaletteDragStart"
       class="step-palette__item">
    <span class="step-palette__icon step-palette__icon--resolve">&check;</span>
    <span class="step-palette__label">Resolve</span>
  </div>

  <div draggable="true"
       data-step-type="sub_flow"
       data-action="dragstart->visual-editor#handlePaletteDragStart"
       class="step-palette__item">
    <span class="step-palette__icon step-palette__icon--sub-flow">&hookleftarrow;</span>
    <span class="step-palette__label">Sub-flow</span>
  </div>
</div>
