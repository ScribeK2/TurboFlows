<div class="w-[200px] flex-shrink-0 border-r border-gray-200 dark:border-gray-700 bg-gray-50 dark:bg-gray-800/50 p-3 space-y-2 overflow-y-auto"
     data-visual-editor-target="palette">
  <p class="text-xs font-semibold text-gray-500 dark:text-gray-400 uppercase tracking-wider mb-3">Step Types</p>

  <div draggable="true"
       data-step-type="question"
       data-action="dragstart->visual-editor#handlePaletteDragStart"
       class="flex items-center gap-2 px-3 py-2 rounded-lg bg-white dark:bg-gray-700 border border-gray-200 dark:border-gray-600 shadow-sm cursor-grab active:cursor-grabbing hover:shadow-md transition-shadow">
    <span class="inline-flex items-center justify-center w-6 h-6 rounded-full bg-slate-600 text-white text-xs font-bold">?</span>
    <span class="text-sm font-medium text-gray-700 dark:text-gray-200">Question</span>
  </div>

  <div draggable="true"
       data-step-type="message"
       data-action="dragstart->visual-editor#handlePaletteDragStart"
       class="flex items-center gap-2 px-3 py-2 rounded-lg bg-white dark:bg-gray-700 border border-gray-200 dark:border-gray-600 shadow-sm cursor-grab active:cursor-grabbing hover:shadow-md transition-shadow">
    <span class="inline-flex items-center justify-center w-6 h-6 rounded-full bg-cyan-500 text-white text-xs font-bold">i</span>
    <span class="text-sm font-medium text-gray-700 dark:text-gray-200">Message</span>
  </div>

  <div draggable="true"
       data-step-type="action"
       data-action="dragstart->visual-editor#handlePaletteDragStart"
       class="flex items-center gap-2 px-3 py-2 rounded-lg bg-white dark:bg-gray-700 border border-gray-200 dark:border-gray-600 shadow-sm cursor-grab active:cursor-grabbing hover:shadow-md transition-shadow">
    <span class="inline-flex items-center justify-center w-6 h-6 rounded-full bg-emerald-500 text-white text-xs font-bold">!</span>
    <span class="text-sm font-medium text-gray-700 dark:text-gray-200">Action</span>
  </div>

  <div draggable="true"
       data-step-type="escalate"
       data-action="dragstart->visual-editor#handlePaletteDragStart"
       class="flex items-center gap-2 px-3 py-2 rounded-lg bg-white dark:bg-gray-700 border border-gray-200 dark:border-gray-600 shadow-sm cursor-grab active:cursor-grabbing hover:shadow-md transition-shadow">
    <span class="inline-flex items-center justify-center w-6 h-6 rounded-full bg-orange-500 text-white text-xs font-bold">&uarr;</span>
    <span class="text-sm font-medium text-gray-700 dark:text-gray-200">Escalate</span>
  </div>

  <div draggable="true"
       data-step-type="resolve"
       data-action="dragstart->visual-editor#handlePaletteDragStart"
       class="flex items-center gap-2 px-3 py-2 rounded-lg bg-white dark:bg-gray-700 border border-gray-200 dark:border-gray-600 shadow-sm cursor-grab active:cursor-grabbing hover:shadow-md transition-shadow">
    <span class="inline-flex items-center justify-center w-6 h-6 rounded-full bg-green-500 text-white text-xs font-bold">&check;</span>
    <span class="text-sm font-medium text-gray-700 dark:text-gray-200">Resolve</span>
  </div>

  <div draggable="true"
       data-step-type="sub_flow"
       data-action="dragstart->visual-editor#handlePaletteDragStart"
       class="flex items-center gap-2 px-3 py-2 rounded-lg bg-white dark:bg-gray-700 border border-gray-200 dark:border-gray-600 shadow-sm cursor-grab active:cursor-grabbing hover:shadow-md transition-shadow">
    <span class="inline-flex items-center justify-center w-6 h-6 rounded-full bg-indigo-500 text-white text-xs font-bold">&hookleftarrow;</span>
    <span class="text-sm font-medium text-gray-700 dark:text-gray-200">Sub-flow</span>
  </div>
</div>
