<%#
  Step Row — compact row for the builder step list.

  Local variables:
  - step: AR Step object
  - workflow: Workflow object
%>
<div class="builder__list-row"
     id="<%= dom_id(step) %>"
     data-step-id="<%= step.id %>"
     data-step-uuid="<%= step.uuid %>"
     data-step-type="<%= step.step_type %>"
     data-action="click->builder#openStep"
     data-builder-url-param="<%= panel_edit_workflow_step_path(workflow, step) %>"
     role="listitem">

  <%# Drag Handle (edit mode only) %>
  <span class="drag-handle builder__edit-only" title="Drag to reorder"
        data-controller="tooltip" data-tooltip-text-value="Drag to reorder">
    <svg class="icon icon--sm" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 8h16M4 16h16"/>
    </svg>
  </span>

  <%# Type Badge with Step Number %>
  <span class="builder__step-badge builder__step-badge--<%= step.step_type %>">
    <%= step.position %>
  </span>

  <%# Title %>
  <span class="builder__step-title">
    <%= step.title.presence || "Untitled #{step.step_type.titleize}" %>
  </span>

  <%# Type Label %>
  <span class="builder__step-type"><%= step_type_label(step.step_type) %></span>

  <%# Connection Hints + Status Pills %>
  <span class="builder__step-connections">
    <% if step == workflow.start_step %>
      <span class="step-pill step-pill--start">Start</span>
    <% end %>
    <% if step.terminal? %>
      <span class="step-pill step-pill--terminal">Terminal</span>
    <% end %>
    <% if step.transitions.loaded? ? step.transitions.any? : step.transitions.exists? %>
      <% targets = step.transitions.map { |t| t.target_step }.compact %>
      <% if targets.any? %>
        &rarr; <%= targets.map { |t| "Step #{t.position}" }.join(", ") %>
      <% end %>
    <% elsif !step.is_a?(Steps::Resolve) && !step.terminal? %>
      <span class="step-pill step-pill--warning">No connections</span>
    <% end %>
  </span>

  <%# Warning Icon (populated by step_warnings_controller.js) %>
  <span class="step-warning-icon" data-step-warnings-target="icon" data-step-uuid="<%= step.uuid %>" hidden></span>

  <%# Delete Button (edit mode only) %>
  <%= button_to workflow_step_path(workflow, step),
        method: :delete,
        data: { turbo_confirm: "Remove this step?", turbo_stream: true, action: "click->step-list#stopPropagation" },
        class: "builder__step-delete builder__edit-only btn btn--plain btn--sm",
        style: "color: var(--color-negative);",
        title: "Remove step" do %>
    <svg class="icon icon--sm" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
    </svg>
  <% end %>
</div>
