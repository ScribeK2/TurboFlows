<% if step_type == "question" %>
  <%= render partial: "question_fields", locals: { step: step, step_index: defined?(step_index) ? step_index : 0 } %>
<% elsif step_type == "action" %>
  <%= render partial: "action_fields", locals: { step: step, step_index: defined?(step_index) ? step_index : nil, workflow: workflow } %>
<% elsif step_type == "sub_flow" %>
  <%= render partial: "subflow_selector", locals: { step: step, index: defined?(step_index) ? step_index : nil } %>
<% elsif step_type == "message" %>
  <%= render partial: "message_fields", locals: { step: step, workflow: workflow } %>
<% elsif step_type == "escalate" %>
  <%= render partial: "escalate_fields", locals: { step: step, workflow: workflow } %>
<% elsif step_type == "resolve" %>
  <%= render partial: "resolve_fields", locals: { step: step } %>
<% elsif step_type.blank? %>
  <div class="text-sm text-yellow-600 bg-yellow-50 border border-yellow-200 rounded p-2 mb-2">
    <p class="font-semibold">Step type missing</p>
    <p class="text-xs">This step appears to be incomplete. Please remove and re-add it.</p>
  </div>
<% end %>
