<%# Message-specific fields partial %>
<%# Message steps display read-only information/guidance to the CSR %>

<div class="field-container">
  <div class="bg-cyan-50 dark:bg-cyan-900/20 border border-cyan-200 dark:border-cyan-800/30 rounded-lg p-3 mb-4">
    <div class="flex items-start">
      <svg class="w-5 h-5 text-cyan-600 dark:text-cyan-400 mr-2 mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
      </svg>
      <div class="flex-1">
        <p class="text-sm text-cyan-800 dark:text-cyan-300">
          <strong>Message Step:</strong> Display information or guidance to the CSR. This step auto-advances and doesn't require user input. Use <code class="px-1 py-0.5 bg-cyan-100 dark:bg-cyan-800 rounded text-xs">{{variable_name}}</code> to include dynamic content.
        </p>
      </div>
    </div>
  </div>

  <%# Content Field %>
  <div class="mb-4">
    <label class="block text-sm font-medium text-gray-700 dark:text-gray-200 mb-1">
      Message Content
      <span class="font-normal text-gray-500 dark:text-gray-400">(optional)</span>
    </label>
    <%= form_with model: [workflow, step], url: workflow_step_path(workflow, step), method: :patch, local: true do |f| %>
      <%= f.rich_text_area :content,
          data: { step_form_target: "field", variable_autocomplete_target: "input" } %>
    <% end %>
  </div>

  <%# Can Resolve Checkbox %>
  <div class="mb-4" data-controller="checkbox-hidden">
    <label class="flex items-center cursor-pointer">
      <input type="hidden" name="workflow[steps][][can_resolve]"
             value="<%= step['can_resolve'] == true || step['can_resolve'] == 'true' ? 'true' : 'false' %>"
             data-checkbox-hidden-target="hidden"
             data-step-form-target="field">
      <input type="checkbox"
             data-checkbox-hidden-target="checkbox"
             data-action="change->checkbox-hidden#toggle"
             class="h-4 w-4 text-emerald-600 focus:ring-emerald-500 border-gray-300 rounded">
      <span class="ml-2 text-sm text-gray-700 dark:text-gray-300">This step may resolve the issue</span>
    </label>
    <p class="mt-1 ml-6 text-xs text-gray-500 dark:text-gray-400">
      When enabled, the scenario player shows a "This resolved the issue" button alongside Continue.
    </p>
  </div>
</div>
