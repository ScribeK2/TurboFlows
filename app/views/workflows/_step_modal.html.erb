<%# Step Addition Modal %>
<div id="step-modal"
     class="is-hidden dialog-overlay"
     data-step-modal-target="modalContainer"
     data-action="click->step-modal#backdropClick">
  <%# Backdrop %>
  <div class="dialog-backdrop" data-step-modal-target="backdrop"></div>

  <%# Modal wrapper for centering %>
  <div class="dialog-wrapper">
    <div class="dialog-centering">
      <%# Center modal spacer %>
      <span class="dialog-spacer">&#8203;</span>

      <%# Modal panel %>
      <div class="dialog dialog--lg"
           data-step-modal-target="modal"
           data-action="click->step-modal#stopPropagation">
      <div class="dialog__body">
        <div class="flex items-center justify-between mb-4">
          <h3 class="dialog__title">Add Step</h3>
          <button type="button"
                  data-action="click->step-modal#close"
                  class="dialog__close">
            <span class="sr-only">Close</span>
            <svg class="icon icon--sm" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
            </svg>
          </button>
        </div>

        <form data-step-modal-target="form" id="step-modal-form" novalidate>
          <%# Step Type Selector %>
          <div class="form-group">
            <label class="form-label">Step Type</label>
            <div class="step-type-grid">
              <% [
                { value: 'question', label: 'Question', icon: '?', color: 'slate' },
                { value: 'action', label: 'Action', icon: '!', color: 'emerald' },
                { value: 'message', label: 'Message', icon: 'i', color: 'cyan' },
                { value: 'sub_flow', label: 'Sub-Flow', icon: '↪', color: 'indigo' }
              ].each do |type| %>
                <label class="step-type-option"
                       data-step-type-option="<%= type[:value] %>"
                       data-step-type-color="<%= type[:color] %>"
                       data-type="<%= type[:value] %>">
                  <input type="radio"
                         name="step_type"
                         value="<%= type[:value] %>"
                         data-step-modal-target="stepType"
                         data-action="change->step-modal#updateStepType"
                         data-step-modal-type-param="<%= type[:value] %>"
                         <%= 'checked' if type[:value] == 'question' %>
                         class="sr-only">
                  <span class="step-type-option__icon"><%= type[:icon] %></span>
                  <span class="step-type-option__label"><%= type[:label] %></span>
                </label>
              <% end %>
            </div>
          </div>

          <%# Template Selector %>
          <div class="form-group" data-step-modal-target="templateContainer">
            <label class="form-label">Apply Template (Optional)</label>
            <select data-step-modal-target="templateSelect"
                    data-action="change->step-modal#applyTemplate"
                    class="form-select">
              <option value="">-- Select a template --</option>
            </select>
            <p class="form-hint">Quickly fill form fields with a predefined template</p>
          </div>

          <%# Variable Suggestions %>
          <div class="card card--muted p-3 mb-4" data-step-modal-target="variableSuggest">
            <p class="form-hint mb-0">Loading variables...</p>
          </div>

          <%# Step Form Fields %>
          <div id="step-form-fields" style="display: flex; flex-direction: column; gap: 1rem;">
            <%# Basic fields that apply to all step types %>
            <div class="form-group">
              <label class="form-label">Title <span class="text-red-500">*</span></label>
              <input type="text"
                     name="title"
                     id="modal-step-title"
                     placeholder="Step title"
                     class="form-input">
            </div>

            <div class="form-group">
              <label class="form-label">Description</label>
              <textarea name="description"
                        id="modal-step-description"
                        placeholder="Step description (optional)"
                        rows="2"
                        class="form-textarea"></textarea>
            </div>

            <%# Type-specific fields - shown based on step type %>
            <div id="type-specific-fields" style="display: flex; flex-direction: column; gap: 1rem;">
              <%# Question fields %>
              <div id="question-fields" class="hidden" style="display: flex; flex-direction: column; gap: 1rem;">
                <div class="form-group">
                  <label class="form-label">Question Text</label>
                  <input type="text"
                         name="question"
                         id="modal-step-question"
                         placeholder="Enter your question"
                         class="form-input">
                </div>
                <div class="form-group">
                  <label class="form-label">Answer Type</label>
                  <select name="answer_type"
                          id="modal-step-answer-type"
                          class="form-select">
                    <option value="">Select answer type...</option>
                    <option value="text">Text</option>
                    <option value="yes_no">Yes/No</option>
                    <option value="multiple_choice">Multiple Choice</option>
                    <option value="dropdown">Dropdown</option>
                    <option value="date">Date</option>
                    <option value="number">Number</option>
                    <option value="file">File Upload</option>
                  </select>
                </div>
                <div class="form-group">
                  <label class="form-label">Variable Name</label>
                  <input type="text"
                         name="variable_name"
                         id="modal-step-variable-name"
                         placeholder="e.g., user_name, age, etc."
                         class="form-input">
                  <p class="form-hint">Optional: Name this answer for use in transition conditions</p>
                </div>
              </div>

              <%# Action fields %>
              <div id="action-fields" class="hidden" style="display: flex; flex-direction: column; gap: 1rem;">
                <div class="form-group">
                  <label class="form-label">Action Type</label>
                  <input type="text"
                         name="action_type"
                         id="modal-step-action-type"
                         placeholder="e.g., Email, Notification, etc."
                         class="form-input">
                </div>
                <div class="form-group">
                  <label class="form-label">Instructions</label>
                  <textarea name="instructions"
                            id="modal-step-instructions"
                            placeholder="Detailed instructions for this action..."
                            rows="3"
                            class="form-textarea"></textarea>
                </div>
              </div>

              <%# Message fields %>
              <div id="message-fields" class="hidden">
                <div class="form-group">
                  <label class="form-label">Message Content</label>
                  <textarea name="content"
                            id="modal-step-content"
                            placeholder="Message to display..."
                            rows="3"
                            class="form-textarea"></textarea>
                </div>
              </div>

              <%# Sub-Flow fields %>
              <div id="sub_flow-fields" class="hidden">
                <p class="form-hint">Sub-flow steps launch another workflow as a child process.</p>
              </div>
            </div>
          </div>

          <div class="dialog__footer">
            <button type="button"
                    data-action="click->step-modal#close"
                    class="btn btn--plain">
              Cancel
            </button>
            <button type="button"
                    id="add-step-button"
                    data-action="click->step-modal#addStep"
                    class="btn btn--primary">
              Add Step
            </button>
          </div>
        </form>
      </div>
    </div>
    </div>
  </div>
</div>
