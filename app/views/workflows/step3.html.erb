<div class="page-content" style="max-width: 48rem; margin: 0 auto;">
  <div class="mb-6">
    <h1 class="page-title">Review & Launch</h1>
    <p class="text-sm mt-1">Step 3 of 3: Review your workflow and create it.</p>
  </div>

  <%= render partial: "wizard_progress", locals: { current_step: 3, workflow: @workflow } %>

  <%= form_with model: @workflow, url: create_from_draft_workflow_path(@workflow), method: :patch, local: true, data: { turbo: false }, class: "card" do |form| %>
    <%= render partial: "shared/error_messages", locals: { object: @workflow, container_class: "card__body" } %>

    <div class="card__body" style="display: flex; flex-direction: column; gap: 1.5rem;">
      <!-- Workflow Summary -->
      <div class="card card--muted p-4">
        <h3 class="font-semibold mb-3">Workflow Summary</h3>
        <div style="display: flex; flex-direction: column; gap: 0.5rem;">
          <div>
            <span class="text-sm font-medium">Title:</span>
            <span class="text-sm ml-2"><%= @workflow.title %></span>
          </div>
          <% if @workflow.description_text.present? %>
            <div>
              <span class="text-sm font-medium">Description:</span>
              <div class="text-sm mt-1"><%= @workflow.description %></div>
            </div>
          <% end %>
          <% if @workflow.groups.any? %>
            <div>
              <span class="text-sm font-medium">Groups:</span>
              <span class="text-sm ml-2"><%= @workflow.groups.map(&:name).join(", ") %></span>
            </div>
          <% end %>
          <div>
            <span class="text-sm font-medium">Steps:</span>
            <span class="text-sm ml-2"><%= @workflow.steps.size %> step(s)</span>
          </div>
        </div>
      </div>

      <!-- Validation Summary -->
      <% steps = @workflow.steps.order(:position) %>
      <% has_steps = steps.size > 0 %>
      <% all_have_titles = steps.all? { |s| s.title.present? && s.title.to_s.strip.present? } %>
      <% all_pass = has_steps && all_have_titles %>
      <div class="alert <%= all_pass ? 'alert--success' : 'alert--warning' %>">
        <h3 class="font-semibold mb-2">Validation Summary</h3>
        <ul style="display: flex; flex-direction: column; gap: 0.25rem;">
          <li class="flex items-center gap-2 text-sm">
            <% if has_steps %>
              <span>&#10003;</span>
              <span>Workflow has steps (<%= steps.size %>)</span>
            <% else %>
              <span>&#10007;</span>
              <span>Workflow has no steps</span>
            <% end %>
          </li>
          <% if has_steps %>
            <li class="flex items-center gap-2 text-sm">
              <% if all_have_titles %>
                <span>&#10003;</span>
                <span>All steps have titles</span>
              <% else %>
                <span>&#10007;</span>
                <span>Some steps are missing titles</span>
              <% end %>
            </li>
          <% end %>
        </ul>
      </div>

      <!-- Interactive Flowchart Preview -->
      <% if @workflow.steps.any? %>
        <div class="card"
             data-controller="wizard-flow-preview"
             data-wizard-flow-preview-workflow-id-value="<%= @workflow.id %>">
          <script type="application/json" data-wizard-flow-preview-steps-data="<%= @workflow.id %>">
            <%= raw json_escape(serialize_steps_for_editor(@workflow).to_json) %>
          </script>
          <div class="card__header flex justify-between items-center">
            <h3 class="font-semibold">Workflow Flowchart</h3>
            <div class="editor-zoom">
              <button type="button" data-action="click->wizard-flow-preview#zoomOut" class="editor-zoom__btn" title="Zoom out">
                <svg class="icon icon--sm" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0zM13 10H7"/></svg>
              </button>
              <span data-wizard-flow-preview-target="zoomLevel" class="editor-zoom__level">100%</span>
              <button type="button" data-action="click->wizard-flow-preview#zoomIn" class="editor-zoom__btn" title="Zoom in">
                <svg class="icon icon--sm" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0zM10 7v6m3-3H7"/></svg>
              </button>
              <button type="button" data-action="click->wizard-flow-preview#fitToScreen" class="editor-zoom__btn" title="Fit to screen">
                <svg class="icon icon--sm" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M4 8V4m0 0h4M4 4l5 5m11-1V4m0 0h-4m4 0l-5 5M4 16v4m0 0h4m-4 0l5-5m11 5l-5-5m5 5v-4m0 4h-4"/></svg>
              </button>
              <div class="w-px h-5 mx-1" style="background: var(--color-border);"></div>
              <button type="button" data-action="click->wizard-flow-preview#refresh" class="btn btn--plain btn--sm">Refresh</button>
            </div>
          </div>
          <div
            data-wizard-flow-preview-target="canvas"
            class="editor-canvas p-4 m-4"
            style="min-height: 400px; max-height: 700px; overflow: auto;"
          >
            <p class="text-center py-8">Loading preview...</p>
          </div>
          <div class="px-6 pb-4 text-xs">
            <p><%= ui_svg_icon('lightbulb', css_classes: "icon icon--xs inline-block") %> Tip: Click on any step to edit it. Ctrl+scroll to zoom, Alt+drag to pan.</p>
          </div>
        </div>
      <% else %>
        <div class="alert alert--warning">
          <div class="flex items-start gap-3">
            <svg class="icon icon--sm flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z" />
            </svg>
            <div>
              <h3 class="font-medium">No steps added yet</h3>
              <p class="text-sm mt-1">
                <%= link_to "Go back to add steps", step2_workflow_path(@workflow) %> or create the workflow and add steps later.
              </p>
            </div>
          </div>
        </div>
      <% end %>

      <%= render partial: "workflows/step_modal" %>

      <div class="flex justify-between items-center pt-4" style="border-top: 1px solid var(--color-border);">
        <%= link_to step2_workflow_path(@workflow), class: "btn btn--plain" do %>
          <svg class="icon icon--sm" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
          </svg>
          Previous
        <% end %>
        <div class="flex items-center gap-3">
          <button type="submit" name="save_draft" value="1" class="btn btn--plain">
            Save as Draft
          </button>
          <%= form.submit "Create Workflow", class: "btn btn--positive" %>
        </div>
      </div>
    </div>
  <% end %>
</div>
