<%#
  Step Card — Turbo Frame wrapper for each step in the list editor.
  Collapsed by default; expanding loads the edit form lazily.

  Local variables:
  - step: AR Step object
  - workflow: Workflow object
%>
<%= turbo_frame_tag dom_id(step),
      class: "step-card step-item step-card--#{step.step_type}",
      data: {
        step_id: step.id,
        step_index: step.position,
        controller: "collapsible-step",
        collapsible_step_expanded_value: local_assigns.fetch(:expanded, false),
        collapsible_step_step_type_value: step.step_type
      },
      tabindex: "0",
      role: "listitem" do %>

  <%# Hidden fields for step discovery by JS controllers (transitions, tree, condition presets, etc.) %>
  <input type="hidden" name="step_uuid" value="<%= step.uuid %>" data-step-field="id">
  <input type="hidden" name="step_title" value="<%= step.title %>" data-step-field="title">
  <input type="hidden" name="step_type" value="<%= step.step_type %>" data-step-field="type">
  <% if step.respond_to?(:answer_type) %>
    <input type="hidden" name="step_answer_type" value="<%= step.answer_type %>" data-step-field="answer_type">
  <% end %>
  <% if step.respond_to?(:variable_name) %>
    <input type="hidden" name="step_variable_name" value="<%= step.variable_name %>" data-step-field="variable_name">
  <% end %>

  <%# Collapsible Header %>
  <div data-collapsible-step-target="header"
       class="step-card__header"
       data-action="click->collapsible-step#toggle">

    <div class="flex items-center gap-3">
      <%# Drag Handle %>
      <span class="drag-handle" title="Drag to reorder">
        <svg class="icon icon--sm" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 8h16M4 16h16"/>
        </svg>
      </span>

      <%# Step Number & Type %>
      <div class="flex items-center gap-2">
        <span class="step-card__number"><%= step.position + 1 %></span>
        <span class="step-card__type"><%= step_type_svg_icon(step.step_type) %></span>
      </div>

      <%# Step Title %>
      <span class="step-card__title truncate">
        <%= step.title.presence || "Untitled #{step.step_type.titleize}" %>
      </span>

      <%# Status Pills %>
      <% if step == workflow.start_step %>
        <span class="step-pill step-pill--start">Start</span>
      <% end %>
      <% if step.terminal? %>
        <span class="step-pill step-pill--terminal">Terminal</span>
      <% end %>
      <% if workflow.graph_mode? && step.transitions.empty? && !step.is_a?(Steps::Resolve) %>
        <span class="step-pill step-pill--warning">No connections</span>
      <% end %>

      <%# Collapsed Summary %>
      <span data-collapsible-step-target="stepSummary"
            class="is-hidden step-card__hint truncate ml-2">
        <%= highlight_variables(step_summary_text(step)) %>
      </span>
    </div>

    <div class="flex items-center gap-2">
      <%# Delete Button %>
      <form method="post" action="<%= workflow_step_path(workflow, step) %>"
            data-turbo-method="delete" data-turbo-confirm="Remove this step?">
        <button type="submit" class="step-card__remove" title="Remove step"
                onclick="event.stopPropagation()">
          <svg class="icon icon--sm" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/>
          </svg>
        </button>
      </form>

      <%# Toggle Arrow %>
      <svg data-collapsible-step-target="toggleIcon"
           class="icon icon--sm step-card__chevron"
           style="transform: rotate(180deg);"
           fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
      </svg>
    </div>
  </div>

  <%# Collapsible Body — lazy-loaded edit form %>
  <div data-collapsible-step-target="content" class="step-card__body is-hidden">
    <turbo-frame id="<%= dom_id(step, :form) %>"
                 data-collapsible-step-target="editFrame"
                 data-src="<%= edit_workflow_step_path(workflow, step) %>">
      <p class="text-sm p-4" style="color: var(--color-text-muted);">Loading...</p>
    </turbo-frame>
  </div>
<% end %>
