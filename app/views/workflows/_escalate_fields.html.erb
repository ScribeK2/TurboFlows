<%# Escalate-specific fields partial %>
<%# Escalate steps transfer the interaction to another department/supervisor/channel/ticket %>

<div class="field-container">
  <div class="alert alert--warning flex items-start gap-3 mb-4">
    <svg class="icon icon--sm flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 11l5-5m0 0l5 5m-5-5v12" />
    </svg>
    <div class="flex-1">
      <p class="text-sm">
        <strong>Escalate Step:</strong> Transfer the interaction to another department, supervisor, channel, or ticket. This step can be terminal (end workflow) or continue to subsequent steps via connections.
      </p>
    </div>
  </div>

  <%# Target Type %>
  <div class="form-group">
    <label class="form-label">
      Escalation Target Type
    </label>
    <div class="flex flex-wrap gap-2 mb-2"
         data-controller="selection-group"
         data-selection-group-active-class="is-active"
         data-selection-group-inactive-class="">
      <% %w[department supervisor channel ticket].each do |target_type| %>
        <button type="button"
                data-selection-group-target="button"
                data-action="click->selection-group#select"
                data-selection-group-value-param="<%= target_type %>"
                class="btn btn--sm <%= step['target_type'] == target_type ? 'btn--secondary' : 'btn--plain' %>">
          <%= target_type.titleize %>
        </button>
      <% end %>
      <input type="hidden"
             name="workflow[steps][][target_type]"
             value="<%= step['target_type'] %>"
             data-selection-group-target="input"
             data-step-form-target="field">
    </div>
  </div>

  <%# Target Value %>
  <div class="form-group">
    <label class="form-label">
      Target Name/ID
    </label>
    <input type="text"
           name="workflow[steps][][target_value]"
           value="<%= step['target_value'] %>"
           placeholder="e.g., Billing Department, Supervisor, #escalations-channel"
           class="form-input"
           data-step-form-target="field">
    <p class="form-hint">
      The specific department, supervisor, or channel to escalate to.
    </p>
  </div>

  <%# Priority %>
  <div class="form-group">
    <label class="form-label">
      Priority
    </label>
    <select name="workflow[steps][][priority]"
            class="form-select"
            data-step-form-target="field">
      <option value="low" <%= 'selected' if step['priority'] == 'low' %>>Low</option>
      <option value="medium" <%= 'selected' if step['priority'] == 'medium' || step['priority'].blank? %>>Medium</option>
      <option value="high" <%= 'selected' if step['priority'] == 'high' %>>High</option>
      <option value="critical" <%= 'selected' if step['priority'] == 'critical' %>>Critical</option>
    </select>
  </div>

  <%# Reason Required Checkbox %>
  <div class="form-group" data-controller="checkbox-hidden">
    <label class="flex items-center gap-2 cursor-pointer">
      <input type="hidden" name="workflow[steps][][reason_required]"
             value="<%= step['reason_required'] == true || step['reason_required'] == 'true' ? 'true' : 'false' %>"
             data-checkbox-hidden-target="hidden"
             data-step-form-target="field">
      <input type="checkbox"
             data-checkbox-hidden-target="checkbox"
             data-action="change->checkbox-hidden#toggle"
             class="form-checkbox">
      <span class="text-sm">Require CSR to provide a reason for escalation</span>
    </label>
  </div>

  <%# Notes/Instructions %>
  <div class="form-group">
    <label class="form-label">
      Notes/Instructions
      <span class="font-normal">(optional)</span>
    </label>
    <%= form_with model: [workflow, step], url: workflow_step_path(workflow, step), method: :patch, local: true do |f| %>
      <%= f.rich_text_area :notes,
          data: { step_form_target: "field", variable_autocomplete_target: "input" } %>
    <% end %>
  </div>
</div>
