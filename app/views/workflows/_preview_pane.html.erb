<% sample_variables = local_assigns.fetch(:sample_variables, {}) %>
<div class="preview-pane card p-4" data-controller="image-lightbox">
  <h4 class="text-sm font-semibold mb-2">Live Preview</h4>
  <% if sample_variables.present? %>
    <p class="form-hint italic mb-2">Showing preview with sample variable values</p>
  <% end %>

  <%# Preview pane receives either AR Step objects or hashes from preview endpoint %>
  <% if step %>
    <% stype = step.is_a?(Step) ? step.step_type : step["type"]&.to_s&.downcase %>
    <% stitle = step.is_a?(Step) ? step.title : step["title"] %>
    <% sdesc = step.is_a?(Step) ? step.try(:description).to_s : step["description"] %>
    <% case stype %>
    <% when "question" %>
      <div class="flex-col-gap-3">
        <% if stitle.present? %>
          <h5 class="font-medium"><%= VariableInterpolator.interpolate(stitle, sample_variables) %></h5>
        <% end %>

        <% if sdesc.present? %>
          <div class="text-sm"><%= VariableInterpolator.interpolate(sdesc, sample_variables) %></div>
        <% end %>

        <% question_text = step.is_a?(Step) ? step.question : step["question"] %>
        <% if question_text.present? %>
          <p class="font-medium"><%= VariableInterpolator.interpolate(question_text, sample_variables) %></p>
        <% end %>

        <!-- Preview based on answer type -->
        <% answer_type = step.is_a?(Step) ? step.answer_type : step["answer_type"] %>
        <% options = step.is_a?(Step) ? step.options : step["options"] %>
        <div class="mt-2">
          <% case answer_type %>
          <% when "text" %>
            <input type="text"
                   class="form-input w-full"
                   placeholder="Your answer..."
                   disabled />
          <% when "yes_no" %>
            <div class="flex gap-2">
              <button class="btn btn--positive" disabled>Yes</button>
              <button class="btn btn--negative" disabled>No</button>
            </div>
          <% when "multiple_choice" %>
            <div class="flex-col-gap-2">
              <% if options.present? && options.is_a?(Array) %>
                <% options.each do |option| %>
                  <label class="preview-radio-option card cursor-not-allowed">
                    <input type="radio" name="preview_<%= index %>" disabled class="cursor-not-allowed" />
                    <span class="text-sm"><%= option["label"] || option["value"] || "Option" %></span>
                  </label>
                <% end %>
              <% else %>
                <p class="form-hint italic">No options defined yet</p>
              <% end %>
            </div>
          <% when "dropdown" %>
            <select class="form-select w-full" disabled>
              <option>Select an option</option>
              <% if options.present? && options.is_a?(Array) %>
                <% options.each do |option| %>
                  <option><%= option["label"] || option["value"] %></option>
                <% end %>
              <% end %>
            </select>
          <% when "date" %>
            <input type="date"
                   class="form-input w-full"
                   disabled />
          <% when "number" %>
            <input type="number"
                   class="form-input w-full"
                   placeholder="Enter a number"
                   disabled />
          <% when "file" %>
            <div class="file-dropzone text-center">
              <p class="text-sm inline-flex items-center gap-1"><%= ui_svg_icon('paperclip', css_classes: "icon icon--sm") %> File Upload</p>
              <input type="file" class="mt-2" disabled />
            </div>
          <% else %>
            <p class="form-hint italic">Select an answer type to see preview</p>
          <% end %>
        </div>

        <% var_name = step.is_a?(Step) ? step.variable_name : step["variable_name"] %>
        <% if var_name.present? %>
          <div class="mt-2">
            <code class="badge">Variable: <%= var_name %></code>
          </div>
        <% end %>
      </div>

    <% when "action" %>
      <div class="flex-col-gap-2">
        <% if stitle.present? %>
          <h5 class="font-medium"><%= VariableInterpolator.interpolate(stitle, sample_variables) %></h5>
        <% end %>

        <% if sdesc.present? %>
          <div class="text-sm"><%= VariableInterpolator.interpolate(sdesc, sample_variables) %></div>
        <% end %>

        <% action_type = step.is_a?(Step) ? step.action_type : step["action_type"] %>
        <% if action_type.present? %>
          <div class="badge badge--action">
            <%= action_type.humanize %>
          </div>
        <% end %>

        <% if step.is_a?(Step) %>
          <% if step.instructions.present? %>
            <div class="preview-content-box card">
              <div class="text-sm"><%= render_step_content(step, 'instructions', sample_variables) %></div>
            </div>
          <% end %>
        <% else %>
          <% if step["instructions"].present? %>
            <div class="preview-content-box card">
              <div class="text-sm"><%= VariableInterpolator.interpolate(step["instructions"], sample_variables) %></div>
            </div>
          <% end %>
        <% end %>
      </div>

    <% when "message" %>
      <div class="flex-col-gap-2">
        <% if stitle.present? %>
          <h5 class="font-medium"><%= VariableInterpolator.interpolate(stitle, sample_variables) %></h5>
        <% end %>

        <% if sdesc.present? %>
          <div class="text-sm"><%= VariableInterpolator.interpolate(sdesc, sample_variables) %></div>
        <% end %>

        <div class="preview-content-box card card--message">
          <div class="flex items-start gap-2">
            <span class="step-card__number flex-shrink-0 step-card__number--message">i</span>
            <div class="flex-1">
              <% content_val = step.is_a?(Step) ? step.content : step["content"] %>
              <% if content_val.present? %>
                <% if step.is_a?(Step) %>
                  <div class="text-sm"><%= render_step_content(step, 'content', sample_variables) %></div>
                <% else %>
                  <div class="text-sm"><%= VariableInterpolator.interpolate(content_val, sample_variables) %></div>
                <% end %>
              <% else %>
                <p class="text-sm italic">No message content yet</p>
              <% end %>
            </div>
          </div>
        </div>

        <p class="form-hint mt-2">
          <span class="font-medium">Auto-advances</span> - This message will be displayed and the workflow continues automatically.
        </p>
      </div>

    <% when "escalate" %>
      <div class="flex-col-gap-2">
        <% if stitle.present? %>
          <h5 class="font-medium"><%= VariableInterpolator.interpolate(stitle, sample_variables) %></h5>
        <% end %>

        <% if sdesc.present? %>
          <div class="text-sm"><%= VariableInterpolator.interpolate(sdesc, sample_variables) %></div>
        <% end %>

        <div class="preview-content-box card card--escalate">
          <div class="flex items-center gap-2 mb-2">
            <span class="step-card__number step-card__number--escalate">↑</span>
            <span class="font-medium">Escalation</span>
          </div>

          <div class="flex-col-gap-1 text-sm">
            <% target_type = step.is_a?(Step) ? step.target_type : step["target_type"] %>
            <% target_value = step.is_a?(Step) ? step.target_value : step["target_value"] %>
            <% if target_type.present? || target_value.present? %>
              <div class="flex items-center gap-2">
                <span>Target:</span>
                <span class="font-medium">
                  <%= target_type&.titleize %><%= " - #{target_value}" if target_value.present? %>
                </span>
              </div>
            <% end %>

            <% priority = step.is_a?(Step) ? step.priority : step["priority"] %>
            <% if priority.present? %>
              <div class="flex items-center gap-2">
                <span>Priority:</span>
                <span class="badge"><%= priority.titleize %></span>
              </div>
            <% end %>

            <% reason_req = step.is_a?(Step) ? step.reason_required : step["reason_required"] %>
            <% if reason_req == true || reason_req == "true" %>
              <p class="form-hint mt-2">Reason required from CSR</p>
            <% end %>

            <% if step.is_a?(Step) && step.notes.present? %>
              <div class="preview-notes card">
                <%= render_step_content(step, 'notes', sample_variables) %>
              </div>
            <% elsif step.is_a?(Hash) && step["notes"].present? %>
              <div class="preview-notes card">
                <%= VariableInterpolator.interpolate(step["notes"], sample_variables) %>
              </div>
            <% end %>
          </div>
        </div>
      </div>

    <% when "resolve" %>
      <div class="flex-col-gap-2">
        <% if stitle.present? %>
          <h5 class="font-medium"><%= VariableInterpolator.interpolate(stitle, sample_variables) %></h5>
        <% end %>

        <% if sdesc.present? %>
          <div class="text-sm"><%= VariableInterpolator.interpolate(sdesc, sample_variables) %></div>
        <% end %>

        <div class="preview-content-box card card--resolve">
          <div class="flex items-center gap-2 mb-2">
            <span class="step-card__number step-card__number--resolve">✓</span>
            <span class="font-medium">Resolution</span>
            <span class="badge">Terminal</span>
          </div>

          <div class="flex-col-gap-1 text-sm">
            <% res_type = step.is_a?(Step) ? step.resolution_type : step["resolution_type"] %>
            <div class="flex items-center gap-2">
              <span>Type:</span>
              <span class="font-medium"><%= (res_type || "success").titleize %></span>
            </div>

            <% res_code = step.is_a?(Step) ? step.resolution_code : step["resolution_code"] %>
            <% if res_code.present? %>
              <div class="flex items-center gap-2">
                <span>Code:</span>
                <code class="badge"><%= res_code %></code>
              </div>
            <% end %>

            <% notes_req = step.is_a?(Step) ? step.notes_required : step["notes_required"] %>
            <% survey = step.is_a?(Step) ? step.survey_trigger : step["survey_trigger"] %>
            <div class="flex flex-wrap gap-2 mt-2">
              <% if notes_req == true || notes_req == "true" %>
                <span class="badge">Notes required</span>
              <% end %>
              <% if survey == true || survey == "true" %>
                <span class="badge">Survey trigger</span>
              <% end %>
            </div>
          </div>
        </div>

        <p class="form-hint mt-2">
          <span class="font-medium">Terminal step</span> - Workflow ends here with resolution metadata.
        </p>
      </div>

    <% when "sub_flow" %>
      <div class="flex-col-gap-2">
        <% if stitle.present? %>
          <h5 class="font-medium"><%= VariableInterpolator.interpolate(stitle, sample_variables) %></h5>
        <% end %>

        <% if sdesc.present? %>
          <div class="text-sm"><%= VariableInterpolator.interpolate(sdesc, sample_variables) %></div>
        <% end %>

        <div class="preview-content-box card card--sub-flow">
          <div class="flex items-center gap-2 mb-2">
            <span class="badge badge--sub-flow">Sub-flow</span>
          </div>

          <% target_id = step.is_a?(Step) ? step.target_workflow_id : step["target_workflow_id"] %>
          <% if target_id.present? %>
            <% target_wf = Workflow.find_by(id: target_id) %>
            <% if target_wf %>
              <p class="text-sm"><strong>Target:</strong> <%= target_wf.title %></p>
              <p class="form-hint"><%= pluralize(target_wf.steps.count, "step") %></p>
            <% else %>
              <p class="text-sm italic">Target workflow not found</p>
            <% end %>
          <% else %>
            <p class="text-sm italic">No target workflow selected</p>
          <% end %>
        </div>

        <p class="form-hint mt-2">
          Execution will jump to the target workflow and return when it completes.
        </p>
      </div>

    <% else %>
      <p class="text-sm">Select a step type to see preview</p>
    <% end %>
  <% else %>
    <p class="text-sm text-center py-4">Start filling in the form to see a live preview</p>
  <% end %>
</div>
