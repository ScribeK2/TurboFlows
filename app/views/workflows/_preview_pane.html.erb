<% sample_variables = local_assigns.fetch(:sample_variables, {}) %>
<div class="preview-pane bg-gray-50 border rounded-lg p-4" data-controller="image-lightbox">
  <h4 class="text-sm font-semibold text-gray-700 mb-2">Live Preview</h4>
  <% if sample_variables.present? %>
    <p class="text-xs text-gray-500 mb-2 italic">Showing preview with sample variable values</p>
  <% end %>

  <%# Preview pane receives either AR Step objects or hashes from preview endpoint %>
  <% if step %>
    <% stype = step.is_a?(Step) ? step.step_type : step["type"]&.to_s&.downcase %>
    <% stitle = step.is_a?(Step) ? step.title : step["title"] %>
    <% sdesc = step.is_a?(Step) ? step.try(:description).to_s : step["description"] %>
    <% case stype %>
    <% when "question" %>
      <div class="space-y-3">
        <% if stitle.present? %>
          <h5 class="font-medium text-gray-900"><%= VariableInterpolator.interpolate(stitle, sample_variables) %></h5>
        <% end %>

        <% if sdesc.present? %>
          <div class="text-sm text-gray-600"><%= VariableInterpolator.interpolate(sdesc, sample_variables) %></div>
        <% end %>

        <% question_text = step.is_a?(Step) ? step.question : step["question"] %>
        <% if question_text.present? %>
          <p class="font-medium text-gray-800"><%= VariableInterpolator.interpolate(question_text, sample_variables) %></p>
        <% end %>

        <!-- Preview based on answer type -->
        <% answer_type = step.is_a?(Step) ? step.answer_type : step["answer_type"] %>
        <% options = step.is_a?(Step) ? step.options : step["options"] %>
        <div class="mt-3">
          <% case answer_type %>
          <% when "text" %>
            <input type="text"
                   class="w-full border border-gray-300 rounded-md px-3 py-2 bg-white"
                   placeholder="Your answer..."
                   disabled />
          <% when "yes_no" %>
            <div class="flex gap-2">
              <button class="px-4 py-2 bg-green-500 text-white rounded-md hover:bg-green-600 transition-colors" disabled>Yes</button>
              <button class="px-4 py-2 bg-red-500 text-white rounded-md hover:bg-red-600 transition-colors" disabled>No</button>
            </div>
          <% when "multiple_choice" %>
            <div class="space-y-2">
              <% if options.present? && options.is_a?(Array) %>
                <% options.each do |option| %>
                  <label class="flex items-center gap-2 p-2 border rounded-md hover:bg-gray-100 cursor-not-allowed">
                    <input type="radio" name="preview_<%= index %>" disabled class="cursor-not-allowed" />
                    <span class="text-sm"><%= option["label"] || option["value"] || "Option" %></span>
                  </label>
                <% end %>
              <% else %>
                <p class="text-xs text-gray-500 italic">No options defined yet</p>
              <% end %>
            </div>
          <% when "dropdown" %>
            <select class="w-full border border-gray-300 rounded-md px-3 py-2 bg-white" disabled>
              <option>Select an option</option>
              <% if options.present? && options.is_a?(Array) %>
                <% options.each do |option| %>
                  <option><%= option["label"] || option["value"] %></option>
                <% end %>
              <% end %>
            </select>
          <% when "date" %>
            <input type="date"
                   class="w-full border border-gray-300 rounded-md px-3 py-2 bg-white"
                   disabled />
          <% when "number" %>
            <input type="number"
                   class="w-full border border-gray-300 rounded-md px-3 py-2 bg-white"
                   placeholder="Enter a number"
                   disabled />
          <% when "file" %>
            <div class="border-2 border-dashed border-gray-300 rounded-md p-4 text-center">
              <p class="text-sm text-gray-500 inline-flex items-center gap-1"><%= ui_svg_icon('paperclip', css_classes: "w-4 h-4") %> File Upload</p>
              <input type="file" class="mt-2" disabled />
            </div>
          <% else %>
            <p class="text-xs text-gray-500 italic">Select an answer type to see preview</p>
          <% end %>
        </div>

        <% var_name = step.is_a?(Step) ? step.variable_name : step["variable_name"] %>
        <% if var_name.present? %>
          <div class="mt-2 text-xs text-gray-500">
            <span class="font-mono bg-gray-200 px-2 py-1 rounded">Variable: <%= var_name %></span>
          </div>
        <% end %>
      </div>

    <% when "action" %>
      <div class="space-y-2">
        <% if stitle.present? %>
          <h5 class="font-medium text-gray-900"><%= VariableInterpolator.interpolate(stitle, sample_variables) %></h5>
        <% end %>

        <% if sdesc.present? %>
          <div class="text-sm text-gray-600"><%= VariableInterpolator.interpolate(sdesc, sample_variables) %></div>
        <% end %>

        <% action_type = step.is_a?(Step) ? step.action_type : step["action_type"] %>
        <% if action_type.present? %>
          <div class="inline-flex items-center gap-2 px-3 py-1 bg-purple-100 text-purple-800 rounded-full text-xs font-medium">
            <%= action_type.humanize %>
          </div>
        <% end %>

        <% if step.is_a?(Step) %>
          <% if step.instructions.present? %>
            <div class="mt-2 p-3 bg-white border rounded-md">
              <div class="text-sm text-gray-700"><%= render_step_content(step, 'instructions', sample_variables) %></div>
            </div>
          <% end %>
        <% else %>
          <% if step["instructions"].present? %>
            <div class="mt-2 p-3 bg-white border rounded-md">
              <div class="text-sm text-gray-700"><%= VariableInterpolator.interpolate(step["instructions"], sample_variables) %></div>
            </div>
          <% end %>
        <% end %>
      </div>

    <% when "message" %>
      <div class="space-y-2">
        <% if stitle.present? %>
          <h5 class="font-medium text-gray-900"><%= VariableInterpolator.interpolate(stitle, sample_variables) %></h5>
        <% end %>

        <% if sdesc.present? %>
          <div class="text-sm text-gray-600"><%= VariableInterpolator.interpolate(sdesc, sample_variables) %></div>
        <% end %>

        <div class="mt-3 p-3 bg-cyan-50 border border-cyan-200 rounded-md">
          <div class="flex items-start gap-2">
            <span class="inline-flex items-center justify-center w-6 h-6 rounded-full bg-cyan-100 text-cyan-700 text-xs font-bold flex-shrink-0">i</span>
            <div class="flex-1">
              <% content_val = step.is_a?(Step) ? step.content : step["content"] %>
              <% if content_val.present? %>
                <% if step.is_a?(Step) %>
                  <div class="text-sm text-cyan-800"><%= render_step_content(step, 'content', sample_variables) %></div>
                <% else %>
                  <div class="text-sm text-cyan-800"><%= VariableInterpolator.interpolate(content_val, sample_variables) %></div>
                <% end %>
              <% else %>
                <p class="text-sm text-cyan-600 italic">No message content yet</p>
              <% end %>
            </div>
          </div>
        </div>

        <p class="text-xs text-gray-500 mt-2">
          <span class="font-medium">Auto-advances</span> - This message will be displayed and the workflow continues automatically.
        </p>
      </div>

    <% when "escalate" %>
      <div class="space-y-2">
        <% if stitle.present? %>
          <h5 class="font-medium text-gray-900"><%= VariableInterpolator.interpolate(stitle, sample_variables) %></h5>
        <% end %>

        <% if sdesc.present? %>
          <div class="text-sm text-gray-600"><%= VariableInterpolator.interpolate(sdesc, sample_variables) %></div>
        <% end %>

        <div class="mt-3 p-3 bg-orange-50 border border-orange-200 rounded-md">
          <div class="flex items-center gap-2 mb-2">
            <span class="inline-flex items-center justify-center w-6 h-6 rounded-full bg-orange-100 text-orange-700 text-xs font-bold">↑</span>
            <span class="font-medium text-orange-800">Escalation</span>
          </div>

          <div class="space-y-1 text-sm">
            <% target_type = step.is_a?(Step) ? step.target_type : step["target_type"] %>
            <% target_value = step.is_a?(Step) ? step.target_value : step["target_value"] %>
            <% if target_type.present? || target_value.present? %>
              <div class="flex items-center gap-2">
                <span class="text-orange-600">Target:</span>
                <span class="font-medium text-orange-800">
                  <%= target_type&.titleize %><%= " - #{target_value}" if target_value.present? %>
                </span>
              </div>
            <% end %>

            <% priority = step.is_a?(Step) ? step.priority : step["priority"] %>
            <% if priority.present? %>
              <div class="flex items-center gap-2">
                <span class="text-orange-600">Priority:</span>
                <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-medium
                  <%= case priority
                      when 'urgent' then 'bg-red-100 text-red-800'
                      when 'high' then 'bg-orange-100 text-orange-800'
                      when 'normal' then 'bg-blue-100 text-blue-800'
                      else 'bg-gray-100 text-gray-800'
                      end %>">
                  <%= priority.titleize %>
                </span>
              </div>
            <% end %>

            <% reason_req = step.is_a?(Step) ? step.reason_required : step["reason_required"] %>
            <% if reason_req == true || reason_req == "true" %>
              <p class="text-xs text-orange-600 mt-2">Reason required from CSR</p>
            <% end %>

            <% if step.is_a?(Step) && step.notes.present? %>
              <div class="mt-2 p-2 bg-white border border-orange-100 rounded text-sm text-gray-700">
                <%= render_step_content(step, 'notes', sample_variables) %>
              </div>
            <% elsif step.is_a?(Hash) && step["notes"].present? %>
              <div class="mt-2 p-2 bg-white border border-orange-100 rounded text-sm text-gray-700">
                <%= VariableInterpolator.interpolate(step["notes"], sample_variables) %>
              </div>
            <% end %>
          </div>
        </div>
      </div>

    <% when "resolve" %>
      <div class="space-y-2">
        <% if stitle.present? %>
          <h5 class="font-medium text-gray-900"><%= VariableInterpolator.interpolate(stitle, sample_variables) %></h5>
        <% end %>

        <% if sdesc.present? %>
          <div class="text-sm text-gray-600"><%= VariableInterpolator.interpolate(sdesc, sample_variables) %></div>
        <% end %>

        <div class="mt-3 p-3 bg-green-50 border border-green-200 rounded-md">
          <div class="flex items-center gap-2 mb-2">
            <span class="inline-flex items-center justify-center w-6 h-6 rounded-full bg-green-100 text-green-700 text-xs font-bold">✓</span>
            <span class="font-medium text-green-800">Resolution</span>
            <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-medium bg-green-100 text-green-800">Terminal</span>
          </div>

          <div class="space-y-1 text-sm">
            <% res_type = step.is_a?(Step) ? step.resolution_type : step["resolution_type"] %>
            <div class="flex items-center gap-2">
              <span class="text-green-600">Type:</span>
              <span class="font-medium text-green-800"><%= (res_type || "success").titleize %></span>
            </div>

            <% res_code = step.is_a?(Step) ? step.resolution_code : step["resolution_code"] %>
            <% if res_code.present? %>
              <div class="flex items-center gap-2">
                <span class="text-green-600">Code:</span>
                <code class="text-xs bg-green-100 px-2 py-0.5 rounded"><%= res_code %></code>
              </div>
            <% end %>

            <% notes_req = step.is_a?(Step) ? step.notes_required : step["notes_required"] %>
            <% survey = step.is_a?(Step) ? step.survey_trigger : step["survey_trigger"] %>
            <div class="flex flex-wrap gap-2 mt-2">
              <% if notes_req == true || notes_req == "true" %>
                <span class="inline-flex items-center px-2 py-0.5 rounded text-xs bg-gray-100 text-gray-700">Notes required</span>
              <% end %>
              <% if survey == true || survey == "true" %>
                <span class="inline-flex items-center px-2 py-0.5 rounded text-xs bg-blue-100 text-blue-700">Survey trigger</span>
              <% end %>
            </div>
          </div>
        </div>

        <p class="text-xs text-gray-500 mt-2">
          <span class="font-medium">Terminal step</span> - Workflow ends here with resolution metadata.
        </p>
      </div>

    <% else %>
      <p class="text-sm text-gray-500">Select a step type to see preview</p>
    <% end %>
  <% else %>
    <p class="text-sm text-gray-500 text-center py-4">Start filling in the form to see a live preview</p>
  <% end %>
</div>
