<aside class="group-sidebar" data-controller="workflow-sidebar">
  <!-- Mobile Toggle Button -->
  <button type="button"
          data-action="click->workflow-sidebar#toggle"
          class="btn btn--plain w-full text-left mb-4 group-sidebar__toggle">
    <div class="flex items-center justify-between">
      <span>Groups</span>
      <%= icon "bars-3", class: "icon icon--sm" %>
    </div>
  </button>

  <!-- Sidebar Content -->
  <div class="card group-sidebar__content" data-workflow-sidebar-target="sidebar">
    <div class="card__header">
      <h2 class="font-bold">Groups</h2>
    </div>

    <nav class="p-4">
      <ul class="group-sidebar__nav-list">
        <!-- All Workflows Option -->
        <li>
          <%= link_to workflows_path(search: params[:search]),
                      class: "group-sidebar__link #{@selected_group.nil? ? 'group-sidebar__link--active' : ''}" do %>
            <%= icon "document-text", class: "icon icon--sm mr-2" %>
            All Workflows
            <% if @selected_group.nil? && @workflows %>
              <span class="ml-auto badge">
                <%= @workflows.count %>
              </span>
            <% end %>
          <% end %>
        </li>

        <!-- Groups Tree -->
        <% if @accessible_groups.any? %>
          <% @accessible_groups.each do |root_group| %>
            <%= render partial: "workflows/group_sidebar_item", locals: { group: root_group, level: 0, selected_group: @selected_group } %>
          <% end %>
        <% else %>
          <li class="px-3 py-2 text-sm">
            No groups available
          </li>
        <% end %>
      </ul>
    </nav>

    <% if @selected_group.present? && current_user&.admin? %>
      <div class="card__footer border-t">
        <%= link_to admin_group_folders_path(@selected_group),
                    class: "btn btn--plain btn--sm flex items-center gap-2" do %>
          <%= icon "folder", class: "icon icon--sm" %>
          Manage Folders
        <% end %>
      </div>
    <% end %>
  </div>
</aside>
