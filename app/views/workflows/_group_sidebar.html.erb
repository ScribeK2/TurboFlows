<aside class="group-sidebar" data-controller="workflow-sidebar">
  <!-- Mobile Toggle Button -->
  <button type="button"
          data-action="click->workflow-sidebar#toggle"
          class="btn btn--plain w-full text-left mb-4 group-sidebar__toggle">
    <div class="flex items-center justify-between">
      <span>Groups</span>
      <svg class="icon icon--sm" data-workflow-sidebar-target="toggleIcon" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
      </svg>
    </div>
  </button>

  <!-- Sidebar Content -->
  <div class="card group-sidebar__content" data-workflow-sidebar-target="sidebar">
    <div class="card__header">
      <h2 class="font-bold">Groups</h2>
    </div>

    <nav class="p-4">
      <ul class="group-sidebar__nav-list">
        <!-- All Workflows Option -->
        <li>
          <%= link_to workflows_path(search: params[:search]),
                      class: "group-sidebar__link #{@selected_group.nil? ? 'group-sidebar__link--active' : ''}" do %>
            <svg class="icon icon--sm mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
            </svg>
            All Workflows
            <% if @selected_group.nil? && @workflows %>
              <span class="ml-auto badge">
                <%= @workflows.count %>
              </span>
            <% end %>
          <% end %>
        </li>

        <!-- Groups Tree -->
        <% if @accessible_groups.any? %>
          <% @accessible_groups.each do |root_group| %>
            <%= render partial: "workflows/group_sidebar_item", locals: { group: root_group, level: 0, selected_group: @selected_group } %>
          <% end %>
        <% else %>
          <li class="px-3 py-2 text-sm">
            No groups available
          </li>
        <% end %>
      </ul>
    </nav>

    <% if @selected_group.present? && current_user&.admin? %>
      <div class="card__footer border-t">
        <%= link_to admin_group_folders_path(@selected_group),
                    class: "btn btn--plain btn--sm flex items-center gap-2" do %>
          <svg class="icon icon--sm" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 7v10a2 2 0 002 2h14a2 2 0 002-2V9a2 2 0 00-2-2h-6l-2-2H5a2 2 0 00-2 2z" />
          </svg>
          Manage Folders
        <% end %>
      </div>
    <% end %>
  </div>
</aside>
