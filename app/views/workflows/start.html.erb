<div class="page-content" style="max-width: 48rem; margin: 0 auto; padding-bottom: 7rem;">
  <!-- Header Section -->
  <div class="mb-6 text-center">
    <h1 class="page-title"><%= @workflow.title %></h1>
    <% if @workflow.has_description? %>
      <div class="mt-3 text-left">
        <%= @workflow.description %>
      </div>
    <% end %>
  </div>

  <!-- Workflow Info Card -->
  <div class="card mb-6">
    <div class="card__body">
      <div class="flex items-center justify-center gap-6 text-sm">
        <div class="flex items-center gap-2">
          <svg class="icon icon--sm" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2" />
          </svg>
          <span><%= pluralize(@workflow.steps.size, "step") %></span>
        </div>
        <% if @workflow.is_public? %>
          <div class="flex items-center gap-2">
            <svg class="icon icon--sm" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z" />
            </svg>
            <span>Public</span>
          </div>
        <% end %>
      </div>
      <% dots = step_type_composition_dots(@workflow) %>
      <% if dots %>
        <div class="flex items-center justify-center gap-1 mt-3">
          <%= dots %>
        </div>
      <% end %>
    </div>
  </div>

  <!-- Start Button -->
  <div class="text-center" style="position: fixed; bottom: 0; left: 0; right: 0; background: var(--color-surface); border-top: 1px solid var(--color-border); padding: 1rem; z-index: 10;">
    <%= form_with url: begin_execution_workflow_path(@workflow), method: :post, local: true,
        class: "inline-block",
        data: { controller: "form-submit", action: "submit->form-submit#submit" } do |form| %>
      <%= form.submit "Start Workflow",
          data: { form_submit_target: "submit" },
          aria: { label: "Start workflow: #{@workflow.title}" },
          class: "btn btn--positive btn--lg" %>
    <% end %>
    <p class="text-sm mt-2">Begin step-by-step guided execution</p>
  </div>

  <!-- Workflow Steps Preview -->
  <% ar_steps = @workflow.steps.order(:position) %>
  <% if ar_steps.any? %>
    <div class="mt-6">
      <div class="card">
        <div class="card__header">
          <h3 class="font-semibold">Workflow Steps (<%= ar_steps.size %> total)</h3>
        </div>
        <div class="card__body">
          <div role="list" style="display: flex; flex-direction: column; gap: 0.75rem;">
            <% ar_steps.each_with_index do |step, index| %>
              <div class="flex items-start gap-3 p-3 rounded-lg" style="background: var(--color-surface-alt);" role="listitem">
                <span class="step-card__number flex-shrink-0">
                  <%= index + 1 %>
                </span>
                <div class="flex-1" style="min-width: 0;">
                  <h4 class="font-semibold flex items-center gap-1">
                    <%= step_type_svg_icon(step.step_type, css_classes: "icon icon--sm") %> <%= step.title %>
                  </h4>
                  <% snippet = step.try(:question) || step.try(:content)&.to_s || step.try(:instructions)&.to_s %>
                  <% if snippet.present? %>
                    <div class="text-sm mt-1">
                      <%= truncate(strip_tags(snippet.to_s), length: 200) %>
                    </div>
                  <% end %>
                  <span class="badge badge--<%= step.step_type %> mt-2">
                    <%= step_type_label(step.step_type) %>
                  </span>
                </div>
              </div>
            <% end %>
          </div>
        </div>
      </div>
    </div>
  <% end %>

  <!-- Back Link -->
  <div class="mt-6 text-center">
    <%= link_to workflows_path, class: "btn btn--plain btn--sm" do %>
      <svg class="icon icon--sm" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
      </svg>
      Back to Workflows
    <% end %>
  </div>
</div>
