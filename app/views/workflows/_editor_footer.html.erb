<%#
  Editor Footer — sticky save/cancel bar.

  Local variables:
  - workflow: Workflow object
%>
<div class="wf-sticky-footer">
  <div class="wf-sticky-footer__inner">
    <div id="editor-status" class="text-sm font-medium">
      Ready
    </div>
    <div class="wf-btn-group">
      <%= link_to "Cancel", workflow_path(workflow), class: "btn btn--plain" %>
      <button type="button"
              data-controller="modal-trigger"
              data-modal-trigger-modal-id-value="save-template-modal"
              data-action="click->modal-trigger#open"
              class="btn btn--plain">
        Save as Template
      </button>
      <%= link_to "Done Editing", workflow_path(workflow), class: "btn btn--primary" %>
    </div>
  </div>
</div>
