<dialog data-dialog-target="dialog" class="dialog" style="position: fixed; inset: 0; margin: auto; max-width: 28rem; width: 100%; height: fit-content;">
  <div class="dialog__body">
    <h3 class="dialog__title mb-4">Publish Workflow</h3>
    <p class="text-sm mb-4">
      This creates a new published version. Agents running this workflow will use the new version.
    </p>
    <%= form_with url: workflow_publishing_path(workflow), method: :post, data: { turbo: false }, style: "display: flex; flex-direction: column; gap: 1rem;" do |f| %>
      <div class="form-group">
        <%= f.label :changelog, "Changelog (optional)", class: "form-label" %>
        <%= f.text_area :changelog, rows: 3, placeholder: "What changed in this version?",
            class: "form-textarea" %>
      </div>
      <div class="flex justify-end gap-3">
        <button type="button" data-action="dialog#close"
                class="btn btn--plain">
          Cancel
        </button>
        <%= f.submit "Publish", class: "btn btn--positive" %>
      </div>
    <% end %>
  </div>
</dialog>
