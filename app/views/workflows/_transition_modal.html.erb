<%# Modal for editing graph transitions between steps %>
<div id="transition-modal"
     class="is-hidden dialog-overlay"
     data-controller="transition-editor"
     data-transition-editor-workflow-id-value="<%= @workflow.id %>">
  <div class="dialog-wrapper">
    <div class="dialog-centering">
      <%# Backdrop %>
      <div class="dialog-backdrop"
           data-action="click->transition-editor#close"></div>

      <%# Center modal spacer %>
      <span class="dialog-spacer">&#8203;</span>

      <%# Modal panel %>
      <div class="dialog dialog--md">
        <div class="dialog__header">
          <h3 class="dialog__title">Edit Transition</h3>
          <button type="button"
                  data-action="click->transition-editor#close"
                  class="dialog__close">
            <span class="sr-only">Close</span>
            <svg class="icon icon--sm" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
            </svg>
          </button>
        </div>

        <div class="dialog__body" style="display: flex; flex-direction: column; gap: 1rem;">
          <%# From Step (read-only) %>
          <div class="form-group">
            <label class="form-label">From Step</label>
            <div class="form-input" style="background: var(--color-surface-muted);"
                 data-transition-editor-target="fromStep">
              --
            </div>
          </div>

          <%# To Step (read-only) %>
          <div class="form-group">
            <label class="form-label">To Step</label>
            <div class="form-input" style="background: var(--color-surface-muted);"
                 data-transition-editor-target="toStep">
              --
            </div>
          </div>

          <%# Condition %>
          <div class="form-group">
            <label class="form-label">
              Condition
              <span class="font-normal">(optional)</span>
            </label>
            <input type="text"
                   data-transition-editor-target="condition"
                   placeholder="e.g., answer == 'yes'"
                   class="form-input">
            <p class="form-hint">
              Leave empty for default/unconditional transition. Use format: variable == 'value' or variable != 'value'
            </p>
          </div>

          <%# Label %>
          <div class="form-group">
            <label class="form-label">
              Label
              <span class="font-normal">(optional)</span>
            </label>
            <input type="text"
                   data-transition-editor-target="label"
                   placeholder="e.g., Yes, No, Default"
                   class="form-input">
            <p class="form-hint">
              Display label for this transition in the flow preview.
            </p>
          </div>

          <%# Hidden fields for step IDs %>
          <input type="hidden" data-transition-editor-target="fromStepId">
          <input type="hidden" data-transition-editor-target="toStepId">
        </div>

        <div class="dialog__footer flex items-center justify-between">
          <button type="button"
                  data-action="click->transition-editor#deleteTransition"
                  class="btn btn--negative btn--sm">
            Delete Transition
          </button>
          <div class="flex gap-3">
            <button type="button"
                    data-action="click->transition-editor#close"
                    class="btn btn--plain">
              Cancel
            </button>
            <button type="button"
                    data-action="click->transition-editor#saveTransition"
                    class="btn btn--primary">
              Save Transition
            </button>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>
