<%# Workflow list item partial with caching
    Cache key includes: workflow, current_user, selected_group, and folders
    Busts when: workflow updated, user permissions change, group context changes, or folders change %>
<% cache [workflow, current_user, @selected_group, current_user&.role, @folders&.map(&:id)] do %>
  <%
    border_color = case workflow.dominant_step_type
                   when 'question' then 'border-l-blue-500'
                   when 'action' then 'border-l-amber-500'
                   when 'message' then 'border-l-purple-500'
                   when 'resolve' then 'border-l-emerald-500'
                   when 'escalate' then 'border-l-red-500'
                   when 'sub_flow' then 'border-l-cyan-500'
                   else 'border-l-slate-300 dark:border-l-slate-600'
                   end
  %>
  <li class="group hover:bg-slate-50 dark:hover:bg-slate-800/50 transition-colors duration-150 rounded-xl border-l-4 <%= border_color %> animate-fade-in-up" style="animation-delay: <%= local_assigns[:index].to_i * 0.05 %>s;">
    <div class="px-6 py-5 sm:px-6">
      <div class="flex items-center justify-between">
        <div class="flex items-center flex-1 min-w-0">
          <div class="flex-shrink-0 mr-4">
            <div class="w-10 h-10 rounded-lg bg-slate-100 dark:bg-slate-700 flex flex-wrap items-center justify-center gap-0.5 p-1 overflow-hidden">
              <%= step_type_composition_dots(workflow) || content_tag(:svg, content_tag(:path, nil, 'stroke-linecap': 'round', 'stroke-linejoin': 'round', 'stroke-width': '2', d: 'M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z'), class: 'h-6 w-6 text-slate-400 dark:text-slate-500', fill: 'none', viewBox: '0 0 24 24', stroke: 'currentColor') %>
            </div>
          </div>
          <div class="ml-4 flex-1 min-w-0">
            <div class="text-base font-semibold text-gray-900 dark:text-gray-100 mb-1 flex items-center gap-2">
              <%= link_to workflow.title, workflow_path(workflow), class: "hover:text-slate-600 dark:hover:text-slate-400 transition-colors duration-200" %>
              <%= workflow_status_badge(workflow) %>
              <% if workflow.is_public? %>
                <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-medium bg-emerald-100 dark:bg-emerald-900/30 text-emerald-800 dark:text-emerald-300" title="Public workflow">
                  Public
                </span>
              <% end %>
              <% if workflow.user != current_user %>
                <span class="text-xs text-gray-500 dark:text-gray-400">by <%= workflow.user.email %></span>
              <% end %>
              <% if workflow.primary_group.present? && workflow.primary_group != @selected_group %>
                <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-medium bg-slate-100 dark:bg-slate-700 text-slate-800 dark:text-slate-300">
                  <%= workflow.primary_group.name %>
                </span>
              <% end %>
            </div>
            <div class="text-sm text-gray-600 dark:text-gray-400 mb-1 line-clamp-2">
              <%= workflow.description_text.presence || "No description" %>
            </div>
            <div class="text-xs text-gray-500 dark:text-gray-500 mt-1">
              <span><%= pluralize(workflow.steps&.length || 0, "step") %> - Updated <%= time_ago_in_words(workflow.updated_at) %> ago</span>
            </div>
          </div>
        </div>
        <div class="flex items-center space-x-3 ml-4">
          <%= link_to start_workflow_path(workflow), class: "px-4 py-2 text-sm font-medium text-white bg-emerald-500 hover:bg-emerald-600 rounded-full shadow-md hover:shadow-lg transition-all duration-300 hover:scale-105 inline-flex items-center" do %>
            <svg class="w-4 h-4 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14.752 11.168l-3.197-2.132A1 1 0 0010 9.87v4.263a1 1 0 001.555.832l3.197-2.132a1 1 0 000-1.664z" />
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
            Start
          <% end %>
          <%= link_to workflow_path(workflow), class: "px-4 py-2 text-sm font-medium text-slate-600 dark:text-slate-400 bg-slate-50 dark:bg-slate-800 rounded-full hover:bg-slate-100 dark:hover:bg-slate-700 transition-all duration-200 hover:scale-105" do %>
            View
          <% end %>
          <% if workflow.can_be_edited_by?(current_user) %>
            <%= link_to edit_workflow_path(workflow), class: "px-4 py-2 text-sm font-medium text-gray-700 dark:text-gray-300 bg-slate-100 dark:bg-slate-700 rounded-full hover:bg-slate-200 dark:hover:bg-slate-600 transition-all duration-200 hover:scale-105" do %>
              Edit
            <% end %>
          <% end %>
          <% if workflow.can_be_deleted_by?(current_user) %>
            <%= link_to workflow_path(workflow), data: { turbo_method: :delete, turbo_confirm: "Are you sure?" }, class: "opacity-0 group-hover:opacity-100 transition-opacity duration-200 p-2 text-slate-400 hover:text-red-500 dark:hover:text-red-400", title: "Delete workflow" do %>
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" />
              </svg>
            <% end %>
          <% end %>
          <% if @selected_group.present? && @folders.present? && @folders.any? && workflow.can_be_edited_by?(current_user) %>
            <% current_gw = workflow.group_workflows.find_by(group_id: @selected_group.id) %>
            <%= form_with url: move_workflow_folder_path, method: :patch, class: "inline-flex items-center" do |f| %>
              <%= hidden_field_tag :workflow_id, workflow.id %>
              <%= hidden_field_tag :group_id, @selected_group.id %>
              <select name="folder_id" data-controller="move-to-folder" data-action="change->move-to-folder#submit"
                      class="text-xs border border-slate-200 dark:border-slate-700 rounded-lg bg-white dark:bg-slate-800 text-slate-600 dark:text-slate-400 px-2 py-1.5 focus:ring-2 focus:ring-slate-500 transition-colors cursor-pointer">
                <option value="uncategorized" <%= 'selected' if current_gw&.folder_id.nil? %>>Uncategorized</option>
                <% @folders.each do |folder| %>
                  <option value="<%= folder.id %>" <%= 'selected' if current_gw&.folder_id == folder.id %>><%= folder.name %></option>
                <% end %>
              </select>
            <% end %>
          <% end %>
        </div>
      </div>
    </div>
  </li>
<% end %>
