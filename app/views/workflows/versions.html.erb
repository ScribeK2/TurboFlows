<div class="page-content">
  <div class="wf-page-header mb-6">
    <h1 class="page-title">Version History: <%= @workflow.title %></h1>
    <%= link_to "Back to Workflow", @workflow, class: "btn btn--plain btn--sm" %>
  </div>

  <% if @versions.size >= 2 %>
    <div class="card p-4 mb-4">
      <h2 class="font-semibold mb-3">Compare Versions</h2>
      <%= form_tag diff_workflow_versions_path(@workflow), method: :get, class: "flex items-center gap-3 flex-wrap" do %>
        <label class="text-sm">From:</label>
        <%= select_tag :v1, options_from_collection_for_select(@versions, :id, ->(v) { "v#{v.version_number}" }), class: "input input--sm" %>
        <label class="text-sm">To:</label>
        <%= select_tag :v2, options_from_collection_for_select(@versions, :id, ->(v) { "v#{v.version_number}" }, @versions.first.id), class: "input input--sm" %>
        <%= submit_tag "Compare", class: "btn btn--primary btn--sm" %>
      <% end %>
    </div>
  <% end %>

  <% if @versions.any? %>
    <div class="table-wrap">
      <table class="table">
        <thead>
          <tr>
            <th>Version</th>
            <th>Published By</th>
            <th>Date</th>
            <th>Changelog</th>
            <th>Actions</th>
          </tr>
        </thead>
        <tbody>
          <% @versions.each do |version| %>
            <tr class="<%= version == @workflow.published_version ? 'is-current' : '' %>">
              <td class="font-medium">
                v<%= version.version_number %>
                <% if version == @workflow.published_version %>
                  <span class="badge badge--published ml-2">Current</span>
                <% end %>
              </td>
              <td class="text-sm"><%= version.published_by.email %></td>
              <td class="text-sm"><%= version.published_at.strftime("%b %d, %Y %H:%M") %></td>
              <td class="text-sm"><%= version.changelog.presence || "—" %></td>
              <td class="text-sm">
                <div class="flex gap-3">
                  <%= link_to "View", workflow_version_path(@workflow, version), class: "btn btn--plain btn--sm" %>
                  <% if @workflow.can_be_edited_by?(current_user) && version != @workflow.published_version %>
                    <%= button_to "Restore", restore_workflow_version_path(@workflow, version),
                        method: :post,
                        class: "btn btn--warning btn--sm",
                        data: { turbo_confirm: "Restore version #{version.version_number}? This will overwrite the current draft steps." } %>
                  <% end %>
                </div>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  <% else %>
    <div class="card p-8 text-center">
      <p>No published versions yet.</p>
      <p class="text-sm mt-2">Use the Publish button on the workflow page to create the first version.</p>
    </div>
  <% end %>
</div>
