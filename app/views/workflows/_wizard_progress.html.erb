<nav role="navigation" aria-label="Workflow creation progress" class="wizard-progress mb-6" data-controller="wizard-navigation">
  <div class="wizard-progress__steps">
    <!-- Step 1 -->
    <div class="wizard-progress__step">
      <% if current_step > 1 && local_assigns[:workflow] %>
        <%= link_to step1_workflow_path(workflow), class: "wizard-progress__indicator is-done", title: "Go back to Name & Group" do %>
          <svg class="icon icon--sm" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
          </svg>
        <% end %>
      <% else %>
        <div class="wizard-progress__indicator <%= current_step >= 1 ? 'is-active' : '' %>"
             <%= 'aria-current="step"' if current_step == 1 %>>
          <span class="text-sm font-semibold">1</span>
        </div>
      <% end %>
      <div class="wizard-progress__label">
        <p class="text-sm font-medium <%= current_step == 1 ? 'text-active' : (current_step > 1 ? 'text-done' : '') %>">Name & Group</p>
        <p class="text-xs">Basic information</p>
      </div>
    </div>

    <!-- Connector Line -->
    <div class="wizard-progress__connector <%= current_step > 1 ? 'is-done' : '' %>"></div>

    <!-- Step 2 -->
    <div class="wizard-progress__step">
      <% if current_step > 2 && local_assigns[:workflow] %>
        <%= link_to step2_workflow_path(workflow), class: "wizard-progress__indicator is-done", title: "Go back to Add Steps" do %>
          <svg class="icon icon--sm" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
          </svg>
        <% end %>
      <% elsif current_step == 2 %>
        <div class="wizard-progress__indicator is-active" aria-current="step">
          <span class="text-sm font-semibold">2</span>
        </div>
      <% else %>
        <div class="wizard-progress__indicator">
          <span class="text-sm font-semibold">2</span>
        </div>
      <% end %>
      <div class="wizard-progress__label">
        <p class="text-sm font-medium <%= current_step == 2 ? 'text-active' : (current_step > 2 ? 'text-done' : '') %>">Add Steps</p>
        <p class="text-xs">Build your workflow</p>
      </div>
    </div>

    <!-- Connector Line -->
    <div class="wizard-progress__connector <%= current_step > 2 ? 'is-done' : '' %>"></div>

    <!-- Step 3 -->
    <div class="wizard-progress__step">
      <div class="wizard-progress__indicator <%= current_step == 3 ? 'is-active' : '' %>"
           <%= 'aria-current="step"' if current_step == 3 %>>
        <span class="text-sm font-semibold">3</span>
      </div>
      <div class="wizard-progress__label">
        <p class="text-sm font-medium <%= current_step == 3 ? 'text-active' : '' %>">Review & Launch</p>
        <p class="text-xs">Finalize workflow</p>
      </div>
    </div>
  </div>
</nav>
