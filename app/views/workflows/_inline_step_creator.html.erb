<%#
  Inline Step Creator

  Sprint 3: Navigation & Visual Improvements
  Inline step creation between existing steps.
  Shows a "+" button that expands to show step type options.

  Local variables:
  - after_index: The index after which to insert the new step
%>

<% after_index ||= -1 %>

<div data-controller="inline-step-creator"
     data-inline-step-creator-after-index-value="<%= after_index %>"
     class="inline-step-creator my-1">

  <%# Collapsed state - hover-reveal dashed line with + button %>
  <div data-inline-step-creator-target="addButton"
       class="inline-step-creator__trigger">
    <div class="inline-step-creator__line"></div>
    <button type="button"
            data-action="click->inline-step-creator#expand"
            class="inline-step-creator__add-btn"
            title="Add a new step here">
      <svg class="icon icon--sm" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/>
      </svg>
    </button>
    <div class="inline-step-creator__line"></div>
  </div>

  <%# Expanded state - step type selector %>
  <div data-inline-step-creator-target="typeSelector"
       class="hidden">
    <div class="card p-3">
      <div class="flex items-center justify-between mb-2">
        <span class="text-xs font-medium">Add Step</span>
        <button type="button"
                data-action="click->inline-step-creator#collapse"
                class="btn btn--plain p-1">
          <svg class="icon icon--sm" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
          </svg>
        </button>
      </div>

      <% if @workflow&.graph_mode? %>
        <%# Graph Mode: Show Question, Message, Action, Escalate, Resolve %>
        <div class="inline-step-creator__grid inline-step-creator__grid--5">
          <button type="button"
                  data-action="click->inline-step-creator#createStep"
                  data-step-type="question"
                  class="inline-step-creator__type-btn inline-step-creator__type-btn--question">
            <span class="text-xs font-medium text-white">Question</span>
          </button>

          <button type="button"
                  data-action="click->inline-step-creator#createStep"
                  data-step-type="message"
                  class="inline-step-creator__type-btn inline-step-creator__type-btn--message">
            <span class="text-xs font-medium text-white">Message</span>
          </button>

          <button type="button"
                  data-action="click->inline-step-creator#createStep"
                  data-step-type="action"
                  class="inline-step-creator__type-btn inline-step-creator__type-btn--action">
            <span class="text-xs font-medium text-white">Action</span>
          </button>

          <button type="button"
                  data-action="click->inline-step-creator#createStep"
                  data-step-type="escalate"
                  class="inline-step-creator__type-btn inline-step-creator__type-btn--escalate">
            <span class="text-xs font-medium text-white">Escalate</span>
          </button>

          <button type="button"
                  data-action="click->inline-step-creator#createStep"
                  data-step-type="resolve"
                  class="inline-step-creator__type-btn inline-step-creator__type-btn--resolve">
            <span class="text-xs font-medium text-white">Resolve</span>
          </button>
        </div>
      <% else %>
        <%# Non-graph mode: Same step types without graph-specific UI %>
        <div class="inline-step-creator__grid inline-step-creator__grid--4">
          <button type="button"
                  data-action="click->inline-step-creator#createStep"
                  data-step-type="question"
                  class="inline-step-creator__type-btn inline-step-creator__type-btn--question">
            <span class="text-xs font-medium text-white">Question</span>
          </button>

          <button type="button"
                  data-action="click->inline-step-creator#createStep"
                  data-step-type="action"
                  class="inline-step-creator__type-btn inline-step-creator__type-btn--action">
            <span class="text-xs font-medium text-white">Action</span>
          </button>

          <button type="button"
                  data-action="click->inline-step-creator#createStep"
                  data-step-type="message"
                  class="inline-step-creator__type-btn inline-step-creator__type-btn--message">
            <span class="text-xs font-medium text-white">Message</span>
          </button>

          <button type="button"
                  data-action="click->inline-step-creator#createStep"
                  data-step-type="sub_flow"
                  class="inline-step-creator__type-btn inline-step-creator__type-btn--sub-flow">
            <span class="text-xs font-medium text-white">Sub-flow</span>
          </button>
        </div>
      <% end %>
    </div>
  </div>
</div>
