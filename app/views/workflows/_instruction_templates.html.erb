<%#
  Instruction Templates Panel

  Sprint 2: Action Step Simplification
  Pre-written instruction snippets for common CSR tasks.
  Templates are organized by category and can be inserted with one click.

  Note: The toggle button is rendered separately in _action_fields.html.erb
  to keep it in the header flex row. This panel renders at full column width.
%>

<%# Template Panel (Initially Hidden) - relative z-20 ensures it stacks above the Live Preview sticky pane %>
<div data-instruction-template-target="templatePanel"
     class="hidden card mb-3" style="overflow: hidden; position: relative; z-index: 20;">

  <%# Header %>
  <div class="card__header flex items-center justify-between">
    <div class="flex items-center gap-2">
      <svg class="icon icon--sm" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>
      </svg>
      <h4 class="font-semibold text-sm">Instruction Templates</h4>
    </div>
    <div class="flex items-center gap-3">
      <%# Insert Mode Toggle %>
      <label class="flex items-center gap-2 text-xs cursor-pointer">
        <input type="checkbox"
               data-action="change->instruction-template#toggleInsertMode"
               class="form-checkbox">
        Replace existing text
      </label>
      <button type="button"
              data-action="click->instruction-template#closePanel"
              class="btn btn--plain p-1">
        <svg class="icon icon--sm" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
        </svg>
      </button>
    </div>
  </div>

  <%# Search Bar %>
  <div class="px-4 py-2" style="border-bottom: 1px solid var(--color-border);">
    <div class="relative">
      <svg class="icon icon--sm absolute left-3 top-1/2 -translate-y-1/2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/>
      </svg>
      <input type="text"
             placeholder="Search templates..."
             data-instruction-template-target="searchInput"
             data-action="input->instruction-template#searchTemplates"
             class="form-input w-full pl-9">
    </div>
  </div>

  <%# Category Tabs %>
  <div data-instruction-template-target="categoryTabs"
       class="flex gap-1 px-4 py-2 overflow-x-auto" style="border-bottom: 1px solid var(--color-border);">
    <button type="button"
            data-action="click->instruction-template#selectCategory"
            data-category="greeting"
            class="btn btn--secondary btn--sm inline-flex items-center gap-1 whitespace-nowrap">
      <svg class="icon icon--xs" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"/>
      </svg>
      Greeting
    </button>
    <button type="button"
            data-action="click->instruction-template#selectCategory"
            data-category="verification"
            class="btn btn--plain btn--sm inline-flex items-center gap-1 whitespace-nowrap">
      <svg class="icon icon--xs" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/>
      </svg>
      Verification
    </button>
    <button type="button"
            data-action="click->instruction-template#selectCategory"
            data-category="troubleshooting"
            class="btn btn--plain btn--sm inline-flex items-center gap-1 whitespace-nowrap">
      <svg class="icon icon--xs" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.066 2.573c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.573 1.066c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.066-2.573c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"/>
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/>
      </svg>
      Troubleshooting
    </button>
    <button type="button"
            data-action="click->instruction-template#selectCategory"
            data-category="email"
            class="btn btn--plain btn--sm inline-flex items-center gap-1 whitespace-nowrap">
      <svg class="icon icon--xs" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
      </svg>
      Email
    </button>
    <button type="button"
            data-action="click->instruction-template#selectCategory"
            data-category="dns"
            class="btn btn--plain btn--sm inline-flex items-center gap-1 whitespace-nowrap">
      <svg class="icon icon--xs" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 12a9 9 0 01-9 9m9-9a9 9 0 00-9-9m9 9H3m9 9a9 9 0 01-9-9m9 9c1.657 0 3-4.03 3-9s-1.343-9-3-9m0 18c-1.657 0-3-4.03-3-9s1.343-9 3-9m-9 9a9 9 0 019-9"/>
      </svg>
      DNS
    </button>
    <button type="button"
            data-action="click->instruction-template#selectCategory"
            data-category="closing"
            class="btn btn--plain btn--sm inline-flex items-center gap-1 whitespace-nowrap">
      <svg class="icon icon--xs" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>
      </svg>
      Closing
    </button>
  </div>

  <%# Template List %>
  <div data-instruction-template-target="templateList"
       class="p-3 overflow-y-auto" style="max-height: 16rem; display: flex; flex-direction: column; gap: 0.5rem;">
    <%# Templates will be rendered by JavaScript %>
    <div class="text-center py-6">
      <div>Loading templates...</div>
    </div>
  </div>

  <%# Preview Panel (Hidden by default) %>
  <div data-instruction-template-target="previewPanel"
       class="hidden px-4 py-3" style="border-top: 1px solid var(--color-border); background: var(--color-surface-muted);">
    <div class="form-hint mb-1">Preview:</div>
    <pre class="text-sm whitespace-pre-wrap font-mono card p-2 rounded" style="border: 1px solid var(--color-border);"></pre>
  </div>

  <%# Help Text %>
  <div class="card__footer">
    <p class="form-hint mb-0">
      <svg class="icon icon--xs inline-block align-text-bottom mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
      </svg>
      Click a template to insert it. By default, text is appended to existing instructions.
    </p>
  </div>
</div>
