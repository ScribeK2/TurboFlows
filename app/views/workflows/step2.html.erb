<div class="page-content">
  <div class="wizard-page__header">
    <h1 class="page-title">Add Steps</h1>
    <p class="wizard-page__subtitle">Step 2 of 3: Build your workflow by adding steps.</p>
  </div>

  <%= render partial: "wizard_progress", locals: { current_step: 2, workflow: @workflow } %>

  <%= render partial: "shared/error_messages", locals: { object: @workflow, container_class: "mb-6" } %>

  <%# Steps are saved individually via Turbo Frame inline editing %>
  <div class="card p-6 wizard-card-body">
    <% ar_steps = @workflow.steps.includes(:transitions, :incoming_transitions).order(:position) %>
    <%= render "workflows/steps_list", workflow: @workflow, steps: ar_steps %>
  </div>

  <%# Navigation Buttons %>
  <div class="wizard-page__footer mt-4">
    <%= link_to step1_workflow_path(@workflow), class: "btn btn--plain" do %>
      <svg class="icon icon--sm" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
      </svg>
      Previous
    <% end %>

    <div class="flex items-center gap-3">
      <% if ar_steps.any? %>
        <span class="text-sm">
          <%= ar_steps.size %> step<%= ar_steps.size != 1 ? 's' : '' %> added
        </span>
      <% end %>

      <%= link_to "Next: Review →", step3_workflow_path(@workflow), class: "btn btn--primary" %>
    </div>
  </div>
</div>
