<div class="page-content">
  <div class="mb-6">
    <h1 class="page-title">Add Steps</h1>
    <p class="text-sm mt-1">Step 2 of 3: Build your workflow by adding steps.</p>
  </div>

  <%= render partial: "wizard_progress", locals: { current_step: 2, workflow: @workflow } %>

  <%= form_with model: @workflow, url: update_step2_workflow_path(@workflow), method: :patch, local: true, data: { turbo: false, controller: "error-highlight" }, class: "" do |form| %>
    <%= render partial: "shared/error_messages", locals: { object: @workflow, container_class: "mb-6" } %>

    <%# Mode Toggle (graph mode only) %>
    <% if @workflow.graph_mode? %>
      <div class="mb-4" data-controller="view-mode-toggle">
        <input type="hidden" name="workflow[editor_mode]" value="list" data-view-mode-toggle-target="modeInput">
        <div class="wf-mode-toggle">
          <button type="button"
                  data-action="click->view-mode-toggle#switchToList"
                  data-view-mode-toggle-target="listBtn"
                  class="wf-mode-toggle__btn is-active">
            List
          </button>
          <button type="button"
                  data-action="click->view-mode-toggle#switchToVisual"
                  data-view-mode-toggle-target="visualBtn"
                  class="wf-mode-toggle__btn">
            Visual
          </button>
        </div>
      </div>
    <% end %>

    <%# List Editor Container %>
    <div id="list-editor-container">

    <%# Two-Column Layout: Sidebar + Main Content %>
    <div class="flex gap-6">
      <%# Step Outline Sidebar (shown for workflows with >3 steps) %>
      <% if @workflow.steps.any? && @workflow.steps.size > 3 %>
        <div class="hidden lg:block flex-shrink-0" style="position: sticky; top: 6rem; align-self: start;">
          <%= render partial: "step_outline", locals: { workflow: @workflow } %>
        </div>
      <% end %>

      <%# Main Content %>
      <div class="flex-1" style="min-width: 0;">
        <div class="card p-6" style="display: flex; flex-direction: column; gap: 1.5rem;">
          <div data-controller="workflow-builder variable-autocomplete"
               data-workflow-builder-workflow-id-value="<%= @workflow.id %>"
               data-workflow-builder-graph-mode-value="<%= @workflow.graph_mode? %>"
               data-workflow-builder-debug-value="<%= Rails.env.development? %>"
               data-workflow-builder-wizard-next-url-value="<%= step3_workflow_path(@workflow) %>"
               data-variable-autocomplete-workflow-id-value="<%= @workflow.id %>"
               id="workflow-builder-container">

            <%# Header with Add Step Buttons %>
            <div class="flex items-center justify-between gap-4 mb-4" style="flex-wrap: wrap;" data-floating-step-adder-target="sentinel">
              <label class="form-label mb-0">
                Workflow Steps
                <% if @workflow.steps.any? %>
                  <span class="text-xs ml-2">(<%= @workflow.steps.size %> step<%= @workflow.steps.size != 1 ? 's' : '' %>)</span>
                <% end %>
              </label>
              <div class="flex gap-2" style="flex-wrap: wrap;">
                <button type="button"
                        data-action="click->workflow-builder#addStepDirect"
                        data-step-type="question"
                        class="btn btn--secondary btn--sm">
                  Question
                </button>

                <% if @workflow.graph_mode? %>
                  <button type="button" data-action="click->workflow-builder#addStepDirect" data-step-type="message" class="btn btn--sm" style="background: var(--step-message-color, #06b6d4); color: #fff;">Message</button>
                  <button type="button" data-action="click->workflow-builder#addStepDirect" data-step-type="action" class="btn btn--positive btn--sm">Action</button>
                  <button type="button" data-action="click->workflow-builder#addStepDirect" data-step-type="escalate" class="btn btn--sm" style="background: var(--step-escalate-color, #f97316); color: #fff;">Escalate</button>
                  <button type="button" data-action="click->workflow-builder#addStepDirect" data-step-type="resolve" class="btn btn--sm" style="background: var(--step-resolve-color, #22c55e); color: #fff;">Resolve</button>
                  <button type="button" data-action="click->workflow-builder#addStepDirect" data-step-type="sub_flow" class="btn btn--sm" style="background: var(--step-sub-flow-color, #6366f1); color: #fff;">Sub-flow</button>
                <% else %>
                  <button type="button" data-action="click->workflow-builder#addStepDirect" data-step-type="message" class="btn btn--sm" style="background: var(--step-message-color, #06b6d4); color: #fff;">Message</button>
                  <button type="button" data-action="click->workflow-builder#addStepDirect" data-step-type="action" class="btn btn--positive btn--sm">Action</button>
                  <button type="button" data-action="click->workflow-builder#addStepDirect" data-step-type="sub_flow" class="btn btn--sm" style="background: var(--step-sub-flow-color, #6366f1); color: #fff;">Sub-flow</button>
                <% end %>
              </div>
            </div>

            <%# Expand/Collapse All Controls %>
            <% if @workflow.steps.any? && @workflow.steps.size > 3 %>
              <div class="flex justify-end gap-2 mb-3" data-controller="step-controls">
                <button type="button" data-action="click->step-controls#expandAll" class="btn btn--plain btn--sm">Expand all</button>
                <span>|</span>
                <button type="button" data-action="click->step-controls#collapseAll" class="btn btn--plain btn--sm">Collapse all</button>
              </div>
            <% end %>

            <%# Steps Container %>
            <div data-workflow-builder-target="container" class="wf-steps-container">
              <% if @workflow.steps.any? %>
                <%= render partial: "inline_step_creator", locals: { after_index: -1 } %>

                <% @workflow.steps.order(:position).each_with_index do |step, index| %>
                  <%= render partial: "step_item", locals: {
                    step: step,
                    index: index,
                    workflow: @workflow,
                    expanded: @workflow.steps.size <= 5 || index == @workflow.steps.size - 1
                  } %>
                  <%= render partial: "inline_step_creator", locals: { after_index: index } %>
                <% end %>
              <% else %>
                <div class="text-center py-10">
                  <svg class="icon icon--xl mx-auto mb-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-6 9l2 2 4-4"/>
                  </svg>
                  <h3 class="font-medium mb-1">No steps yet</h3>
                  <p class="text-sm mb-4">Get started by adding your first step using the buttons above.</p>
                  <div class="flex justify-center gap-3" style="flex-wrap: wrap;">
                    <button type="button" data-action="click->workflow-builder#addStepDirect" data-step-type="question" class="btn btn--secondary btn--sm">Start with a Question</button>
                    <button type="button" data-action="click->workflow-builder#addStepDirect" data-step-type="action" class="btn btn--positive btn--sm">Start with an Action</button>
                  </div>
                </div>
              <% end %>
            </div>
          </div>

          <%# Flow Preview Section %>
          <div data-controller="flow-preview" class="mt-6">
            <%= render partial: "flow_preview" %>
          </div>
        </div>
      </div>
    </div>

    </div><%# end list-editor-container %>

    <% if @workflow.graph_mode? %>
      <%= render partial: "visual_editor", locals: { workflow: @workflow, wizard_next_url: step3_workflow_path(@workflow) } %>
    <% end %>

    <%# Navigation Buttons %>
    <div class="flex justify-between items-center pt-4 mt-4" style="border-top: 1px solid var(--color-border);">
      <%= link_to step1_workflow_path(@workflow), class: "btn btn--plain" do %>
        <svg class="icon icon--sm" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
        </svg>
        Previous
      <% end %>

      <div class="flex items-center gap-3">
        <% if @workflow.steps.any? %>
          <span class="text-sm">
            <%= @workflow.steps.size %> step<%= @workflow.steps.size != 1 ? 's' : '' %> added
          </span>
        <% end %>

        <%= form.submit "Next: Review →",
            class: "btn btn--primary",
            data: { action: "click->step-form#logSubmit" } %>
      </div>
    </div>
  <% end %>

  <%# Floating Action Button for Quick Step Adding %>
  <div data-controller="floating-step-adder" class="hidden" data-floating-step-adder-target="fab">
    <div style="position: fixed; bottom: 1.5rem; right: 1.5rem; z-index: 30;">
      <button type="button"
              data-action="click->floating-step-adder#toggle"
              data-floating-step-adder-target="toggleButton"
              class="btn btn--primary btn--circle" style="width: 3.5rem; height: 3.5rem;">
        <svg class="icon" data-floating-step-adder-target="icon" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/>
        </svg>
      </button>

      <div class="hidden editor-popover"
           data-floating-step-adder-target="popover"
           style="position: absolute; bottom: 4rem; right: 0; min-width: 11rem;">
        <p class="text-xs font-medium mb-2 px-1">Add Step</p>
        <div style="display: flex; flex-direction: column; gap: 0.375rem;">
          <button type="button" data-action="click->floating-step-adder#addStep" data-step-type="question" class="btn btn--secondary btn--sm">Question</button>
          <% if @workflow.graph_mode? %>
            <button type="button" data-action="click->floating-step-adder#addStep" data-step-type="message" class="btn btn--sm" style="background: var(--step-message-color, #06b6d4); color: #fff;">Message</button>
            <button type="button" data-action="click->floating-step-adder#addStep" data-step-type="action" class="btn btn--positive btn--sm">Action</button>
            <button type="button" data-action="click->floating-step-adder#addStep" data-step-type="escalate" class="btn btn--sm" style="background: var(--step-escalate-color, #f97316); color: #fff;">Escalate</button>
            <button type="button" data-action="click->floating-step-adder#addStep" data-step-type="resolve" class="btn btn--sm" style="background: var(--step-resolve-color, #22c55e); color: #fff;">Resolve</button>
            <button type="button" data-action="click->floating-step-adder#addStep" data-step-type="sub_flow" class="btn btn--sm" style="background: var(--step-sub-flow-color, #6366f1); color: #fff;">Sub-flow</button>
          <% else %>
            <button type="button" data-action="click->floating-step-adder#addStep" data-step-type="message" class="btn btn--sm" style="background: var(--step-message-color, #06b6d4); color: #fff;">Message</button>
            <button type="button" data-action="click->floating-step-adder#addStep" data-step-type="action" class="btn btn--positive btn--sm">Action</button>
            <button type="button" data-action="click->floating-step-adder#addStep" data-step-type="sub_flow" class="btn btn--sm" style="background: var(--step-sub-flow-color, #6366f1); color: #fff;">Sub-flow</button>
          <% end %>
        </div>
      </div>
    </div>
  </div>
</div>

<%# Graph Mode: Transition Editor Modal %>
<% if @workflow.graph_mode? %>
  <%= render partial: "transition_modal" %>
<% end %>
