<%# Branch Template Selector Partial %>
<%# Shows available templates for creating branches quickly %>

<div data-controller="branch-template-selector"
     data-branch-template-selector-variable-value="<%= local_assigns[:variable] || '' %>"
     data-branch-template-selector-answer-type-value="<%= local_assigns[:answer_type] || '' %>">

  <button type="button"
          class="btn btn--plain btn--sm flex items-center gap-1"
          data-action="click->branch-template-selector#togglePanel">
    <%= icon "squares-2x2", class: "icon icon--sm" %>
    Use Template
  </button>

  <%# Modal Backdrop %>
  <div data-branch-template-selector-target="backdrop"
       class="is-hidden dialog-backdrop"
       data-action="click->branch-template-selector#togglePanel">
  </div>

  <%# Modal Dialog - Centered %>
  <div data-branch-template-selector-target="panel"
       class="is-hidden dialog-wrapper" style="pointer-events: none;">
    <div class="dialog dialog--lg" style="max-height: 90vh; display: flex; flex-direction: column; pointer-events: auto;">
      <div class="dialog__header">
        <div>
          <h4 class="dialog__title">Branch Templates</h4>
          <p class="form-hint mt-1 mb-0">Quickly create branches using pre-built templates</p>
        </div>
        <button type="button"
                class="dialog__close"
                data-action="click->branch-template-selector#togglePanel">
          <%= icon "x-mark", class: "icon icon--sm" %>
        </button>
      </div>

      <div class="dialog__body overflow-y-auto flex-1">
        <div data-branch-template-selector-target="templatesContainer" class="grid grid-cols-2 gap-3">
          <!-- Templates will be rendered here by JavaScript -->
        </div>
      </div>

      <div data-branch-template-selector-target="customizationPanel" class="is-hidden dialog__footer flex-col flex-stretch bg-canvas-raised">
        <h5 class="text-sm font-medium mb-3">Customize Template</h5>
        <div data-branch-template-selector-target="customizationContent" class="mb-3">
          <!-- Customization options will be rendered here -->
        </div>
        <div class="flex gap-2 justify-end">
          <button type="button"
                  class="btn btn--plain"
                  data-action="click->branch-template-selector#cancelCustomization">
            Cancel
          </button>
          <button type="button"
                  class="btn btn--primary"
                  data-action="click->branch-template-selector#applyTemplate">
            Apply Template
          </button>
        </div>
      </div>
    </div>
  </div>
</div>
