<%#
  Health Panel Inner — content rendered inside the builder panel turbo-frame.

  Used by:
  - _health_panel.html.erb (wraps in turbo-frame for frame loads via src)
  - health_fixes_controller (turbo_stream.update for in-place refresh)

  Local variables:
  - workflow: Workflow object
  - health: WorkflowHealthCheck::Result
%>
<div class="builder__panel-header">
  <div class="builder__panel-header-left">
    <strong>Health</strong>
  </div>
  <button class="builder__panel-close"
          data-action="click->builder#closePanel"
          title="Close panel">
    <%= icon "x-mark" %>
  </button>
</div>

<div class="builder__panel-body">
  <% if health.clean? %>
    <%# === All Clear === %>
    <div class="health-panel__clean">
      <%= icon "check-circle", class: "health-panel__clean-icon" %>
      <span class="health-panel__clean-title">All checks passing</span>
    </div>

    <ul class="health-panel__checklist">
      <li>Reachability from start</li>
      <li>No cycles detected</li>
      <li>All terminals are Resolve steps</li>
      <li>No circular sub-flows</li>
      <li>All required fields present</li>
    </ul>
  <% else %>
    <%# === Summary === %>
    <div class="health-panel__summary">
      <% if health.summary[:errors] > 0 %>
        <span class="health-panel__count health-panel__count--error">
          <%= health.summary[:errors] %> <%= "error".pluralize(health.summary[:errors]) %>
        </span>
      <% end %>
      <% if health.summary[:warnings] > 0 %>
        <span class="health-panel__count health-panel__count--warning">
          <%= health.summary[:warnings] %> <%= "warning".pluralize(health.summary[:warnings]) %>
        </span>
      <% end %>
    </div>

    <%# === Errors Section === %>
    <% errors = health.issues.select { |_uuid, issues| issues.any? { |i| i[:severity] == :error } } %>
    <% if errors.any? %>
      <div class="health-panel__section">
        <h4 class="health-panel__section-title">Errors</h4>
        <% errors.each do |uuid, issues| %>
          <% step = workflow.steps.find { |s| s.uuid == uuid } %>
          <% issues.select { |i| i[:severity] == :error }.each do |issue| %>
            <div class="health-panel__issue">
              <div class="health-panel__issue-icon health-panel__issue-icon--error">
                <%= icon "exclamation-circle", class: "icon icon--xs" %>
              </div>
              <div class="health-panel__issue-body">
                <div class="health-panel__issue-message"><%= issue[:message] %></div>
                <% if step %>
                  <button type="button"
                          class="health-panel__issue-step"
                          data-action="click->builder#openStep"
                          data-builder-url-param="<%= panel_edit_workflow_step_path(workflow, step) %>">
                    Step <%= step.position %>: <%= step.title.presence || "Untitled" %>
                  </button>
                <% end %>
              </div>
              <% if issue[:fixable] && issue[:fix_type] %>
                <button type="button"
                        class="btn btn--sm health-panel__issue-fix"
                        data-action="click->step-warnings#fixFromPanel"
                        data-step-warnings-step-uuid-param="<%= uuid %>"
                        data-step-warnings-fix-type-param="<%= issue[:fix_type] %>">
                  Fix
                </button>
              <% end %>
            </div>
          <% end %>
        <% end %>
      </div>
    <% end %>

    <%# === Warnings Section === %>
    <% warnings = health.issues.select { |_uuid, issues| issues.any? { |i| i[:severity] == :warning } } %>
    <% if warnings.any? %>
      <div class="health-panel__section">
        <h4 class="health-panel__section-title">Warnings</h4>
        <% warnings.each do |uuid, issues| %>
          <% step = workflow.steps.find { |s| s.uuid == uuid } %>
          <% issues.select { |i| i[:severity] == :warning }.each do |issue| %>
            <div class="health-panel__issue">
              <div class="health-panel__issue-icon health-panel__issue-icon--warning">
                <%= icon "exclamation-triangle" %>
              </div>
              <div class="health-panel__issue-body">
                <div class="health-panel__issue-message"><%= issue[:message] %></div>
                <% if step %>
                  <button type="button"
                          class="health-panel__issue-step"
                          data-action="click->builder#openStep"
                          data-builder-url-param="<%= panel_edit_workflow_step_path(workflow, step) %>">
                    Step <%= step.position %>: <%= step.title.presence || "Untitled" %>
                  </button>
                <% end %>
              </div>
              <% if issue[:fixable] && issue[:fix_type] %>
                <button type="button"
                        class="btn btn--sm health-panel__issue-fix"
                        data-action="click->step-warnings#fixFromPanel"
                        data-step-warnings-step-uuid-param="<%= uuid %>"
                        data-step-warnings-fix-type-param="<%= issue[:fix_type] %>">
                  Fix
                </button>
              <% end %>
            </div>
          <% end %>
        <% end %>
      </div>
    <% end %>

    <%# === Passing Checks === %>
    <% passing_checks = [] %>
    <% graph_errors = health.issues.values.flatten.map { |i| i[:message] } %>
    <% passing_checks << "Reachability from start" unless graph_errors.any? { |m| m.include?("reachable") } %>
    <% passing_checks << "No cycles detected" unless graph_errors.any? { |m| m.include?("Cycle") } %>
    <% passing_checks << "All terminals are Resolve steps" unless graph_errors.any? { |m| m.include?("Resolve") } %>
    <% passing_checks << "No circular sub-flows" unless graph_errors.any? { |m| m.include?("sub-flow") || m.include?("Sub-flow") } %>
    <% passing_checks << "All required fields present" unless graph_errors.any? { |m| m.include?("required") } %>
    <% if passing_checks.any? %>
      <div class="health-panel__section">
        <h4 class="health-panel__section-title">Passing</h4>
        <ul class="health-panel__checklist">
          <% passing_checks.each do |check| %>
            <li><%= check %></li>
          <% end %>
        </ul>
      </div>
    <% end %>
  <% end %>
</div>
